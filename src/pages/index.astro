---
import '../styles/global.css';
const p = Astro.url.pathname;
const lc = (href: string, active: string, inactive: string) =>
  p === href || p === href + '/' ? active : inactive;
---
<!doctype html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>SkyWatch – Tableau de bord</title>
  <script is:inline src="/lib/dark-mode.js"></script>
</head>

<body class="text-gray-900 dark:text-gray-100 min-h-screen flex bg-slate-50 dark:bg-gray-950">

  <!-- ─ Sidebar ─────────────────────────────────────────────────────────────── -->
  <aside class="hidden lg:flex flex-col w-56 shrink-0 sticky top-0 h-screen
                border-r border-gray-200 dark:border-gray-800
                bg-white dark:bg-gray-900
                px-4 py-6 overflow-y-auto">
    <div class="mb-6">
      <div class="text-2xl font-bold tracking-tight text-gray-900 dark:text-white">🛡 SkyWatch</div>
      <div class="text-gray-400 dark:text-gray-500 text-xs mt-1">Superviseur dispatch</div>
    </div>
    <nav class="flex flex-col gap-1 text-sm">
      <div class="text-[10px] uppercase font-semibold text-gray-400 dark:text-gray-600 tracking-widest mb-2">Navigation</div>
      <a href="/"
         aria-current={p === '/' ? 'page' : undefined}
         class={`flex items-center gap-2 px-3 py-2 rounded-lg transition font-medium ${lc('/', 'bg-blue-50 dark:bg-blue-950 text-blue-700 dark:text-blue-300 font-semibold pointer-events-none', 'text-gray-600 dark:text-gray-400 hover:bg-blue-50 dark:hover:bg-blue-950 hover:text-blue-700 dark:hover:text-blue-400')}`}
      >🗺️ Tableau de bord</a>
      <div class="mt-4 pt-4 border-t border-gray-100 dark:border-gray-800">
        <div class="text-[10px] uppercase font-semibold text-gray-400 dark:text-gray-600 tracking-widest mb-2">Outils</div>
        <a href="/briefing"
           aria-current={p === '/briefing' ? 'page' : undefined}
           class={`flex items-center gap-2 px-3 py-2 rounded-lg transition font-medium ${lc('/briefing', 'bg-purple-50 dark:bg-purple-950 text-purple-700 dark:text-purple-300 font-semibold pointer-events-none', 'text-gray-600 dark:text-gray-400 hover:bg-purple-50 dark:hover:bg-purple-950 hover:text-purple-700 dark:hover:text-purple-400')}`}
        >🗒 Trame briefing</a>
        <a href="/chainages"
           aria-current={p === '/chainages' ? 'page' : undefined}
           class={`flex items-center gap-2 px-3 py-2 rounded-lg transition font-medium ${lc('/chainages', 'bg-indigo-50 dark:bg-indigo-950 text-indigo-700 dark:text-indigo-300 font-semibold pointer-events-none', 'text-gray-600 dark:text-gray-400 hover:bg-indigo-50 dark:hover:bg-indigo-950 hover:text-indigo-700 dark:hover:text-indigo-400')}`}
        >🔗 Chaînages</a>
        <a href="/crosswind"
           aria-current={p === '/crosswind' ? 'page' : undefined}
           class={`flex items-center gap-2 px-3 py-2 rounded-lg transition font-medium ${lc('/crosswind', 'bg-blue-50 dark:bg-blue-950 text-blue-700 dark:text-blue-300 font-semibold pointer-events-none', 'text-gray-600 dark:text-gray-400 hover:bg-blue-50 dark:hover:bg-blue-950 hover:text-blue-700 dark:hover:text-blue-400')}`}
        >💨 Vent de travers</a>
      </div>
    </nav>
    <div class="mt-auto pt-6 border-t border-gray-100 dark:border-gray-800 text-[10px] text-gray-400 dark:text-gray-600 leading-relaxed">
      <strong class="text-gray-500 dark:text-gray-400">Horizon :</strong> 24h glissantes<br>
      Vols AF long-courrier uniquement.
    </div>
  </aside>

  <!-- ─ Contenu ─────────────────────────────────────────────────────────────── -->
  <div class="flex-1 min-w-0 overflow-y-auto">
    <div class="max-w-7xl mx-auto px-4 py-6 xl:px-8">
      <div class="flex items-center justify-between flex-wrap gap-4 mb-6">
        <div>
          <h1 class="text-2xl font-bold tracking-tight text-gray-900 dark:text-white">🗺️ Tableau de bord</h1>
          <p class="text-gray-500 dark:text-gray-400 text-xs mt-1">Vue d'ensemble — AF long-courrier</p>
        </div>
        <button id="btn-dark" class="px-3 py-1.5 text-xs font-medium rounded-lg border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-800 hover:bg-gray-50 dark:hover:bg-gray-700 text-gray-600 dark:text-gray-300 transition">🌙 Thème</button>
      </div>
      <div id="dashboard-content" class="text-gray-400 text-sm italic text-center py-20">Chargement…</div>
    </div>
  </div>

  <script is:inline>
    document.getElementById('btn-dark')?.addEventListener('click', () => {
      document.documentElement.classList.toggle('dark');
      localStorage.setItem('theme', document.documentElement.classList.contains('dark') ? 'dark' : 'light');
    });
  </script>

</body>
</html>
