    updateAircraftFilterTiles();
  }

  function updateAircraftFilterTiles() {
    const isAll = selectedAircraftGroups.has('ALL');
    document.querySelectorAll('.ac-filter-tile').forEach(tile => {
      const group = tile.dataset.group;
      const active = !isAll && selectedAircraftGroups.has(group);
      // Actif = surligné bleu ; inactif quand filtre = mis en grisé
      if (isAll) {
        // Pas de filtre : toutes les tuiles apparaissent normales
        tile.classList.remove(
          'border-blue-400', 'dark:border-blue-500', 'bg-blue-50', 'dark:bg-blue-900/20', 'opacity-40'
        );
        tile.classList.add('border-transparent');
      } else if (active) {
