---
import type { WeatherAlert, Region } from '../types/alert';
import AlertTable from '../components/AlertTable.astro';
import { proxied } from '../lib/proxy';

export const prerender = false;

let alerts: WeatherAlert[] = [];
let error = '';
let lastUpdate = '';

try {
  const { fetchGDACS } = await import('../lib/gdacs');
  const { fetchNOAA } = await import('../lib/noaa');
  const { fetchMeteoAlarm } = await import('../lib/meteoalarm');

  const [gdacs, noaa, meteoalarm] = await Promise.all([
    fetchGDACS(),
    fetchNOAA(),
    fetchMeteoAlarm(),
  ]);

  

  const SEVERITY_ORDER = { red: 0, orange: 1, yellow: 2 };
  alerts = [...gdacs, ...noaa, ...meteoalarm]
    .sort((a, b) => SEVERITY_ORDER[a.severity] - SEVERITY_ORDER[b.severity]);

  lastUpdate = new Date().toISOString();
} catch (e) {
  error = String(e);
}
const debugRes = await fetch(proxied('https://www.gdacs.org/xml/rss.xml'));
const debugXml = await debugRes.text();

const REGIONS: Region[] = ['AMN', 'AMS', 'AMO', 'EUR', 'ASIE'];

const redCount    = alerts.filter(a => a.severity === 'red').length;
const orangeCount = alerts.filter(a => a.severity === 'orange').length;
const yellowCount = alerts.filter(a => a.severity === 'yellow').length;
---

<!doctype html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>SkyWatch – Alertes météo dispatch</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    body { background: #f0f4f8; font-family: system-ui, sans-serif; }
  </style>
</head>

<body class="text-gray-900 min-h-screen p-6 max-w-7xl mx-auto">

  <!-- Header -->
  <header class="mb-8">
    <div class="flex items-center justify-between flex-wrap gap-4">
      <div>
        <h1 class="text-3xl font-bold tracking-tight text-gray-900">
          🛰 SkyWatch
        </h1>
        <p class="text-gray-500 text-sm mt-1">
          Agrégateur d'alertes météo mondiales — Outil superviseur dispatch
        </p>
      </div>
      <div class="text-right text-xs text-gray-500">
        <div>Dernière mise à jour : {lastUpdate ? new Date(lastUpdate).toLocaleString('fr-FR') : '—'}</div>
        <div class="mt-2 flex gap-2 justify-end">
          <span class="bg-red-500 text-white px-2 py-1 rounded-full text-xs font-semibold">
            {redCount} rouge{redCount > 1 ? 's' : ''}
          </span>
          <span class="bg-orange-400 text-white px-2 py-1 rounded-full text-xs font-semibold">
            {orangeCount} orange{orangeCount > 1 ? 's' : ''}
          </span>
          <span class="bg-yellow-400 text-gray-900 px-2 py-1 rounded-full text-xs font-semibold">
            {yellowCount} jaune{yellowCount > 1 ? 's' : ''}
          </span>
        </div>
      </div>
    </div>

    <!-- Bannière horizon J+3 -->
    <div class="mt-4 bg-blue-50 border border-blue-200 rounded-xl p-3 text-sm text-blue-700">
      ℹ️ <strong>Horizon affiché :</strong> J à J+3 — Phénomènes de grande échelle uniquement
      (cyclones, blizzards, inondations majeures, séismes significatifs).
      Les orages isolés restent sous responsabilité dispatcher individuelle.
    </div>
  </header>

  <!-- Erreur de chargement -->
  {error && (
    <div class="bg-red-50 border border-red-300 rounded-xl p-4 mb-6 text-sm text-red-700">
      ⚠️ Erreur de chargement : {error}
    </div>
  )}

  <!-- Tableaux par région -->
  <main>
    {REGIONS.map(region => (
      <AlertTable region={region} alerts={alerts} />
    ))}
  </main>

  <!-- Footer -->
  <footer class="mt-12 pt-6 border-t border-gray-200 text-xs text-gray-400 flex flex-wrap gap-4 justify-between">
    <span>Sources : GDACS (UN/CE) · NOAA/NWS · MeteoAlarm (EUMETNET)</span>
    <span>SkyWatch POC v0.1 — Open source uniquement</span>
  </footer>

</body>
</html>
