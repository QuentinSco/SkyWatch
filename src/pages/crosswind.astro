  function getAircraftFilter() {
    if (selectedAircraftGroups.has('ALL') || selectedAircraftGroups.size === 0) return null;
    const allowed = new Set();
    for (const group of selectedAircraftGroups) {
      for (const code of (AIRCRAFT_FILTER_GROUPS[group] ?? [])) allowed.add(code);
