    return allowed;
  }

  function setupAircraftFilterListeners() {
    const tiles = document.querySelectorAll('.ac-filter-tile');
    tiles.forEach(tile => {
      tile.addEventListener('click', () => {
        const group = tile.dataset.group;
        if (selectedAircraftGroups.has(group)) {
          // Déselectionner
          selectedAircraftGroups.delete(group);
          if (selectedAircraftGroups.size === 0) selectedAircraftGroups.add('ALL');
        } else {
          // Sélectionner et retirer ALL
          selectedAircraftGroups.delete('ALL');
          selectedAircraftGroups.add(group);
        }
        updateAircraftFilterTiles();
        renderResults(cachedData.tafs, cachedData.flights);
      });
