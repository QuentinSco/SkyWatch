---
import '../styles/global.css';
---
<!doctype html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>SkyWatch – Trame Briefing CCO</title>
  <script is:inline src="/lib/dark-mode.js"></script>
</head>

<body class="text-gray-900 min-h-screen flex" style="background:#f8fafc">

  <!-- ─── Sidebar ─────────────────────────────────────────────────────── -->
  <aside class="hidden lg:flex flex-col w-56 shrink-0 sticky top-0 h-screen border-r border-gray-200 bg-white px-4 py-6 overflow-y-auto">
    <div class="mb-6">
      <div class="text-2xl font-bold tracking-tight text-gray-900">🛡 SkyWatch</div>
      <div class="text-gray-400 text-xs mt-1">Superviseur dispatch</div>
    </div>
    <nav class="flex flex-col gap-1 text-sm">
      <div class="text-[10px] uppercase font-semibold text-gray-400 tracking-widest mb-2">Sections</div>
      <a href="/" class="flex items-center gap-2 px-3 py-2 rounded-lg text-gray-600 hover:bg-blue-50 hover:text-blue-700 transition font-medium">🗺️ Tableau de bord</a>
      <a href="/briefing" class="flex items-center gap-2 px-3 py-2 rounded-lg bg-blue-50 text-blue-700 font-semibold">🗒 Trame briefing</a>
    </nav>
    <div class="mt-auto pt-6 border-t border-gray-100 text-[10px] text-gray-400 leading-relaxed">
      <strong class="text-gray-500">Horizon :</strong> 6h glissantes<br>
      Pré-remplissage auto — compléter avant diffusion.
    </div>
  </aside>

  <!-- ─── Contenu principal ──────────────────────────────────────────── -->
  <div class="flex-1 min-w-0 overflow-y-auto">
    <div class="max-w-3xl mx-auto px-4 py-6 xl:px-8">

      <!-- Header -->
      <div class="flex items-center justify-between flex-wrap gap-4 mb-6">
        <div>
          <h1 class="text-2xl font-bold tracking-tight text-gray-900">🗒 Trame Briefing CCO</h1>
          <p class="text-gray-500 text-xs mt-1">Pré-remplie automatiquement — horizon 6h · Compléter les champs <span class="text-orange-500 font-semibold">orange</span> avant diffusion</p>
        </div>
        <div class="flex items-center gap-2">
          <span id="briefing-age" class="text-xs text-gray-400">Chargement…</span>
          <button id="btn-refresh"
            class="flex items-center gap-1.5 px-3 py-1.5 text-xs font-medium rounded-lg border border-gray-200 bg-white hover:bg-gray-50 text-gray-600 transition">
            🔄 Actualiser
          </button>
          <button id="btn-copy"
            class="flex items-center gap-1.5 px-3 py-1.5 text-xs font-semibold rounded-lg bg-blue-600 hover:bg-blue-700 text-white transition">
            📋 Copier
          </button>
        </div>
      </div>

      <!-- Trame -->
      <div id="briefing-form" class="space-y-0 bg-white border border-gray-200 rounded-xl shadow-sm overflow-hidden">
        <div class="text-gray-400 text-sm italic px-6 py-8 text-center">Chargement de la trame…</div>
      </div>

      <!-- Toast copy -->
      <div id="toast-copy"
        class="fixed bottom-6 right-6 bg-gray-900 text-white text-xs font-medium px-4 py-2.5 rounded-xl shadow-lg opacity-0 transition-opacity duration-300 pointer-events-none">
        ✅ Trame copiée dans le presse-papier
      </div>

    </div>
  </div>

  <script is:inline>
  (function () {

    // ── Helpers ──────────────────────────────────────────────────────────────
    const SEV_COLORS = {
      red:    { dot: 'bg-red-500',    badge: 'bg-red-100 text-red-700',    border: 'border-red-200' },
      orange: { dot: 'bg-orange-400', badge: 'bg-orange-100 text-orange-700', border: 'border-orange-200' },
      yellow: { dot: 'bg-yellow-400', badge: 'bg-yellow-100 text-yellow-700', border: 'border-yellow-200' },
    };

    function sectionHeader(icon, title, badge) {
      return `
        <div class="flex items-center justify-between px-6 py-3 bg-gray-50 border-b border-gray-100">
          <span class="text-sm font-semibold text-gray-700">${icon} ${title}</span>
          <span class="text-[10px] font-medium px-2 py-0.5 rounded-full ${badge.cls}">${badge.label}</span>
        </div>`;
    }

    function nilLine() {
      return `<div class="px-6 py-3 text-sm text-gray-400 italic">- NIL</div>`;
    }

    function manualTextarea(id, placeholder, value = '') {
      return `
        <div class="px-6 py-3">
          <textarea id="${id}" rows="2" placeholder="${placeholder}"
            class="w-full text-sm border border-orange-200 rounded-lg px-3 py-2 bg-orange-50
                   placeholder-orange-300 focus:outline-none focus:ring-2 focus:ring-orange-300
                   resize-none font-mono"
          >${value}</textarea>
        </div>`;
    }

    // ── Rendu de la trame ─────────────────────────────────────────────────────
    function renderBriefing(data) {
      const form = document.getElementById('briefing-form');
      if (!form) return;
      let html = '';

      // ── Météo hors Europe ──────────────────────────────────────────────────
      html += sectionHeader('🌩', 'Météo hors Europe', { cls: 'bg-green-100 text-green-700', label: '✓ Auto · 6h' });

      if (!data.meteoHorsEurope.length) {
        html += nilLine();
      } else {
        data.meteoHorsEurope.forEach((line, i) => {
          const c = SEV_COLORS[line.severity] || SEV_COLORS.yellow;
          html += `
            <div class="px-6 py-3 border-b border-gray-50 last:border-b-0">
              <div class="flex items-start gap-3">
                <span class="mt-1.5 w-2 h-2 rounded-full flex-shrink-0 ${c.dot}"></span>
                <div class="flex-1 min-w-0">
                  <div class="flex flex-wrap items-center gap-2 text-sm font-medium text-gray-800">
                    <span>${line.phenomenon}</span>
                    <span class="font-bold">${line.iata}</span>
                    <span class="text-blue-700 font-bold">${line.flight}</span>
                    <span class="text-gray-500 text-xs">(ETA <span class="font-mono font-semibold text-gray-700">${line.etaZ}</span> · Fenêtre <span class="font-mono text-gray-700">${line.fenetreZ}</span>)</span>
                  </div>
                  <div class="mt-2 flex flex-wrap items-center gap-3">
                    <label class="flex items-center gap-1.5 text-xs text-gray-500">
                      Capa attente
                      <input type="number" min="0" placeholder="min"
                        data-field="capa" data-idx="${i}"
                        class="w-16 border border-orange-200 rounded-md px-2 py-0.5 bg-orange-50
                               text-xs font-mono focus:outline-none focus:ring-1 focus:ring-orange-300 text-center"
                      />
                    </label>
                    <label class="flex items-center gap-1.5 text-xs text-gray-500">
                      Dégagement
                      <input type="text" placeholder="ICAO / IATA"
                        data-field="deg" data-idx="${i}"
                        class="w-24 border border-orange-200 rounded-md px-2 py-0.5 bg-orange-50
                               text-xs font-mono uppercase focus:outline-none focus:ring-1 focus:ring-orange-300"
                      />
                    </label>
                  </div>
                </div>
              </div>
            </div>`;
        });
      }

      // ── Perturbation tropicale ─────────────────────────────────────────────
      html += sectionHeader('🌀', 'Perturbation tropicale', { cls: 'bg-green-100 text-green-700', label: '✓ Auto' });
      if (!data.tropicale.length) {
        html += nilLine();
      } else {
        data.tropicale.forEach(tc => {
          const affected = tc.affected.length ? ` — Terrains AF : ${tc.affected.join(', ')}` : '';
          html += `
            <div class="px-6 py-3 text-sm text-gray-800 border-b border-gray-50 last:border-b-0">
              <span class="font-bold text-red-700">${tc.name}</span>
              <span class="ml-2 text-gray-500">${tc.basin} · ${tc.category} · ${tc.windKt}kt${affected}</span>
            </div>`;
        });
      }

      // ── Activité volcanique ────────────────────────────────────────────────
      html += sectionHeader('🌋', 'Activité volcanique', { cls: 'bg-green-100 text-green-700', label: '✓ Auto · VAAC' });
      if (!data.volcanique.length) {
        html += nilLine();
      } else {
        data.volcanique.forEach(v => {
          const fl = v.flLevel ? ` — ${v.flLevel}` : '';
          html += `
            <div class="px-6 py-3 text-sm text-gray-800 border-b border-gray-50 last:border-b-0">
              <span class="font-bold">${v.volcanoName}</span>
              <span class="text-gray-500 ml-2">${v.country}${fl} (VAAC ${v.vaac})</span>
            </div>`;
        });
      }

      // ── Vent arrière SXM / SJO ─────────────────────────────────────────────
      html += sectionHeader('💨', 'Vent arrière (charge offerte)', { cls: 'bg-green-100 text-green-700', label: '✓ Auto · METAR+TAF' });
      if (!data.tailwindWatch.length) {
        html += nilLine();
      } else {
        data.tailwindWatch.forEach(tw => {
          let content = '';
          if (!tw.alert && !tw.forecastAlerts.length) {
            content = `<span class="text-gray-400 italic">NIL</span>`;
          } else {
            const parts = [];
            if (tw.alert && tw.currentTW !== null) {
              parts.push(`<span class="font-semibold text-orange-600">Vent arrière actuel ${tw.currentTW}kt ${tw.runway ?? ''}</span>`);
            }
            tw.forecastAlerts.forEach(fa => {
              const hh = d => { const x = new Date(d * 1000); return `${String(x.getUTCHours()).padStart(2,'0')}${String(x.getUTCMinutes()).padStart(2,'0')}z`; };
              parts.push(`Prévu ${fa.tailwindKt}kt ${fa.runway} (${hh(fa.periodStart)}/${hh(fa.periodEnd)})`);
            });
            content = parts.join(' · ');
          }
          html += `
            <div class="px-6 py-3 text-sm border-b border-gray-50 last:border-b-0 flex items-center gap-2">
              <span class="font-bold text-gray-800 w-10">${tw.iata}</span>
              <span class="text-gray-500">${tw.name}</span>
              <span class="ml-auto text-right">${content}</span>
            </div>`;
        });
      }

      // ── Carburant (manuel) ─────────────────────────────────────────────────
      html += sectionHeader('⛽', 'Carburant', { cls: 'bg-orange-100 text-orange-700', label: '✏️ Manuel' });
      html += manualTextarea('field-carburant', 'Ex : Afrique + BZV + HAV', data.carburant);

      // ── Géopolitique (manuel) ──────────────────────────────────────────────
      html += sectionHeader('🌐', 'Géopolitique', { cls: 'bg-orange-100 text-orange-700', label: '✏️ Manuel' });
      html += manualTextarea('field-geopolitique', 'Ex : Survol Afghanistan ok', data.geopolitique);

      // ── Effectif DSP (manuel) ──────────────────────────────────────────────
      html += sectionHeader('👥', 'Effectif DSP', { cls: 'bg-orange-100 text-orange-700', label: '✏️ Manuel' });
      html += `
        <div class="px-6 py-3">
          <input id="field-dsp" type="text" value="${data.effectifDsp || 'OK'}"
            class="w-40 border border-orange-200 rounded-lg px-3 py-1.5 bg-orange-50
                   text-sm font-mono focus:outline-none focus:ring-2 focus:ring-orange-300"
          />
        </div>`;

      form.innerHTML = html;
    }

    // ── Génération du texte à copier ──────────────────────────────────────────
    function buildCopyText() {
      if (!window._briefingData) return '';
      const d = window._briefingData;
      const lines = [];

      // ── Météo hors Europe ────────────────────────────────────────────
      lines.push('**Météo hors Europe :**');
      if (!d.meteoHorsEurope.length) {
        lines.push('-NIL');
      } else {
        d.meteoHorsEurope.forEach((line, i) => {
          const capaEl = document.querySelector(`[data-field="capa"][data-idx="${i}"]`);
          const degEl  = document.querySelector(`[data-field="deg"][data-idx="${i}"]`);
          // On ne construit que les parties renseignées
          const infos = [`ETA ${line.etaZ}`, `Fenêtre ${line.fenetreZ}`];
          if (capaEl?.value?.trim()) infos.push(`Capa attente ~${capaEl.value.trim()}min`);
          if (degEl?.value?.trim())  infos.push(`Dégagement ${degEl.value.trim().toUpperCase()}`);
          lines.push(`-${line.phenomenon} ${line.iata} ${line.flight} (${infos.join(' - ')})`);
        });
      }

      // ── Perturbation tropicale ─────────────────────────────────────────
      lines.push('**Perturbation tropicale :**');
      if (!d.tropicale.length) {
        lines.push('-NIL');
      } else {
        d.tropicale.forEach(tc => lines.push(`-${tc.name} — ${tc.basin} — ${tc.category} — ${tc.windKt}kt`));
      }

      // ── Activité volcanique ────────────────────────────────────────────
      lines.push('**Activité volcanique :**');
      if (!d.volcanique.length) {
        lines.push('-NIL');
      } else {
        d.volcanique.forEach(v => {
          const fl = v.flLevel ? ` ${v.flLevel}` : '';
          lines.push(`-${v.volcanoName}${fl} (VAAC ${v.vaac})`);
        });
      }

      // ── Vent arrière ────────────────────────────────────────────────────
      lines.push('**Vent arrière :**');
      const twAlerts = (d.tailwindWatch || []).filter(tw => tw.alert || tw.forecastAlerts.length);
      if (!twAlerts.length) {
        lines.push('-NIL');
      } else {
        twAlerts.forEach(tw => {
          const parts = [];
          if (tw.alert && tw.currentTW !== null) parts.push(`${tw.currentTW}kt actuel ${tw.runway}`);
          tw.forecastAlerts.forEach(fa => {
            const hh = s => { const x = new Date(s * 1000); return `${String(x.getUTCHours()).padStart(2,'0')}${String(x.getUTCMinutes()).padStart(2,'0')}z`; };
            parts.push(`prévu ${fa.tailwindKt}kt ${fa.runway} (${hh(fa.periodStart)}/${hh(fa.periodEnd)})`);
          });
          lines.push(`-${tw.iata} — ${parts.join(' / ')}`);
        });
      }

      // ── Carburant ───────────────────────────────────────────────────────
      lines.push('**Carburant :**');
      const carb = document.getElementById('field-carburant')?.value?.trim();
      lines.push(carb ? `-${carb}` : '-NIL');

      // ── Géopolitique ──────────────────────────────────────────────────
      lines.push('**Géopolitique :**');
      const geo = document.getElementById('field-geopolitique')?.value?.trim();
      lines.push(geo ? `-${geo}` : '-NIL');

      // ── Effectif DSP ───────────────────────────────────────────────────
      lines.push('**Effectif DSP :**');
      const dsp = document.getElementById('field-dsp')?.value?.trim();
      lines.push(`-${dsp || 'OK'}`);

      return lines.join('\n');
    }

    // ── Fetch + render ────────────────────────────────────────────────────────
    async function load(force = false) {
      const age = document.getElementById('briefing-age');
      if (age) age.textContent = 'Actualisation…';

      try {
        const r = await fetch(`/api/briefing${force ? '?force=1' : ''}`);
        if (!r.ok) throw new Error(`HTTP ${r.status}`);
        const data = await r.json();
        window._briefingData = data;
        renderBriefing(data);

        if (age) {
          const gen = new Date(data.generatedAt);
          const hh  = String(gen.getUTCHours()).padStart(2, '0');
          const mm  = String(gen.getUTCMinutes()).padStart(2, '0');
          age.textContent = `Données à ${hh}${mm}z`;
        }
      } catch (e) {
        const form = document.getElementById('briefing-form');
        if (form) form.innerHTML = `<div class="px-6 py-8 text-center text-red-500 text-sm">⚠️ Erreur de chargement : ${e.message}</div>`;
        if (age) age.textContent = 'Erreur';
      }
    }

    // ── Boutons ───────────────────────────────────────────────────────────────
    document.getElementById('btn-refresh')?.addEventListener('click', () => load(true));

    document.getElementById('btn-copy')?.addEventListener('click', async () => {
      const text = buildCopyText();
      try {
        await navigator.clipboard.writeText(text);
        const toast = document.getElementById('toast-copy');
        if (toast) {
          toast.classList.remove('opacity-0');
          toast.classList.add('opacity-100');
          setTimeout(() => { toast.classList.remove('opacity-100'); toast.classList.add('opacity-0'); }, 2500);
        }
      } catch (_) {
        prompt('Copier ce texte :', text);
      }
    });

    // ── Init ──────────────────────────────────────────────────────────────────
    load();
    setInterval(() => load(), 10 * 60 * 1000);

  })();
  </script>

</body>
</html>
