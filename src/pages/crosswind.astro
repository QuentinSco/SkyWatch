  function setH1PrintDate() {
    const h1 = document.querySelector('h1');
    if (!h1) return;
    if (!h1.hasAttribute('data-print-date')) {
      const now = new Date();
      const dateStr = `${String(now.getDate()).padStart(2,'0')}/${String(now.getMonth()+1).padStart(2,'0')}/${now.getFullYear()} ${String(now.getHours()).padStart(2,'0')}:${String(now.getMinutes()).padStart(2,'0')}`;
      h1.setAttribute('data-print-date', dateStr);
    }
  }

  function preparePrint() {
    setH1PrintDate();

    const mmToPx  = 96 / 25.4;
    // A4 portrait : zone utile largeur = 210 - 8 - 8 = 194mm, hauteur = 297 - 12 - 12 = 273mm
    const printW  = Math.round(194 * mmToPx);
    const pageHpx = Math.round(273 * mmToPx);

    const blocks = Array.from(document.querySelectorAll('#crosswind-container > div'));
    blocks.forEach(b => {
      b.style.removeProperty('break-before');
      b.style.removeProperty('page-break-before');
    });

    // — Forcer temporairement le layout colonne unique sur toutes les grilles —
    // À l'impression, xl:grid-cols-2 → display:block (colonnes empilées).
    // On reproduit ce layout le temps de mesurer les hauteurs réelles.
    const grids = Array.from(document.querySelectorAll('#crosswind-container .grid'));
    grids.forEach(g => {
      g.dataset._origDisplay = g.style.display;
      g.dataset._origWidth   = g.style.width;
      g.style.display = 'block';
      g.style.width   = printW + 'px';
    });
    // Forcer aussi la largeur du conteneur à printW pour que les mesures soient cohérentes
    const containerEl = document.getElementById('crosswind-container');
    const origContainerW = containerEl.style.width;
    containerEl.style.width = printW + 'px';

    // — Mesurer les hauteurs dans le layout imprimé —
    const headerH  = Math.round(55 * mmToPx / 25.4 * 25.4); // ~55px
    const marginPx = Math.round(4 * mmToPx);

    let usedPx = 55; // header h1 + légende

    blocks.forEach(block => {
      const printedH = block.getBoundingClientRect().height;

      if (usedPx > 55 && usedPx + printedH > pageHpx) {
        block.style.breakBefore = 'page';
        block.style.pageBreakBefore = 'always';
        usedPx = printedH + marginPx;
      } else {
        usedPx += printedH + marginPx;
      }
    });

    // — Restaurer le layout écran —
    grids.forEach(g => {
      g.style.display = g.dataset._origDisplay ?? '';
      g.style.width   = g.dataset._origWidth   ?? '';
      delete g.dataset._origDisplay;
      delete g.dataset._origWidth;
    });
    containerEl.style.width = origContainerW;
  }

  function cleanupPrint() {
    const h1 = document.querySelector('h1');
    if (h1) h1.removeAttribute('data-print-date');
    document.querySelectorAll('#crosswind-container > div').forEach(b => {
      b.style.removeProperty('break-before');
      b.style.removeProperty('page-break-before');
    });
  }

  document.getElementById('btn-print')?.addEventListener('click', () => {
    preparePrint();
    requestAnimationFrame(() => {
      window.print();
      setTimeout(cleanupPrint, 1000);
    });
  });

  // ─── Chargement données ────────────────────────────────────────────────────
  async function loadCrosswind(force = false) {
    const container = document.getElementById('crosswind-container');

    if (selectedIcaos.size === 0) {
      container.innerHTML = `
        <div class="flex items-center justify-center py-20 text-gray-400">
          <div class="text-center">
            <div class="text-4xl mb-3">✈️</div>
            <p class="text-sm">Ajoutez une escale ci-dessus pour commencer.</p>
          </div>
        </div>`;
      return;
    }

    container.innerHTML = `
      <div class="flex items-center justify-center py-20 text-gray-400">
        <div class="text-center"><div class="text-2xl mb-3 animate-spin">↻</div><p class="text-sm">Récupération TAF + vols…</p></div>
      </div>`;

    let qs = `icaos=${[...selectedIcaos].join(',')}${force ? '&force=1' : ''}`;
    if (timeRangeEnabled.checked && timeStart.value && timeEnd.value) {
      const start = new Date(timeStart.value).toISOString();
      const end   = new Date(timeEnd.value).toISOString();
      qs += `&start=${encodeURIComponent(start)}&end=${encodeURIComponent(end)}`;
    }

    try {
      const res = await fetch(`/api/crosswind.json?${qs}`);
      if (!res.ok) throw new Error(`HTTP ${res.status} — /api/crosswind.json`);
      const data = await res.json();
      if (data.error) throw new Error(data.error);
      cachedData = { tafs: data.tafs ?? {}, flights: data.flights ?? {} };
      renderResults(cachedData.tafs, cachedData.flights);
      const el = document.getElementById('crosswind-updated');
      if (el) el.textContent = 'Mis à jour ' + new Date().toLocaleTimeString('fr-FR', { hour: '2-digit', minute: '2-digit', timeZone: 'UTC' }) + 'z';
    } catch (err) {
      container.innerHTML = `
        <div class="bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 rounded-xl p-5 text-red-700 dark:text-red-400 text-sm">
          ⚠️ Erreur lors du chargement : ${err.message ?? err}
        </div>`;
    }
  }

  function renderResults(tafByIcao, flightsByIcao) {
    const html = [...selectedIcaos]
      .map(icao => renderAirportBlock(icao, tafByIcao[icao] ?? null, flightsByIcao[icao] ?? []))
      .join('');
    document.getElementById('crosswind-container').innerHTML =
      html || '<p class="text-gray-400 text-sm text-center py-10">Aucune donnée disponible.</p>';
  }

  function renderAirportBlock(icao, tafData, flights) {
    const iataKey = Object.keys(AF_IATA_TO_ICAO).find(k => AF_IATA_TO_ICAO[k] === icao) ?? icao;
    const apName = AIRPORT_RUNWAYS[icao]?.name ?? icao;
    const defaultQfuList = AIRPORT_RUNWAYS[icao]?.qfu ?? [];
    const hasDefaultQfu = defaultQfuList.length > 0;
    const activeQfu = customQfuByIcao.get(icao) ?? (hasDefaultQfu ? defaultQfuList[0] : null);
    const decl = AIRPORT_RUNWAYS[icao]?.decl ?? 0;

    const fcsts = tafData?.fcsts ?? [];
    const periodsWithWind = fcsts.filter(f => f.wdir != null && f.wspd != null);
    const tafValidTo = fcsts.reduce((max, f) => (f.timeTo != null && f.timeTo > max ? f.timeTo : max), 0);

    // ─── Filtrage vols par plage horaire ──────────────────────────────────────
    // Si plage personnalisée, on filtre par start/end ; sinon par validité TAF
    const allowedAcTypes = getAircraftFilter();

    let flightFilter;
    if (timeRangeEnabled.checked && timeStart.value && timeEnd.value) {
      const startMs = new Date(timeStart.value).getTime();
      const endMs   = new Date(timeEnd.value).getTime();
      flightFilter = flight => {
        const eta = flight.estimatedTouchDownTime || flight.scheduledArrival;
        if (!eta) return false;
        const etaMs = new Date(eta).getTime();
        if (etaMs < startMs || etaMs > endMs) return false;
        if (allowedAcTypes && !allowedAcTypes.has(flight.aircraftType ?? '')) return false;
        return true;
      };
    } else {
      flightFilter = flight => {
        const eta = flight.estimatedTouchDownTime || flight.scheduledArrival;
        if (!eta) return false;
        const etaEpochSec = Math.floor(new Date(eta).getTime() / 1000);
        if (tafValidTo === 0) return false;
        if (etaEpochSec > tafValidTo) return false;
        if (allowedAcTypes && !allowedAcTypes.has(flight.aircraftType ?? '')) return false;
        return true;
      };
    }

    // QFU selector
    let qfuSelector = '';
    if (hasDefaultQfu) {
      const qfuOptions = defaultQfuList.map(q => `<option value="${q}" ${q === activeQfu ? 'selected' : ''}>QFU ${String(q).padStart(2,'0')}</option>`).join('');
      qfuSelector = `
        <div class="flex items-center gap-2">
          <label class="text-xs text-gray-500">Piste :</label>
          <select onchange="changeQfu('${icao}', this.value)" class="text-xs font-mono font-semibold px-2 py-1 rounded border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 text-gray-800 dark:text-gray-200">
            ${qfuOptions}
          </select>
        </div>`;
    } else {
      qfuSelector = `
        <div class="flex items-center gap-2">
          ${activeQfu !== null 
            ? `<span class="text-xs font-mono font-semibold px-2 py-1 rounded bg-indigo-50 dark:bg-indigo-900/30 text-indigo-700 dark:text-indigo-300 border border-indigo-200 dark:border-indigo-700">QFU ${String(activeQfu).padStart(2,'0')}</span>`
            : '<span class="text-xs text-orange-500 font-semibold">⚠️ QFU non défini</span>'
          }
          <button onclick="setCustomQfuForAirport('${icao}')" class="text-xs px-2 py-1 rounded border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 hover:bg-gray-50 dark:hover:bg-gray-700 text-gray-600 dark:text-gray-300 transition">
            ${activeQfu !== null ? '✏️ Modifier' : '+ Définir QFU'}
          </button>
        </div>`;
    }

    let tafRows = '';
    if (!tafData) {
      tafRows = `<tr><td colspan="5" class="px-4 py-3 text-xs text-gray-400 italic">TAF non disponible pour ${icao}</td></tr>`;
    } else if (periodsWithWind.length === 0) {
      tafRows = `<tr><td colspan="5" class="px-4 py-3 text-xs text-gray-400 italic">Aucun vent dans le TAF</td></tr>`;
    } else if (activeQfu === null) {
      tafRows = `<tr><td colspan="5" class="px-4 py-3 text-xs text-orange-500 italic">⚠️ Définir un QFU pour calculer les composantes</td></tr>`;
    } else {
      for (const f of periodsWithWind) {
        const isVrb = String(f.wdir ?? '').toUpperCase() === 'VRB';
        const { crosswind: cwBase, vrb } = computeCrosswind(f.wdir, f.wspd, activeQfu, decl);
        const cwGust = f.wgst ? computeCrosswind(f.wdir, f.wgst, activeQfu, decl).crosswind : null;
        const worstCw = cwGust ?? cwBase;
        const code = getRunwayCodeForFcst(f);
        const activeLimit = code === 4 ? 27 : (code === 5 ? 38 : 38);
        const status = getCrosswindColor(worstCw, activeLimit);
        const wxString = f.wxString ?? '';
        const codeBadge = wxString
          ? `<span class="ml-1 px-1 py-0.5 rounded text-[9px] font-bold ${code === 6 ? 'bg-gray-100 dark:bg-gray-700 text-gray-500' : (code === 5 ? 'bg-blue-100 dark:bg-blue-900/40 text-blue-700 dark:text-blue-300' : 'bg-purple-100 dark:bg-purple-900/40 text-purple-700 dark:text-purple-300')}">${wxString}</span>`
          : '';
        const dirStr = isVrb ? 'VRB' : String(Number(f.wdir)).padStart(3, '0');
        const windStr = `${dirStr}/${String(f.wspd).padStart(2,'0')}${f.wgst ? 'G'+f.wgst : ''}KT`;
        const qfuCell = vrb
          ? '<span class="text-gray-400 italic text-[10px]">VRB</span>'
          : String(activeQfu).padStart(2,'0');
        const cwNote = vrb
          ? ' <span class="text-gray-400 text-[10px]">(pire cas)</span>'
          : (cwGust != null ? ` <span class="text-gray-400 text-[10px]">(G ${cwGust})</span>` : '');
        const cwStr = `${cwBase} kt${cwNote}`;
        tafRows += `
          <tr class="border-b border-gray-100 dark:border-gray-700 hover:bg-gray-50 dark:hover:bg-gray-700/40 transition ${code !== 6 ? 'bg-blue-50/30 dark:bg-blue-900/10' : ''}">
            <td class="px-4 py-2 text-xs font-mono text-gray-500 whitespace-nowrap">${formatEpoch(f.timeFrom)}→${formatEpoch(f.timeTo)}</td>
            <td class="px-4 py-2 text-xs font-mono font-semibold text-gray-800 dark:text-gray-200">${windStr}${codeBadge}</td>
            <td class="px-4 py-2 text-xs font-mono text-gray-500">${qfuCell}</td>
            <td class="px-4 py-2 text-xs font-bold font-mono ${status.text}">${cwStr}</td>
            <td class="px-4 py-2 text-xs whitespace-nowrap"><span class="px-1.5 py-0.5 rounded text-[10px] font-bold ${status.bg} ${status.text}">${status.label}</span></td>
          </tr>`;
      }
    }

    const sortedFlights = [...flights]
      .filter(flightFilter)
      .sort((a, b) =>
        new Date(a.estimatedTouchDownTime ?? a.scheduledArrival).getTime() -
        new Date(b.estimatedTouchDownTime ?? b.scheduledArrival).getTime()
      );

    let flightRows = '';
    if (sortedFlights.length === 0) {
      flightRows = `<tr><td colspan="5" class="px-3 py-3 text-xs text-gray-400 italic">Aucun vol AF dans la fenêtre sélectionnée</td></tr>`;
    } else if (activeQfu === null) {
      flightRows = `<tr><td colspan="5" class="px-3 py-3 text-xs text-orange-500 italic">⚠️ Définir un QFU pour calculer les composantes</td></tr>`;
    } else {
      for (const flight of sortedFlights) {
        const eta = flight.estimatedTouchDownTime || flight.scheduledArrival;
        const etaEpochSec = eta ? Math.floor(new Date(eta).getTime() / 1000) : null;
        const etaStr = eta
          ? new Date(eta).toLocaleTimeString('fr-FR', { hour: '2-digit', minute: '2-digit', timeZone: 'UTC' }) + 'z'
          : '–';
        const { base: baseWind, tempos: tempoWinds } = etaEpochSec ? getWindAtTime(fcsts, etaEpochSec) : { base: null, tempos: [] };
        const acInfo = AIRCRAFT_LIMITS[flight.aircraftType ?? ''] ?? DEFAULT_LIMIT;
        let windCell = `<td class="px-3 py-2 text-xs text-gray-400 font-mono">–</td>`;
        let riskCell = `<td class="px-3 py-2 text-xs text-gray-400">–</td>`;
        if (baseWind) {
          // Calculer le travers du vent de base
          const baseSpd = baseWind.wgst ?? baseWind.wspd;
          const { crosswind: baseCw, vrb: baseVrb } = computeCrosswind(baseWind.wdir, baseSpd, activeQfu, decl);

          // Trouver le pire TEMPO actif à l'ETA
          let worstCw = 0, worstTempo = null;
          for (const t of tempoWinds) {
            const { crosswind: cwt } = computeCrosswind(t.wdir, t.wgst ?? t.wspd, activeQfu, decl);
            if (cwt > worstCw) { worstCw = cwt; worstTempo = t; }
          }

          // Pire cas : TEMPO s'il dépasse le vent de base
          const useTempoAsMain = worstTempo && worstCw > baseCw;
          const mainWind = useTempoAsMain ? worstTempo : baseWind;
          const crosswind = useTempoAsMain ? worstCw : baseCw;
          const vrb = useTempoAsMain
            ? (String(worstTempo.wdir ?? '').toUpperCase() === 'VRB')
            : baseVrb;

          const code = getRunwayCode(fcsts, etaEpochSec);
          const mainCode = useTempoAsMain ? getRunwayCodeForFcst(worstTempo) : code;
          const activeLimit = mainCode === 6 ? acInfo.code6 : (mainCode === 5 ? acInfo.code5 : acInfo.code4);
          const status = getCrosswindColor(crosswind, activeLimit);

          // Affichage vent principal
          const isVrbMain = String(mainWind.wdir ?? '').toUpperCase() === 'VRB';
          const dirStr = isVrbMain ? 'VRB' : String(Number(mainWind.wdir)).padStart(3,'0');
          const windStr = `${dirStr}/${String(mainWind.wspd).padStart(2,'0')}${mainWind.wgst ? 'G'+mainWind.wgst : ''}KT`;
          const tempoLabel = useTempoAsMain ? (mainWind.changeIndicator ?? 'TEMPO') : '';
          const windLabelSuffix = useTempoAsMain
            ? ` <span class="text-orange-400 text-[9px] font-bold">${tempoLabel}</span>`
            : '';
          const qfuStr = vrb ? '<span class="text-gray-400 italic">VRB</span>' : `QFU ${String(activeQfu).padStart(2,'0')}`;
          const codeLabel = mainCode === 6 ? 'SÈCHE' : (mainCode === 5 ? 'MOUILLÉE' : 'CONTAMINÉE');
          const condBadge = mainCode === 6
            ? `<span class="px-1 py-0.5 rounded text-[9px] font-bold bg-gray-100 dark:bg-gray-700 text-gray-500">${codeLabel}</span>`
            : (mainCode === 5
              ? `<span class="px-1 py-0.5 rounded text-[9px] font-bold bg-blue-100 dark:bg-blue-900/40 text-blue-700 dark:text-blue-300">${codeLabel}</span>`
              : `<span class="px-1 py-0.5 rounded text-[9px] font-bold bg-purple-100 dark:bg-purple-900/40 text-purple-700 dark:text-purple-300">${codeLabel}</span>`);

          // Vent de base affiché en secondaire si un TEMPO est pire
          let baseStr = '';
          if (useTempoAsMain) {
            const isVrbBase = String(baseWind.wdir ?? '').toUpperCase() === 'VRB';
            const baseDirStr = isVrbBase ? 'VRB' : String(Number(baseWind.wdir)).padStart(3,'0');
            const baseWindStr = `${baseDirStr}/${String(baseWind.wspd).padStart(2,'0')}${baseWind.wgst ? 'G'+baseWind.wgst : ''}KT`;
            baseStr = `<div class="text-[10px] text-gray-400 mt-0.5">Base : ${baseWindStr} — ${baseCw} kt</div>`;
          }

          // Autres TEMPOs moins pires affichés en secondaire
          let otherTempoStr = '';
          if (!useTempoAsMain && worstTempo) {
            const tempoCode = getRunwayCodeForFcst(worstTempo);
            const tempoLimit = tempoCode === 6 ? acInfo.code6 : (tempoCode === 5 ? acInfo.code5 : acInfo.code4);
            const { text: tt, label: tl } = getCrosswindColor(worstCw, tempoLimit);
            otherTempoStr = `<div class="text-[10px] ${tt} mt-0.5">${worstTempo.changeIndicator ?? 'TEMPO'} : ${worstCw} kt (${tl})</div>`;
          }

          windCell = `<td class="px-3 py-2 text-xs font-mono text-gray-600 dark:text-gray-400 whitespace-nowrap">${windStr}${windLabelSuffix} <span class="text-gray-400">${qfuStr}</span></td>`;
          riskCell = `<td class="px-3 py-2 text-xs">
            <div class="flex flex-wrap items-center gap-1">
              <span class="font-bold font-mono ${status.text}">${crosswind} kt</span>
              ${condBadge}
              <span class="px-1.5 py-0.5 rounded text-[10px] font-bold ${status.bg} ${status.text}">${status.label}</span>
            </div>
            <div class="text-[10px] text-gray-400 mt-0.5">${acInfo.label} · max ${activeLimit} kt (code ${mainCode})</div>
            ${baseStr}${otherTempoStr}
          </td>`;
        }
        flightRows += `
          <tr class="border-b border-gray-100 dark:border-gray-700 hover:bg-gray-50 dark:hover:bg-gray-700/40 transition">
            <td class="px-3 py-2 text-xs font-bold font-mono text-gray-800 dark:text-gray-200">${formatFlightId(flight.flightId)}</td>
            <td class="px-3 py-2 text-xs font-mono text-blue-600 dark:text-blue-400 font-semibold">${etaStr}</td>
            <td class="px-3 py-2 text-xs font-mono text-gray-500">${flight.aircraftType ?? '–'}</td>
            ${windCell}${riskCell}
          </tr>`;
      }
    }

    return `
      <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-700 shadow-sm mb-5 overflow-hidden">
        <div class="flex items-center gap-3 px-5 py-3 border-b border-gray-100 dark:border-gray-700 bg-gray-50 dark:bg-gray-800">
          <span class="text-lg font-black font-mono text-gray-800 dark:text-gray-100">${iataKey}</span>
          <span class="text-sm text-gray-500">${apName}</span>
          ${decl !== 0
            ? `<span class="text-[10px] font-mono text-gray-400 dark:text-gray-500 border border-gray-200 dark:border-gray-700 rounded px-1.5 py-0.5" title="Déclinaison magnétique (WMM 2025)">${decl > 0 ? '+' : ''}${decl}° mag</span>`
            : `<span class="text-[10px] font-mono text-gray-300 dark:text-gray-600 border border-gray-100 dark:border-gray-800 rounded px-1.5 py-0.5" title="Déclinaison magnétique nulle">0° mag</span>`
          }
          <div class="ml-auto">${qfuSelector}</div>
        </div>
        <div class="grid grid-cols-1 xl:grid-cols-2 divide-y xl:divide-y-0 xl:divide-x divide-gray-100 dark:divide-gray-700">
          <div>
            <div class="px-5 py-2 border-b border-gray-100 dark:border-gray-700">
              <span class="text-xs font-semibold text-gray-500 uppercase tracking-wide">📋 TAF — Travers par période</span>
            </div>
            <div class="overflow-x-auto">
              <table class="w-full text-sm text-left">
                <thead class="text-[10px] uppercase text-gray-400 border-b border-gray-100 dark:border-gray-700">
                  <tr>
                    <th class="px-4 py-2">Période (UTC)</th>
                    <th class="px-4 py-2">Vent TAF</th><th class="px-4 py-2">QFU</th>
                    <th class="px-4 py-2">Composante travers</th><th class="px-4 py-2">État</th>
                  </tr>
                </thead>
                <tbody>${tafRows}</tbody>
              </table>
            </div>
          </div>
          <div>
            <div class="px-5 py-2 border-b border-gray-100 dark:border-gray-700">
              <span class="text-xs font-semibold text-gray-500 uppercase tracking-wide">✈️ Vols AF — Travers à l'ETA</span>
            </div>
            <div class="overflow-x-auto">
              <table class="w-full text-sm text-left">
                <thead class="text-[10px] uppercase text-gray-400 border-b border-gray-100 dark:border-gray-700">
                  <tr>
                    <th class="px-3 py-2">Vol</th><th class="px-3 py-2">ETA</th>
                    <th class="px-3 py-2">Avion</th><th class="px-3 py-2">Vent prévu</th>
                    <th class="px-3 py-2">Travers / Risque</th>
                  </tr>
                </thead>
                <tbody>${flightRows}</tbody>
              </table>
            </div>
          </div>
        </div>
        <div class="taf-raw-section border-t border-gray-100 dark:border-gray-700">
          <button
            class="w-full flex items-center justify-between px-5 py-2.5 text-xs text-gray-500 hover:bg-gray-50 dark:hover:bg-gray-700/40 transition font-medium"
            onclick="(function(btn){
              const block = btn.nextElementSibling;
              const isHidden = block.classList.contains('hidden');
              block.classList.toggle('hidden');
              btn.querySelector('.taf-toggle-icon').textContent = isHidden ? '▼' : '▶';
            })(this)"
          >
            <span>📄 TAF brut — ${icao}</span>
            <span class="taf-toggle-icon text-gray-400">▶</span>
          </button>
          <div class="hidden px-5 pb-4">
            <pre class="font-mono text-[11px] text-gray-600 dark:text-gray-400 bg-gray-50 dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-lg p-3 whitespace-pre-wrap break-words leading-relaxed">${
              tafData?.rawTaf
                ? formatTafForDisplay(tafData.rawTaf.trim())
                : 'TAF non disponible'
            }</pre>
          </div>
        </div>
      </div>`;
  }

  function formatTafForDisplay(rawTaf) {
    return rawTaf
      .replace(/\s+(TEMPO|BECMG)\s+/g, '\n$1 ')
      .replace(/\s+(PROB\d{2})\s+(?!TEMPO)/g, '\n$1 ')
      .trim();
  }

function formatEpoch(epochSec) {
  if (!epochSec) return '–';
  const d = new Date(epochSec * 1000);
  const day = String(d.getUTCDate()).padStart(2, '0');
  const mon = String(d.getUTCMonth() + 1).padStart(2, '0');
  const hh  = String(d.getUTCHours()).padStart(2, '0');
  const mm  = String(d.getUTCMinutes()).padStart(2, '0');
  return `${day}/${hh}:${mm}z`;
}

  document.addEventListener('DOMContentLoaded', () => {
    renderAirportSelector();
    setupAircraftFilterListeners();
    loadCrosswind(false);
  });
  </script>

</body>
</html>
