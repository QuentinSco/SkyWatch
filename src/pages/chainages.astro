---
import '../styles/global.css';
---
<!doctype html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>SkyWatch – Chaînages</title>
  <script is:inline src="/lib/dark-mode.js"></script>
  <style>
    /* Frise */
    .timeline-wrap { overflow-x: auto; }
    .timeline-canvas { display: block; }

    /* Tooltip */
    #ch-tooltip {
      position: fixed;
      pointer-events: none;
      background: #1e293b;
      color: #f1f5f9;
      font-size: 11px;
      line-height: 1.5;
      padding: 6px 10px;
      border-radius: 8px;
      white-space: pre;
      z-index: 9999;
      opacity: 0;
      transition: opacity .15s;
    }
  </style>
</head>

<body class="text-gray-900 min-h-screen flex" style="background:#f8fafc">

  <!-- ─── Sidebar -->
  <aside class="hidden lg:flex flex-col w-56 shrink-0 sticky top-0 h-screen border-r border-gray-200 bg-white px-4 py-6 overflow-y-auto">
    <div class="mb-6">
      <div class="text-2xl font-bold tracking-tight text-gray-900">🛡 SkyWatch</div>
      <div class="text-gray-400 text-xs mt-1">Superviseur dispatch</div>
    </div>
    <nav class="flex flex-col gap-1 text-sm">
      <div class="text-[10px] uppercase font-semibold text-gray-400 tracking-widest mb-2">Navigation</div>
      <a href="/" class="flex items-center gap-2 px-3 py-2 rounded-lg text-gray-600 hover:bg-blue-50 hover:text-blue-700 transition font-medium">🗺️ Tableau de bord</a>
      <div class="mt-4 pt-4 border-t border-gray-100">
        <div class="text-[10px] uppercase font-semibold text-gray-400 tracking-widest mb-2">Outils</div>
        <a href="/briefing" class="flex items-center gap-2 px-3 py-2 rounded-lg text-gray-600 hover:bg-purple-50 hover:text-purple-700 transition font-medium">🗒 Trame briefing</a>
        <a href="/chainages" class="flex items-center gap-2 px-3 py-2 rounded-lg bg-indigo-50 text-indigo-700 font-semibold">🔗 Chaînages</a>
      </div>
    </nav>
    <div class="mt-auto pt-6 border-t border-gray-100 text-[10px] text-gray-400 leading-relaxed">
      <strong class="text-gray-500">Horizon :</strong> 24h glissantes<br>
      Vols AF long-courrier uniquement.
    </div>
  </aside>

  <!-- ─── Contenu principal -->
  <div class="flex-1 min-w-0 overflow-y-auto">
    <div class="max-w-5xl mx-auto px-4 py-6 xl:px-8">

      <!-- Header -->
      <div class="flex items-center justify-between flex-wrap gap-4 mb-6">
        <div>
          <h1 class="text-2xl font-bold tracking-tight text-gray-900">🔗 Chaînages</h1>
          <p class="text-gray-500 text-xs mt-1">Temps de rotation des appareils AF LC sur une escale — Fenêtre <strong>maintenant → +24h</strong></p>
        </div>
        <div class="flex items-center gap-2">
          <span id="ch-age" class="text-xs text-gray-400"></span>
          <button id="btn-refresh" class="flex items-center gap-1.5 px-3 py-1.5 text-xs font-medium rounded-lg border border-gray-200 bg-white hover:bg-gray-50 text-gray-600 transition">
            🔄 Actualiser
          </button>
        </div>
      </div>

      <!-- Saisie aéroports -->
      <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4 mb-6">
        <div class="text-xs font-semibold text-gray-500 uppercase tracking-widest mb-3">Aéroports à surveiller</div>
        <div class="flex items-center gap-2 mb-3">
          <input id="airport-input" type="text" maxlength="4"
            placeholder="IATA (JFK) ou OACI (KJFK)"
            class="w-48 border border-gray-300 rounded-lg px-3 py-1.5 text-sm font-mono uppercase
                   focus:outline-none focus:ring-2 focus:ring-indigo-300 placeholder-gray-400" />
          <button id="btn-add-airport"
            class="flex items-center gap-1.5 px-3 py-1.5 text-xs font-semibold rounded-lg bg-indigo-600 hover:bg-indigo-700 text-white transition">
            + Ajouter
          </button>
        </div>
        <div id="airport-tags" class="flex flex-wrap gap-2 min-h-[28px]">
          <span class="text-xs text-gray-400 italic" id="no-airport-hint">Aucun aéroport sélectionné</span>
        </div>
      </div>

      <!-- Légende -->
      <div id="ch-legend" class="hidden flex items-center gap-4 mb-3 text-xs text-gray-500">
        <span class="flex items-center gap-1.5"><span class="inline-block w-3 h-3 rounded bg-indigo-400"></span> Au sol (durée connue)</span>
        <span class="flex items-center gap-1.5"><span class="inline-block w-3 h-3 rounded bg-indigo-200 border border-dashed border-indigo-400"></span> Au sol (départ inconnu)</span>
        <span class="flex items-center gap-1.5"><span class="inline-block w-2 h-2 rounded-full bg-red-400"></span> Maintenant</span>
      </div>

      <!-- Frise -->
      <div id="chainages-result">
        <div class="text-gray-400 text-sm italic text-center py-12">Ajoutez un aéroport pour afficher les chaînages.</div>
      </div>

      <div id="ch-tooltip"></div>
    </div>
  </div>

  <script is:inline>
  (function () {

    // ──────────────────────────────────────────────
    // Constantes de dessin
    const ROW_H      = 44;   // hauteur ligne
    const ROW_PAD    = 8;    // padding vertical intérieur
    const BAR_H      = ROW_H - ROW_PAD * 2;  // hauteur du bloc
    const LABEL_W    = 90;   // largeur colonne matricule
    const CHART_PAD  = 12;   // padding droit
    const HEADER_H   = 28;   // hauteur header heures
    const TICK_EVERY = 2;    // graduation toutes les X heures
    const FONT       = '11px/1 Inter, system-ui, sans-serif';
    const FONT_BOLD  = 'bold 11px/1 Inter, system-ui, sans-serif';

    const COLOR_BAR     = '#818cf8'; // indigo-400
    const COLOR_BAR_UNK = '#c7d2fe'; // indigo-200
    const COLOR_NOW     = '#f87171'; // red-400
    const COLOR_GRID    = '#e2e8f0'; // gray-200
    const COLOR_LABEL   = '#64748b'; // slate-500
    const COLOR_FLIGHT  = '#1e40af'; // blue-800
    const COLOR_TIME    = '#374151'; // gray-700
    const COLOR_BG_ROW_ALT = '#f8fafc';

    const airports  = new Set();
    let   lastData  = null;
    const tooltip   = document.getElementById('ch-tooltip');
    let   hitZones  = [];   // [{x1,y1,x2,y2, stop}] pour le hover

    // ── Tags ────────────────────────────────────────────────────
    function renderTags() {
      const container = document.getElementById('airport-tags');
      const hint = document.getElementById('no-airport-hint');
      container.querySelectorAll('.ap-tag').forEach(el => el.remove());
      if (airports.size === 0) { hint.style.display = ''; return; }
      hint.style.display = 'none';
      airports.forEach(code => {
        const tag = document.createElement('span');
        tag.className = 'ap-tag inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full bg-indigo-100 text-indigo-800 text-xs font-mono font-semibold';
        tag.innerHTML = `${code} <button data-code="${code}" class="ap-remove text-indigo-400 hover:text-red-500 font-bold leading-none">✕</button>`;
        container.appendChild(tag);
      });
      container.querySelectorAll('.ap-remove').forEach(btn => {
        btn.addEventListener('click', () => { airports.delete(btn.getAttribute('data-code')); renderTags(); fetchChainages(); });
      });
    }

    function addAirport() {
      const input = document.getElementById('airport-input');
      const val = input.value.trim().toUpperCase();
      if (!val || val.length < 3) return;
      airports.add(val); input.value = '';
      renderTags(); fetchChainages();
    }
    document.getElementById('btn-add-airport').addEventListener('click', addAirport);
    document.getElementById('airport-input').addEventListener('keydown', e => { if (e.key === 'Enter') addAirport(); });
    document.getElementById('btn-refresh').addEventListener('click', () => fetchChainages(true));

    // ── Dessin frise ──────────────────────────────────────────────
    function hhmm(ms) {
      const d = new Date(ms);
      return String(d.getUTCHours()).padStart(2,'0') + ':' + String(d.getUTCMinutes()).padStart(2,'0') + 'z';
    }
    function ddmm(ms) {
      const d = new Date(ms);
      return String(d.getUTCDate()).padStart(2,'0') + '/' + String(d.getUTCMonth()+1).padStart(2,'0');
    }

    function drawTimeline(data) {
      const container = document.getElementById('chainages-result');
      const legend    = document.getElementById('ch-legend');
      const stops     = data.stops || [];

      if (stops.length === 0) {
        container.innerHTML = '<div class="text-gray-400 text-sm italic text-center py-12">Aucun chaînage trouvé pour cette fenêtre 24h.</div>';
        legend.classList.add('hidden');
        return;
      }

      legend.classList.remove('hidden');

      const wStart = data.windowStart;
      const wEnd   = data.windowEnd;
      const span   = wEnd - wStart;   // 24h en ms

      // ─ Dimensions dynamiques ─────────────────────────────────────
      const availW    = Math.max(container.clientWidth - LABEL_W - CHART_PAD, 200);
      const canvasW   = LABEL_W + availW + CHART_PAD;
      const canvasH   = HEADER_H + stops.length * ROW_H;

      // ─ Helpers coordonnées ─────────────────────────────────────
      const toX = msVal => LABEL_W + ((msVal - wStart) / span) * availW;

      // ─ Canvas ──────────────────────────────────────────────
      container.innerHTML = '';
      const wrap = document.createElement('div');
      wrap.className = 'timeline-wrap bg-white border border-gray-200 rounded-xl shadow-sm';

      const canvas = document.createElement('canvas');
      canvas.className = 'timeline-canvas';
      const dpr = window.devicePixelRatio || 1;
      canvas.width  = canvasW * dpr;
      canvas.height = canvasH * dpr;
      canvas.style.width  = canvasW + 'px';
      canvas.style.height = canvasH + 'px';
      wrap.appendChild(canvas);
      container.appendChild(wrap);

      const ctx = canvas.getContext('2d');
      ctx.scale(dpr, dpr);

      // ─ Fond ───────────────────────────────────────────────
      ctx.fillStyle = '#fff';
      ctx.fillRect(0, 0, canvasW, canvasH);

      // Lignes alternées
      stops.forEach((_, i) => {
        if (i % 2 === 1) {
          ctx.fillStyle = COLOR_BG_ROW_ALT;
          ctx.fillRect(0, HEADER_H + i * ROW_H, canvasW, ROW_H);
        }
      });

      // ─ Grille verticale + header heures ─────────────────────────
      ctx.strokeStyle = COLOR_GRID;
      ctx.lineWidth   = 1;
      ctx.font        = FONT;
      ctx.fillStyle   = COLOR_LABEL;
      ctx.textAlign   = 'center';
      ctx.textBaseline = 'middle';

      for (let h = 0; h <= 24; h += TICK_EVERY) {
        const t = wStart + h * 3600000;
        const x = toX(t);
        // grille
        ctx.beginPath(); ctx.moveTo(x, HEADER_H); ctx.lineTo(x, canvasH); ctx.stroke();
        // label heure
        const label = hhmm(t).slice(0, 5); // HH:MM
        ctx.fillText(label, x, HEADER_H / 2);
      }

      // Séparateur header
      ctx.strokeStyle = '#cbd5e1';
      ctx.lineWidth   = 1;
      ctx.beginPath(); ctx.moveTo(LABEL_W, HEADER_H); ctx.lineTo(canvasW, HEADER_H); ctx.stroke();
      // Séparateur colonne labels
      ctx.beginPath(); ctx.moveTo(LABEL_W, 0); ctx.lineTo(LABEL_W, canvasH); ctx.stroke();

      // ─ Lignes : blocs + labels ────────────────────────────────
      hitZones = [];
      const nowMs = Date.now();

      stops.forEach((stop, i) => {
        const y0   = HEADER_H + i * ROW_H;
        const barY = y0 + ROW_PAD;

        // ─ Label matricule ─
        ctx.font      = FONT_BOLD;
        ctx.fillStyle = '#1e293b';
        ctx.textAlign = 'left';
        ctx.textBaseline = 'middle';
        ctx.fillText(stop.registration.replace('F-', 'F-'), 6, y0 + ROW_H / 2);

        // type avion en gris
        if (stop.aircraftType) {
          ctx.font      = FONT;
          ctx.fillStyle = '#94a3b8';
          // mesure le texte du matricule pour positionner après
          ctx.font = FONT_BOLD;
          const labelW = ctx.measureText(stop.registration).width;
          ctx.font      = FONT;
          ctx.fillStyle = '#94a3b8';
          ctx.fillText(stop.aircraftType, 6 + labelW + 4, y0 + ROW_H / 2);
        }

        // ─ Bloc au sol ─
        const xArr = toX(stop.arrMs);
        const known = stop.depMs !== null;
        // Si départ inconnu : on dessine jusqu'à la fin de la fenêtre avec motif hachuré
        const xDep  = known ? toX(stop.depMs) : canvasW - CHART_PAD;

        const barW  = Math.max(xDep - xArr, 4);
        const radius = 4;

        // Fond du bloc
        ctx.fillStyle = known ? COLOR_BAR : COLOR_BAR_UNK;
        ctx.beginPath();
        ctx.roundRect(xArr, barY, barW, BAR_H, radius);
        ctx.fill();

        // Si inconnu : hachures sur la partie droite (les 40% finaux)
        if (!known) {
          ctx.save();
          ctx.beginPath();
          ctx.roundRect(xArr, barY, barW, BAR_H, radius);
          ctx.clip();
          ctx.strokeStyle = '#a5b4fc'; // indigo-300
          ctx.lineWidth   = 1.5;
          for (let xi = xArr + barW * 0.6; xi < xDep + BAR_H; xi += 6) {
            ctx.beginPath();
            ctx.moveTo(xi, barY);
            ctx.lineTo(xi - BAR_H, barY + BAR_H);
            ctx.stroke();
          }
          ctx.restore();
        }

        // ─ Texte dans le bloc ─
        ctx.font        = 'bold 10px/1 Inter, system-ui, sans-serif';
        ctx.fillStyle   = known ? '#fff' : COLOR_FLIGHT;
        ctx.textAlign   = 'left';
        ctx.textBaseline = 'middle';
        const midY = barY + BAR_H / 2;

        // ARR flight
        const arrLabel = '↓ ' + stop.arrFlight;
        ctx.fillText(arrLabel, xArr + 5, midY);

        // DEP flight (si connu)
        if (stop.depFlight) {
          const depLabel = '↑ ' + stop.depFlight;
          const depLabelW = ctx.measureText(depLabel).width;
          ctx.fillText(depLabel, xDep - depLabelW - 5, midY);
        }

        // Durée au sol (si les deux bornes sont connues)
        if (known && stop.depMs !== null) {
          const durMin = Math.round((stop.depMs - stop.arrMs) / 60000);
          const durH   = Math.floor(durMin / 60);
          const durM   = durMin % 60;
          const durLabel = durH > 0 ? `${durH}h${String(durM).padStart(2,'0')}` : `${durM}min`;
          ctx.font      = FONT;
          ctx.fillStyle = 'rgba(255,255,255,0.85)';
          ctx.textAlign = 'center';
          const midX = (xArr + xDep) / 2;
          // Afficher seulement si la largeur le permet
          if (barW > 50) ctx.fillText(durLabel, midX, midY);
        }

        // Zone de hit
        hitZones.push({ x1: xArr, y1: barY, x2: xDep, y2: barY + BAR_H, stop });
      });

      // ─ Curseur "maintenant" ─────────────────────────────────────
      const xNow = toX(nowMs);
      if (xNow >= LABEL_W && xNow <= canvasW) {
        ctx.strokeStyle = COLOR_NOW;
        ctx.lineWidth   = 2;
        ctx.setLineDash([4, 3]);
        ctx.beginPath(); ctx.moveTo(xNow, 0); ctx.lineTo(xNow, canvasH); ctx.stroke();
        ctx.setLineDash([]);

        // Bullet en haut
        ctx.fillStyle = COLOR_NOW;
        ctx.beginPath(); ctx.arc(xNow, HEADER_H / 2, 4, 0, Math.PI * 2); ctx.fill();

        // Label "NOW"
        ctx.font        = 'bold 9px/1 Inter, system-ui, sans-serif';
        ctx.fillStyle   = COLOR_NOW;
        ctx.textAlign   = 'center';
        ctx.textBaseline = 'middle';
        ctx.fillText('NOW', xNow, HEADER_H - 6);
      }

      // ─ Hover tooltip ─────────────────────────────────────────
      canvas.addEventListener('mousemove', e => {
        const rect = canvas.getBoundingClientRect();
        const mx = e.clientX - rect.left;
        const my = e.clientY - rect.top;

        const hit = hitZones.find(z => mx >= z.x1 && mx <= z.x2 && my >= z.y1 && my <= z.y2);
        if (hit) {
          const s = hit.stop;
          const arrLine  = `↓ ARR  ${s.arrFlight}  ${ddmm(s.arrMs)} ${hhmm(s.arrMs)}`;
          const depLine  = s.depFlight
            ? (s.depMs ? `↑ DEP  ${s.depFlight}  ${ddmm(s.depMs)} ${hhmm(s.depMs)}` : `↑ DEP  ${s.depFlight}  heure non disponible`)
            : '↑ DEP  non disponible';
          let durLine = '';
          if (s.depMs) {
            const dm = Math.round((s.depMs - s.arrMs) / 60000);
            durLine = `⏱ Rotation  ${Math.floor(dm/60)}h${String(dm%60).padStart(2,'0')}`;
          }
          tooltip.textContent = [arrLine, depLine, durLine].filter(Boolean).join('\n');
          tooltip.style.opacity = '1';
          tooltip.style.left = (e.clientX + 14) + 'px';
          tooltip.style.top  = (e.clientY - 10) + 'px';
          canvas.style.cursor = 'default';
        } else {
          tooltip.style.opacity = '0';
          canvas.style.cursor = 'default';
        }
      });
      canvas.addEventListener('mouseleave', () => { tooltip.style.opacity = '0'; });
    }

    // ─ Fetch ────────────────────────────────────────────────────────────
    function renderChainages(data) {
      lastData = data;
      const age = document.getElementById('ch-age');
      if (age && data.generatedAt) {
        const d = new Date(data.generatedAt);
        age.textContent = `Données à ${String(d.getUTCHours()).padStart(2,'0')}:${String(d.getUTCMinutes()).padStart(2,'0')}z`;
      }
      drawTimeline(data);
    }

    async function fetchChainages(force = false) {
      if (airports.size === 0) {
        document.getElementById('chainages-result').innerHTML =
          '<div class="text-gray-400 text-sm italic text-center py-12">Ajoutez un aéroport pour afficher les chaînages.</div>';
        document.getElementById('ch-legend').classList.add('hidden');
        return;
      }
      document.getElementById('chainages-result').innerHTML =
        '<div class="text-gray-400 text-sm italic text-center py-8">Chargement…</div>';

      const codes = Array.from(airports).join(',');
      const url = `/api/chainages?airports=${encodeURIComponent(codes)}${force ? '&force=1' : ''}`;
      try {
        const r = await fetch(url);
        if (!r.ok) throw new Error(`HTTP ${r.status}`);
        renderChainages(await r.json());
      } catch (e) {
        document.getElementById('chainages-result').innerHTML =
          `<div class="text-red-500 text-sm text-center py-8">⚠️ Erreur : ${e.message}</div>`;
      }
    }

    // Redessiner si la fenêtre est redimensionnée
    window.addEventListener('resize', () => { if (lastData) drawTimeline(lastData); });

  })();
  </script>

</body>
</html>
