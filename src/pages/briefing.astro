---
import '../styles/global.css';
---
<!doctype html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>SkyWatch – Trame Briefing CCO</title>
  <script is:inline src="/lib/dark-mode.js"></script>
</head>

<body class="text-gray-900 dark:text-gray-100 min-h-screen flex bg-slate-50 dark:bg-gray-950">

  <!-- ─ Sidebar ─────────────────────────────────────────── -->
  <aside class="hidden lg:flex flex-col w-56 shrink-0 sticky top-0 h-screen
                border-r border-gray-200 dark:border-gray-800
                bg-white dark:bg-gray-900
                px-4 py-6 overflow-y-auto">
    <div class="mb-6">
      <div class="text-2xl font-bold tracking-tight text-gray-900 dark:text-white">🛡 SkyWatch</div>
      <div class="text-gray-400 dark:text-gray-500 text-xs mt-1">Superviseur dispatch</div>
    </div>
    <nav class="flex flex-col gap-1 text-sm">
      <div class="text-[10px] uppercase font-semibold text-gray-400 dark:text-gray-600 tracking-widest mb-2">Navigation</div>
      <a href="/" class="flex items-center gap-2 px-3 py-2 rounded-lg
                         text-gray-600 dark:text-gray-400
                         hover:bg-blue-50 dark:hover:bg-blue-950 hover:text-blue-700 dark:hover:text-blue-400
                         transition font-medium">🗺️ Tableau de bord</a>
      <div class="mt-4 pt-4 border-t border-gray-100 dark:border-gray-800">
        <div class="text-[10px] uppercase font-semibold text-gray-400 dark:text-gray-600 tracking-widest mb-2">Outils</div>
        <a href="/briefing" class="flex items-center gap-2 px-3 py-2 rounded-lg
                                    bg-blue-50 dark:bg-blue-950
                                    text-blue-700 dark:text-blue-300 font-semibold">🗒 Trame briefing</a>
        <a href="/chainages" class="flex items-center gap-2 px-3 py-2 rounded-lg
                                    text-gray-600 dark:text-gray-400
                                    hover:bg-indigo-50 dark:hover:bg-indigo-950 hover:text-indigo-700 dark:hover:text-indigo-400
                                    transition font-medium">🔗 Chaînages</a>
      </div>
    </nav>
    <div class="mt-auto pt-6 border-t border-gray-100 dark:border-gray-800 text-[10px] text-gray-400 dark:text-gray-600 leading-relaxed">
      <strong class="text-gray-500 dark:text-gray-400">Horizon :</strong> 10h glissantes<br>
      Pré-remplissage auto — compléter avant diffusion.
    </div>
  </aside>

  <!-- ─ Contenu principal ──────────────────────────────────────── -->
  <div class="flex-1 min-w-0 overflow-y-auto">
    <div class="max-w-3xl mx-auto px-4 py-6 xl:px-8">

      <div class="flex items-center justify-between flex-wrap gap-4 mb-6">
        <div>
          <h1 class="text-2xl font-bold tracking-tight text-gray-900 dark:text-white">🗒 Trame Briefing CCO</h1>
          <p class="text-gray-500 dark:text-gray-400 text-xs mt-1">Pré-remplie automatiquement — horizon 10h · Alertes <span class="text-red-500 font-semibold">rouges uniquement</span> · Compléter les champs <span class="text-orange-500 font-semibold">orange</span> avant diffusion</p>
        </div>
        <div class="flex items-center gap-2">
          <span id="briefing-age" class="text-xs text-gray-400 dark:text-gray-500">Chargement…</span>
          <button id="btn-refresh" class="flex items-center gap-1.5 px-3 py-1.5 text-xs font-medium rounded-lg
                                          border border-gray-200 dark:border-gray-700
                                          bg-white dark:bg-gray-800
                                          hover:bg-gray-50 dark:hover:bg-gray-700
                                          text-gray-600 dark:text-gray-300 transition">
            🔄 Actualiser
          </button>
          <button id="btn-copy" class="flex items-center gap-1.5 px-3 py-1.5 text-xs font-semibold rounded-lg bg-blue-600 hover:bg-blue-700 text-white transition">
            📋 Copier
          </button>
        </div>
      </div>

      <div id="briefing-form" class="space-y-0 bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-xl shadow-sm overflow-hidden">
        <div class="text-gray-400 text-sm italic px-6 py-8 text-center">Chargement de la trame…</div>
      </div>

      <div id="toast-copy" class="fixed bottom-6 right-6 bg-gray-900 text-white text-xs font-medium px-4 py-2.5 rounded-xl shadow-lg opacity-0 transition-opacity duration-300 pointer-events-none">
        ✅ Trame copiée dans le presse-papier
      </div>
    </div>
  </div>

  <script is:inline>
  (function () {

    const SEV_COLORS = {
      red:    { dot: 'bg-red-500',    badge: 'bg-red-100 text-red-700' },
      orange: { dot: 'bg-orange-400', badge: 'bg-orange-100 text-orange-700' },
    };

    function sectionHeader(icon, title, badge) {
      return `<div class="flex items-center justify-between px-6 py-3 bg-gray-50 dark:bg-gray-800 border-b border-gray-100 dark:border-gray-700">
        <span class="text-sm font-semibold text-gray-700 dark:text-gray-200">${icon} ${title}</span>
        <span class="text-[10px] font-medium px-2 py-0.5 rounded-full ${badge.cls}">${badge.label}</span>
      </div>`;
    }
    function nilLine() { return `<div class="px-6 py-3 text-sm text-gray-400 dark:text-gray-600 italic">- NIL</div>`; }
    function manualTextarea(id, placeholder, value = '') {
      return `<div class="px-6 py-3"><textarea id="${id}" rows="2" placeholder="${placeholder}"
        class="w-full text-sm border border-orange-200 dark:border-orange-800 rounded-lg px-3 py-2
               bg-orange-50 dark:bg-orange-950 text-gray-900 dark:text-gray-100
               placeholder-orange-300 dark:placeholder-orange-700
               focus:outline-none focus:ring-2 focus:ring-orange-300 resize-none font-mono"
      >${value}</textarea></div>`;
    }

    const utcDZ = ms => {
      const d = new Date(typeof ms === 'number' && ms < 1e12 ? ms * 1000 : ms);
      const dd = String(d.getUTCDate()).padStart(2, '0');
      const hh = String(d.getUTCHours()).padStart(2, '0');
      const mm = d.getUTCMinutes();
      return mm ? `${dd}/${hh}${String(mm).padStart(2,'0')}z` : `${dd}/${hh}z`;
    };

    function renderBriefing(data) {
      const form = document.getElementById('briefing-form');
      if (!form) return;
      let html = '';

      html += sectionHeader('🌩', 'Météo hors Europe', { cls: 'bg-green-100 text-green-700', label: '✓ Auto · 10h · 🔴 Rouge' });

      if (data.meteoHorsEurope.length > 0) {
        data.meteoHorsEurope.forEach((line, i) => {
          const c = SEV_COLORS[line.severity] || SEV_COLORS.orange;
          html += `<div class="px-6 py-3 border-b border-gray-50 dark:border-gray-800">
            <div class="flex items-start gap-3">
              <span class="mt-1.5 w-2 h-2 rounded-full flex-shrink-0 ${c.dot}"></span>
              <div class="flex-1 min-w-0">
                <div class="flex flex-wrap items-center gap-2 text-sm font-medium text-gray-800 dark:text-gray-200">
                  <span>${line.phenomenon}</span>
                  <span class="font-bold">${line.iata}</span>
                  <span class="text-blue-700 dark:text-blue-400 font-bold">${line.flight}</span>
                  <span class="text-gray-500 dark:text-gray-400 text-xs">(ETA <span class="font-mono font-semibold text-gray-700 dark:text-gray-300">${line.etaZ}</span> · Fenêtre <span class="font-mono text-gray-700 dark:text-gray-300">${line.fenetreZ}</span>)</span>
                </div>
                <div class="mt-2 flex flex-wrap items-center gap-3">
                  <label class="flex items-center gap-1.5 text-xs text-gray-500 dark:text-gray-400">Capa attente
                    <input type="number" min="0" placeholder="min" data-field="capa" data-idx="${i}"
                      class="w-16 border border-orange-200 dark:border-orange-800 rounded-md px-2 py-0.5
                             bg-orange-50 dark:bg-orange-950 text-xs font-mono
                             focus:outline-none focus:ring-1 focus:ring-orange-300 text-center" />
                  </label>
                  <label class="flex items-center gap-1.5 text-xs text-gray-500 dark:text-gray-400">Dégagement
                    <input type="text" placeholder="ICAO / IATA" data-field="deg" data-idx="${i}"
                      class="w-24 border border-orange-200 dark:border-orange-800 rounded-md px-2 py-0.5
                             bg-orange-50 dark:bg-orange-950 text-xs font-mono
                             uppercase focus:outline-none focus:ring-1 focus:ring-orange-300" />
                  </label>
                </div>
              </div>
            </div>
          </div>`;
        });
      }

      const twWithTAF = (data.tailwindWatch || []).filter(tw => tw.forecastAlerts.length > 0);
      if (twWithTAF.length > 0) {
        twWithTAF.forEach(tw => {
          const runway = tw.forecastAlerts[0].runway;
          const chips  = tw.forecastAlerts.map(fa => {
            const windLabel = fa.hasGust ? `${fa.wspdBase}G${fa.wgst}kt` : `${fa.tailwindKt}kt`;
            return `<span class="inline-flex items-center gap-0.5 px-2 py-0.5 rounded bg-amber-100 dark:bg-amber-950 border border-amber-300 dark:border-amber-700 text-amber-800 dark:text-amber-300 text-xs font-mono font-semibold">
              ${windLabel}&nbsp;<span class="font-normal text-amber-700 dark:text-amber-400">${utcDZ(fa.periodStart)}→${utcDZ(fa.periodEnd)}</span>
            </span>`;
          }).join(' ');
          html += `<div class="px-6 py-3 border-b border-gray-50 dark:border-gray-800">
            <div class="flex flex-wrap items-center gap-2">
              <span class="font-bold text-gray-900 dark:text-white text-sm w-10">${tw.iata}</span>
              <span class="text-[10px] font-semibold px-1.5 py-0.5 rounded bg-gray-100 dark:bg-gray-700 text-gray-500 dark:text-gray-400 font-mono">${runway}</span>
              <span class="text-xs text-gray-500 dark:text-gray-400">💨 Vent arrière —</span>
              ${chips}
            </div>
          </div>`;
        });
      }

      if (data.meteoHorsEurope.length === 0 && twWithTAF.length === 0) html += nilLine();

      html += sectionHeader('🌀', 'Perturbation tropicale', { cls: 'bg-green-100 text-green-700', label: '✓ Auto' });
      if (!data.tropicale.length) { html += nilLine(); }
      else data.tropicale.forEach(tc => {
        const affected = tc.affected.length ? ` — Terrains AF : ${tc.affected.join(', ')}` : '';
        html += `<div class="px-6 py-3 text-sm text-gray-800 dark:text-gray-200 border-b border-gray-50 dark:border-gray-800 last:border-b-0">
          <span class="font-bold text-red-700 dark:text-red-400">${tc.name}</span>
          <span class="ml-2 text-gray-500 dark:text-gray-400">${tc.basin} · ${tc.category} · ${tc.windKt}kt${affected}</span>
        </div>`;
      });

      html += sectionHeader('🌋', 'Activité volcanique', { cls: 'bg-green-100 text-green-700', label: '✓ Auto · VAAC' });
      if (!data.volcanique.length) { html += nilLine(); }
      else data.volcanique.forEach(v => {
        const fl = v.flLevel ? ` — ${v.flLevel}` : '';
        html += `<div class="px-6 py-3 text-sm text-gray-800 dark:text-gray-200 border-b border-gray-50 dark:border-gray-800 last:border-b-0">
          <span class="font-bold">${v.volcanoName}</span>
          <span class="text-gray-500 dark:text-gray-400 ml-2">${v.country}${fl} (VAAC ${v.vaac})</span>
        </div>`;
      });

      html += sectionHeader('🚀', 'Tirs de fusée', { cls: 'bg-green-100 text-green-700', label: '✓ Auto · 12h' });
      if (!data.tirsFusee.length) { html += nilLine(); }
      else data.tirsFusee.forEach(launch => {
        const apBadges = launch.airports.map(a =>
          `<span class="bg-blue-100 dark:bg-blue-900 text-blue-700 dark:text-blue-300 text-[10px] px-1.5 py-0.5 rounded font-mono">${a}</span>`
        ).join(' ');
        html += `<div class="px-6 py-3 text-sm text-gray-800 dark:text-gray-200 border-b border-gray-50 dark:border-gray-800 last:border-b-0">
          <div class="flex flex-wrap items-center gap-2">
            <span class="font-bold text-gray-900 dark:text-white">${launch.provider}</span>
            <span class="text-gray-500 dark:text-gray-400">— ${launch.rocket}</span>
            <span class="text-[10px] font-semibold px-1.5 py-0.5 rounded bg-gray-100 dark:bg-gray-700 text-gray-500 dark:text-gray-400 font-mono">${launch.timeZ}</span>
          </div>
          <div class="mt-1 text-xs text-gray-500 dark:text-gray-400">${launch.site}</div>
          <div class="mt-1.5 flex flex-wrap gap-1">${apBadges}</div>
        </div>`;
      });

      html += sectionHeader('⛽', 'Carburant', { cls: 'bg-orange-100 text-orange-700', label: '✏️ Manuel' });
      html += manualTextarea('field-carburant', 'Ex : Afrique + BZV + HAV', data.carburant);
      html += sectionHeader('🌐', 'Géopolitique', { cls: 'bg-orange-100 text-orange-700', label: '✏️ Manuel' });
      html += manualTextarea('field-geopolitique', 'Ex : Survol Afghanistan ok', data.geopolitique);
      html += sectionHeader('👥', 'Effectif DSP', { cls: 'bg-orange-100 text-orange-700', label: '✏️ Manuel' });
      html += `<div class="px-6 py-3">
        <input id="field-dsp" type="text" value="${data.effectifDsp || 'OK'}"
          class="w-40 border border-orange-200 dark:border-orange-800 rounded-lg px-3 py-1.5
                 bg-orange-50 dark:bg-orange-950 text-gray-900 dark:text-gray-100
                 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-orange-300" />
      </div>`;

      form.innerHTML = html;
    }

    function buildCopyContent() {
      if (!window._briefingData) return { plain: '', html: '' };
      const d = window._briefingData;
      const plainLines = [];
      const htmlLines  = ['<meta charset="utf-8">'];
      function section(header, items) {
        plainLines.push(header); htmlLines.push(`<b>${header}</b>`);
        items.forEach(line => { plainLines.push(line); htmlLines.push(line); });
        plainLines.push(''); htmlLines.push('');
      }
      const meteoItems = [];
      d.meteoHorsEurope.forEach((line, i) => {
        const capaEl = document.querySelector(`[data-field="capa"][data-idx="${i}"]`);
        const degEl  = document.querySelector(`[data-field="deg"][data-idx="${i}"]`);
        const infos  = [`ETA ${line.etaZ}`, `Fenêtre ${line.fenetreZ}`];
        if (capaEl?.value?.trim()) infos.push(`Capa attente ~${capaEl.value.trim()}min`);
        if (degEl?.value?.trim())  infos.push(`Dégagement ${degEl.value.trim().toUpperCase()}`);
        meteoItems.push(`-${line.phenomenon} ${line.iata} ${line.flight} (${infos.join(' - ')})`);
      });
      const twWithTAF = (d.tailwindWatch || []).filter(tw => tw.forecastAlerts.length > 0);
      twWithTAF.forEach(tw => {
        const runway = tw.forecastAlerts[0].runway;
        const fcsts  = tw.forecastAlerts.map(fa => {
          const windStr = fa.hasGust ? `${fa.wspdBase}G${fa.wgst}kt` : `${fa.tailwindKt}kt`;
          return `${windStr} (${utcDZ(fa.periodStart)}→${utcDZ(fa.periodEnd)})`;
        });
        meteoItems.push(`-Vent arrière ${tw.iata} ${runway} — TAF : ${fcsts.join(', ')}`);
      });
      section('Météo hors Europe :', meteoItems.length ? meteoItems : ['-NIL']);
      section('Perturbation tropicale :',
        !d.tropicale.length ? ['-NIL'] :
        d.tropicale.map(tc => `-${tc.name} — ${tc.basin} — ${tc.category} — ${tc.windKt}kt`));
      section('Activité volcanique :',
        !d.volcanique.length ? ['-NIL'] :
        d.volcanique.map(v => `-${v.volcanoName}${v.flLevel ? ' ' + v.flLevel : ''} (VAAC ${v.vaac})`));
      section('Tirs de fusée :',
        !d.tirsFusee.length ? ['-NIL'] :
        d.tirsFusee.map(l => `-${l.provider} — ${l.rocket} | ${l.site} | ${l.timeZ} (${l.airports.join(', ')})`));
      const carb = document.getElementById('field-carburant')?.value?.trim();
      section('Carburant :', [carb ? `-${carb}` : '-NIL']);
      const geo = document.getElementById('field-geopolitique')?.value?.trim();
      section('Géopolitique :', [geo ? `-${geo}` : '-NIL']);
      const dsp = document.getElementById('field-dsp')?.value?.trim();
      section('Effectif DSP :', [`-${dsp || 'OK'}`]);
      return { plain: plainLines.join('\n').trimEnd(), html: htmlLines.join('<br>\n').trimEnd() };
    }

    async function load(force = false) {
      const age = document.getElementById('briefing-age');
      if (age) age.textContent = 'Actualisation…';
      try {
        const r = await fetch(`/api/briefing${force ? '?force=1' : ''}`);
        if (!r.ok) throw new Error(`HTTP ${r.status}`);
        const data = await r.json();
        window._briefingData = data;
        renderBriefing(data);
        if (age) {
          const gen = new Date(data.generatedAt);
          age.textContent = `Données à ${String(gen.getUTCHours()).padStart(2,'0')}${String(gen.getUTCMinutes()).padStart(2,'0')}z`;
        }
      } catch (e) {
        const form = document.getElementById('briefing-form');
        if (form) form.innerHTML = `<div class="px-6 py-8 text-center text-red-500 text-sm">⚠️ Erreur : ${e.message}</div>`;
        if (age) age.textContent = 'Erreur';
      }
    }

    document.getElementById('btn-refresh')?.addEventListener('click', () => load(true));
    document.getElementById('btn-copy')?.addEventListener('click', async () => {
      const { plain, html } = buildCopyContent();
      try {
        if (typeof ClipboardItem !== 'undefined') {
          await navigator.clipboard.write([
            new ClipboardItem({
              'text/html':  new Blob([html],  { type: 'text/html' }),
              'text/plain': new Blob([plain], { type: 'text/plain' }),
            }),
          ]);
        } else {
          await navigator.clipboard.writeText(plain);
        }
        const toast = document.getElementById('toast-copy');
        if (toast) {
          toast.classList.remove('opacity-0'); toast.classList.add('opacity-100');
          setTimeout(() => { toast.classList.remove('opacity-100'); toast.classList.add('opacity-0'); }, 2500);
        }
      } catch (_) { prompt('Copier ce texte :', plain); }
    });

    load();
    setInterval(() => load(), 10 * 60 * 1000);

  })();
  </script>

</body>
</html>
