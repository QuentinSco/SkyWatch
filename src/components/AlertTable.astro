---
import AlertBadge from './AlertBadge.astro';
import type { WeatherAlert, Region } from '../types/alert';

export interface Props {
  region: Region;
  alerts: WeatherAlert[];
}
const { region, alerts } = Astro.props;

const regionLabel: Record<Region, string> = {
  AMN: '🌎 Amérique du Nord',
  AMS: '🌎 Amérique du Sud',
  AMO: '🏝 Amérique / Outremer',
  EUR: '🌍 Europe',
  ASIE: '🌏 Asie / Afrique / Océan Indien',
};

const filtered = alerts.filter(a => a.region === region);

function formatShortDate(str: string | undefined): string {
  if (!str) return '—';
  try {
    return new Date(str).toLocaleString('fr-FR', {
      day: '2-digit', month: '2-digit',
      hour: '2-digit', minute: '2-digit',
    });
  } catch { return str; }
}

function timeWindowStatus(validTo: string | undefined): { label: string; cls: string } | null {
  if (!validTo) return null;
  const now = Date.now();
  const to = new Date(validTo).getTime();
  const msLeft = to - now;
  if (msLeft < 0) return { label: 'Expirée', cls: 'text-gray-400 italic' };
  const h = Math.floor(msLeft / 3600000);
  const m = Math.floor((msLeft % 3600000) / 60000);
  if (h < 6) {
    const label = h > 0 ? `expire dans ${h}h${m > 0 ? m + 'm' : ''}` : `expire dans ${m}m`;
    return { label, cls: 'text-red-500 font-semibold' };
  }
  if (h < 24) return { label: `expire dans ${h}h`, cls: 'text-orange-500 font-medium' };
  const d = Math.floor(h / 24);
  return { label: `expire dans ${d}j`, cls: 'text-gray-500' };
}

function getLaunchStatus(validFrom: string | undefined, validTo: string | undefined): { label: string; cls: string } | null {
  if (!validFrom) return null;
  const now = Date.now();
  const from = new Date(validFrom).getTime();
  const to = validTo ? new Date(validTo).getTime() : null;
  if (now < from) return { label: '⏳ À venir', cls: 'text-blue-500 font-semibold' };
  if (to && now >= from && now <= to) return { label: '🟢 Tir en cours', cls: 'text-green-600 font-bold' };
  return { label: '✅ Fenêtre fermée', cls: 'text-gray-400 italic' };
}

function getVolcanoName(alert: WeatherAlert): string | null {
  if (alert.source !== 'VAAC' && (alert as any).eventType !== 'VAAC') return null;

  const direct = (alert as any).volcanoName as string | undefined;
  if (direct && direct.trim() && direct.trim() !== 'Inconnu' && direct.trim() !== 'Volcan inconnu') {
    return direct.trim();
  }

  const h = alert.headline;
  if (!h) return null;

  const m1 = h.match(/Avis cendres volcaniques\s*:\s*([\w][\w .,'\u00C0-\u017E-]{0,60}?)\s*(?:—|\s*FL|\s*\()/);
  if (m1) {
    const v = m1[1].trim();
    if (v && v !== 'Inconnu' && v !== 'Volcan inconnu') return v;
  }

  const m2 = h.match(/Cendres volcaniques\s*[—\-–]\s*([\w][\w .,'\u00C0-\u017E-]{0,60}?)\s*(?:FL|\(VAAC|—|$)/);
  if (m2) {
    const v = m2[1].trim();
    if (v && v !== 'Inconnu' && v !== 'Volcan' && v !== 'Volcan inconnu') return v;
  }

  return null;
}

function getLaunchMissionName(headline: string): string | null {
  const match = headline.match(/^([^\u2014|]+)/);
  if (match) {
    return match[1].trim();
  }
  return null;
}

function getLaunchCountdown(validFrom: string | undefined): { text: string; urgent: boolean; past: boolean } {
  if (!validFrom) return { text: '—', urgent: false, past: false };
  const now = Date.now();
  const launch = new Date(validFrom).getTime();
  const msLeft = launch - now;

  if (msLeft < 0) {
    const msPast = Math.abs(msLeft);
    const h = Math.floor(msPast / 3600000);
    const m = Math.floor((msPast % 3600000) / 60000);
    return { text: h > 0 ? `T+${h}h${m}m` : `T+${m}m`, urgent: false, past: true };
  }

  const h = Math.floor(msLeft / 3600000);
  const m = Math.floor((msLeft % 3600000) / 60000);
  return {
    text: h > 0 ? `T-${h}h${m}m` : `T-${m}m`,
    urgent: msLeft < 7200000,
    past: false,
  };
}

const borderColor = filtered.some(a => a.severity === 'red')
  ? 'border-red-500'
  : filtered.some(a => a.severity === 'orange')
    ? 'border-orange-400'
    : 'border-yellow-400';
---

<section class={`border-l-4 ${borderColor} pl-4 mb-8`}>
  <h2 class="text-base font-semibold text-gray-700 mb-3 flex items-center gap-2">
    {regionLabel[region]}
    <span class="text-sm font-normal text-gray-400">
      ({filtered.length} alerte{filtered.length > 1 ? 's' : ''})
    </span>
  </h2>

  {filtered.length === 0 ? (
    <p class="text-gray-400 text-sm italic">Aucune alerte significative.</p>
  ) : (
    <div class="rounded-xl border border-gray-200 shadow-sm">
      <table class="w-full text-sm text-left text-gray-700 bg-white">
        <thead class="text-xs text-gray-500 uppercase bg-gray-50 border-b border-gray-200">
          <tr>
            <th class="py-3 px-4">Niveau</th>
            <th class="py-3 px-4">Phénomène</th>
            <th class="py-3 px-4">Pays / Zone</th>
            <th class="py-3 px-4">Aéroports AF concernés</th>
            <th class="py-3 px-4">Fenêtre</th>
            <th class="py-3 px-4">Source</th>
            <th class="py-3 px-4">Résumé</th>
          </tr>
        </thead>
        <tbody>
          {filtered.map((alert, i) => {
            const volcanoName = getVolcanoName(alert);
            const isSpatial = alert.phenomenon === 'Tir spatial';
            const isBackup = (alert as any).isBackup === true || (alert as any).eventType === 'LAUNCH_BACKUP';
            const alertId = `alert-${region}-${i}`;
            return (
            <tr 
              class={`border-b border-gray-100 hover:bg-blue-50 transition cursor-pointer ${i % 2 === 0 ? 'bg-white' : 'bg-gray-50/50'}`}
              onclick={`document.getElementById('modal-${alertId}').classList.remove('hidden')`}
            >

              <td class="py-2 px-4">
                <AlertBadge severity={alert.severity} isSpatial={isSpatial} isBackup={isBackup} />
              </td>

              <td class="py-2 px-4 font-medium text-gray-800">
                {alert.phenomenon}
                {isSpatial && (
                  <div class="text-xs text-violet-700 font-semibold mt-0.5 flex items-center gap-1">
                    {isBackup ? '🛸 Backup :' : '🚀'} {getLaunchMissionName(alert.headline)}
                  </div>
                )}
                {volcanoName && (
                  <div class="text-xs text-orange-700 font-semibold mt-0.5 flex items-center gap-1">
                    🌋 {volcanoName}
                  </div>
                )}
              </td>

              <td class="py-2 px-4 text-gray-600">
                {alert.country}
              </td>

              <td class="py-2 px-4">
                {alert.airports.length > 0
                  ? (
                    <div class="flex flex-wrap gap-1">
                      {alert.airports.map(a => (
                        <span class="bg-blue-100 text-blue-700 text-xs px-1.5 py-0.5 rounded font-mono">
                          {a}
                        </span>
                      ))}
                    </div>
                  )
                  : <span class="text-gray-300 italic text-xs">—</span>
                }
              </td>

              <td class="py-2 px-4">
                {(() => {
                  if (isSpatial) {
                    const status = getLaunchStatus(alert.validFrom, alert.validTo);
                    return (
                      <div class="text-xs leading-tight">
                        <div class="text-gray-500">{formatShortDate(alert.validFrom)}</div>
                        <div class="text-gray-400 text-[10px]">→ {formatShortDate(alert.validTo)}</div>
                        {status && <div class={`mt-0.5 text-[10px] ${status.cls}`}>{status.label}</div>}
                      </div>
                    );
                  }
                  const status = timeWindowStatus(alert.validTo);
                  return (
                    <div class="text-xs leading-tight">
                      <div class="text-gray-500">{formatShortDate(alert.validFrom)}</div>
                      <div class="text-gray-400 text-[10px]">→ {formatShortDate(alert.validTo)}</div>
                      {status && <div class={`mt-0.5 text-[10px] ${status.cls}`}>{status.label}</div>}
                    </div>
                  );
                })()}
              </td>

              <td class="py-2 px-4">
                {(() => {
                  const links = (alert as any).sourceLinks as Array<{ label: string; url: string }> | undefined;
                  if (links && links.length > 0) {
                    return (
                      <div class="flex flex-col gap-1">
                        <span class="text-[10px] text-gray-400 uppercase tracking-wide font-medium">{alert.source}</span>
                        <div class="flex flex-col gap-0.5">
                          {links.map((l: { label: string; url: string }) => (
                            <a
                              href={l.url}
                              target="_blank"
                              rel="noopener noreferrer"
                              class="text-xs bg-blue-50 text-blue-700 rounded px-1.5 py-0.5 border border-blue-200 hover:bg-blue-100 transition"
                              onclick={(e: Event) => e.stopPropagation()}
                            >
                              {l.label} ↗
                            </a>
                          ))}
                        </div>
                      </div>
                    );
                  }
                  return (
                    <span class="text-xs bg-gray-100 text-gray-600 rounded px-2 py-0.5 border border-gray-200">
                      {alert.source}
                    </span>
                  );
                })()}
              </td>

              <td class="py-2 px-4 max-w-xs">
                {(() => {
                  if (isSpatial) {
                    const mission = getLaunchMissionName(alert.headline);
                    const countdown = getLaunchCountdown(alert.validFrom);
                    return (
                      <div class="text-xs leading-tight">
                        <div class="font-medium text-gray-700">{mission ?? alert.headline.slice(0, 80)}</div>
                        <div class={`font-bold mt-0.5 ${
                          countdown.past ? 'text-gray-400' : countdown.urgent ? 'text-red-500' : 'text-blue-600'
                        }`}>{countdown.text}</div>
                      </div>
                    );
                  }
                  const text = alert.headline.slice(0, 90) + (alert.headline.length > 90 ? '…' : '');
                  return <span class="text-gray-500 text-xs break-words">{text}</span>;
                })()}
              </td>

            </tr>
            );
          })}
        </tbody>
      </table>
    </div>
  )}
</section>

<!-- Modales de détails -->
{filtered.map((alert, i) => {
  const alertId = `alert-${region}-${i}`;
  const volcanoName = getVolcanoName(alert);
  const isSpatial = alert.phenomenon === 'Tir spatial';
  const isBackup = (alert as any).isBackup === true || (alert as any).eventType === 'LAUNCH_BACKUP';
  return (
    <div 
      id={`modal-${alertId}`} 
      class="hidden fixed inset-0 bg-black bg-opacity-50 z-50 flex items-center justify-center p-4"
      onclick={`if (event.target === this) this.classList.add('hidden')`}
    >
      <div class="bg-white rounded-lg shadow-xl max-w-2xl w-full max-h-[90vh] overflow-y-auto">
        <div class="sticky top-0 bg-white border-b border-gray-200 px-6 py-4 flex items-center justify-between">
          <div class="flex items-center gap-3">
            <AlertBadge severity={alert.severity} isSpatial={isSpatial} isBackup={isBackup} />
            <h3 class="text-lg font-semibold text-gray-800">{alert.phenomenon}</h3>
          </div>
          <button 
            onclick={`document.getElementById('modal-${alertId}').classList.add('hidden')`}
            class="text-gray-400 hover:text-gray-600 text-2xl leading-none"
          >
            ×
          </button>
        </div>
        
        <div class="px-6 py-4 space-y-4">
          {isSpatial && (() => {
            const mission = getLaunchMissionName(alert.headline);
            const countdown = getLaunchCountdown(alert.validFrom);
            const status = getLaunchStatus(alert.validFrom, alert.validTo);
            return (
              <div class={`border rounded-lg p-3 ${
                isBackup ? 'bg-violet-50/50 border-violet-200' : 'bg-violet-50 border-violet-200'
              }`}>
                <div class="text-sm font-semibold text-violet-800 flex items-center gap-2">
                  🚀 Mission : {mission ?? '—'}
                  {isBackup && <span class="text-xs font-normal text-violet-500 bg-violet-100 rounded px-1.5 py-0.5">Tir de secours</span>}
                </div>
                <div class={`text-sm font-bold mt-1 ${
                  countdown.past ? 'text-gray-400' : countdown.urgent ? 'text-red-500' : 'text-blue-600'
                }`}>{countdown.text}</div>
                {status && <div class={`text-xs mt-1 ${status.cls}`}>{status.label}</div>}
              </div>
            );
          })()}

          {volcanoName && (
            <div class="bg-orange-50 border border-orange-200 rounded-lg p-3">
              <div class="text-sm font-semibold text-orange-800 flex items-center gap-2">
                🌋 Volcan : {volcanoName}
              </div>
            </div>
          )}
          
          <div>
            <h4 class="text-sm font-semibold text-gray-700 mb-1">Description complète</h4>
            <p class="text-sm text-gray-600 leading-relaxed">{alert.headline}</p>
          </div>
          
          <div class="grid grid-cols-2 gap-4">
            <div>
              <h4 class="text-xs font-semibold text-gray-500 uppercase mb-1">Pays / Zone</h4>
              <p class="text-sm text-gray-700">{alert.country}</p>
            </div>
            
            <div>
              <h4 class="text-xs font-semibold text-gray-500 uppercase mb-1">Source</h4>
              <p class="text-sm text-gray-700">{alert.source}</p>
            </div>
            
            <div>
              <h4 class="text-xs font-semibold text-gray-500 uppercase mb-1">Début</h4>
              <p class="text-sm text-gray-700">{formatShortDate(alert.validFrom)}</p>
            </div>
            
            <div>
              <h4 class="text-xs font-semibold text-gray-500 uppercase mb-1">Fin</h4>
              <p class="text-sm text-gray-700">{formatShortDate(alert.validTo)}</p>
            </div>
          </div>
          
          {alert.airports.length > 0 && (
            <div>
              <h4 class="text-sm font-semibold text-gray-700 mb-2">Aéroports AF concernés</h4>
              <div class="flex flex-wrap gap-2">
                {alert.airports.map(a => (
                  <span class="bg-blue-100 text-blue-700 text-sm px-2 py-1 rounded font-mono">
                    {a}
                  </span>
                ))}
              </div>
            </div>
          )}
          
          {(() => {
            const links = (alert as any).sourceLinks as Array<{ label: string; url: string }> | undefined;
            if (links && links.length > 0) {
              return (
                <div>
                  <h4 class="text-sm font-semibold text-gray-700 mb-2">Liens officiels</h4>
                  <div class="flex flex-col gap-2">
                    {links.map((l: { label: string; url: string }) => (
                      <a
                        href={l.url}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="text-sm bg-blue-50 text-blue-700 rounded px-3 py-2 border border-blue-200 hover:bg-blue-100 transition flex items-center justify-between"
                      >
                        <span>{l.label}</span>
                        <span>↗</span>
                      </a>
                    ))}
                  </div>
                </div>
              );
            }
          })()}
        </div>
      </div>
    </div>
  );
})}
