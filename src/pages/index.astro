---
import '../styles/global.css';
---
<!doctype html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>SkyWatch – Alertes météo dispatch</title>
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
  
  <!-- Dark Mode Script - Load early to prevent flash -->
  <script is:inline src="/lib/dark-mode.js"></script>
  
  <style>
    .main-grid {
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
    }

    #base-status-slot { display: none; }

    @media (min-width: 1280px) {

      body {
        height: 100vh;
        overflow: hidden;
      }

      .main-grid {
        display: grid;
        grid-template-columns: minmax(0, 1.1fr) minmax(0, 0.9fr);
        grid-template-rows: auto;
        align-items: start;
        gap: 1rem;
      }

      .col-map {
        position: sticky;
        top: 1.5rem;
        display: flex;
        flex-direction: column;
        gap: 1rem;
        height: calc(100vh - 2rem);
      }

      #alert-map {
        height: clamp(350px, 45vh, 520px) !important;
        min-height: 350px;
        flex-shrink: 0;
      }

      #base-status-slot {
        display: flex;
        flex-direction: column;
        flex: 1;
        min-height: 0;
      }

      #base-status-body {
        flex: 1;
        min-height: 0;
        overflow-y: auto;
      }

      .col-alerts {
        overflow-y: auto;
        height: calc(100vh - 2rem);
        padding-right: 0.25rem;
      }
    }

    #base-status-body::-webkit-scrollbar,
    .col-alerts::-webkit-scrollbar { width: 4px; }
    #base-status-body::-webkit-scrollbar-track,
    .col-alerts::-webkit-scrollbar-track { background: transparent; }
    #base-status-body::-webkit-scrollbar-thumb,
    .col-alerts::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 2px; }
  </style>
</head>

<body class="text-gray-900 dark:text-gray-100 min-h-screen flex bg-slate-50 dark:bg-gray-950">

  <!-- ─── Sidebar ───────────────────────────────────────────── -->
  <aside class="hidden xl:flex flex-col w-56 shrink-0 sticky top-0 h-screen border-r border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-900 px-4 py-6 overflow-y-auto">
    <div class="mb-6">
      <div class="flex items-center gap-2 text-2xl font-bold tracking-tight text-gray-900 dark:text-white">
        <img src="/favicon.png" alt="SkyWatch logo" class="w-8 h-8 object-contain" />
        SkyWatch
      </div>
      <div class="text-gray-400 dark:text-gray-500 text-xs mt-1">Superviseur dispatch</div>
    </div>
    <div class="text-xs text-gray-400 dark:text-gray-500 mb-1" id="last-update">Chargement…</div>
    <div id="counters" class="flex flex-wrap gap-1 mb-6"></div>
    <nav class="flex flex-col gap-1 text-sm" id="sidebar-nav">
      <div class="text-[10px] uppercase font-semibold text-gray-400 dark:text-gray-600 tracking-widest mb-2">Sections</div>
      <a href="#section-carte" class="sidebar-link flex items-center gap-2 px-3 py-2 rounded-lg text-gray-600 dark:text-gray-400 hover:bg-blue-50 dark:hover:bg-blue-950 hover:text-blue-700 dark:hover:text-blue-400 transition font-medium">🗺️ Carte</a>
      <a href="#section-alertes" class="sidebar-link flex items-center gap-2 px-3 py-2 rounded-lg text-gray-600 dark:text-gray-400 hover:bg-blue-50 dark:hover:bg-blue-950 hover:text-blue-700 dark:hover:text-blue-400 transition font-medium">
        🌐 Alertes actives <span id="nav-alert-count" class="ml-auto"></span>
      </a>
      <a href="#section-vols" class="sidebar-link flex items-center gap-2 px-3 py-2 rounded-lg text-gray-600 dark:text-gray-400 hover:bg-blue-50 dark:hover:bg-blue-950 hover:text-blue-700 dark:hover:text-blue-400 transition font-medium">
        ✈️ Vols impactés <span id="nav-vol-count" class="ml-auto"></span>
      </a>
      <a href="#section-taf" class="sidebar-link flex items-center gap-2 px-3 py-2 rounded-lg text-gray-600 dark:text-gray-400 hover:bg-blue-50 dark:hover:bg-blue-950 hover:text-blue-700 dark:hover:text-blue-400 transition font-medium">
        🌩 TAF Risques AF <span id="nav-taf-count" class="ml-auto"></span>
      </a>
      <!-- ─── Outils ────────────────────────────────────── -->
      <div class="mt-4 pt-4 border-t border-gray-100 dark:border-gray-800">
        <div class="text-[10px] uppercase font-semibold text-gray-400 dark:text-gray-600 tracking-widest mb-2">Outils</div>
        <a href="/briefing" class="sidebar-link flex items-center gap-2 px-3 py-2 rounded-lg text-gray-600 dark:text-gray-400 hover:bg-purple-50 dark:hover:bg-purple-950 hover:text-purple-700 dark:hover:text-purple-400 transition font-medium">
          🗒 Trame briefing
        </a>
        <a href="/chainages" class="sidebar-link flex items-center gap-2 px-3 py-2 rounded-lg text-gray-600 dark:text-gray-400 hover:bg-indigo-50 dark:hover:bg-indigo-950 hover:text-indigo-700 dark:hover:text-indigo-400 transition font-medium">
          🔗 Chaînages
        </a>
        <a href="/crosswind" class="sidebar-link flex items-center gap-2 px-3 py-2 rounded-lg text-gray-600 dark:text-gray-400 hover:bg-blue-50 dark:hover:bg-blue-950 hover:text-blue-700 dark:hover:text-blue-400 transition font-medium">
          💨 Vent de travers
        </a>
      </div>
    </nav>
    <!-- Dark mode toggle button will be injected here by dark-mode.js -->
    <div class="mt-auto pt-6 border-t border-gray-100 dark:border-gray-800 text-[10px] text-gray-400 dark:text-gray-600 leading-relaxed">
      <strong class="text-gray-500 dark:text-gray-400">Horizon :</strong> J à J+3<br>
      Phénomènes grande échelle uniquement.<br>
      J reste sous resp. dispatcher individuelle.
    </div>
  </aside>

  <!-- ─── Contenu principal ──────────────────────────────────────────────── -->
  <div class="flex-1 min-w-0 overflow-y-auto xl:overflow-hidden">
    <div class="px-4 py-6 xl:px-6">

      <!-- Header mobile / intermédiaire (visible jusqu'à xl) -->
      <header class="xl:hidden mb-6">
        <div class="flex items-center justify-between flex-wrap gap-4">
          <div>
            <h1 class="flex items-center gap-2 text-2xl font-bold tracking-tight text-gray-900 dark:text-white">
              <img src="/favicon.png" alt="SkyWatch logo" class="w-8 h-8 object-contain" />
              SkyWatch
            </h1>
            <p class="text-gray-500 dark:text-gray-400 text-xs mt-1">Agrégateur d&rsquo;alertes météo — Outil superviseur dispatch</p>
          </div>
          <div class="text-right text-xs text-gray-500 dark:text-gray-400">
            <div id="last-update-mobile">Chargement...</div>
          </div>
          <!-- Dark mode toggle button will be injected here by dark-mode.js -->
        </div>
        <div class="mt-3 bg-blue-50 dark:bg-blue-950 border border-blue-200 dark:border-blue-800 rounded-xl p-3 text-xs text-blue-700 dark:text-blue-300">
          ℹ️ <strong>Horizon :</strong> J à J+3 — Phénomènes grande échelle uniquement.
        </div>
        <!-- Liens outils mobile -->
        <div class="mt-2 flex gap-2 flex-wrap">
          <a href="/briefing" class="flex items-center gap-2 px-3 py-2 rounded-xl bg-purple-50 dark:bg-purple-950 border border-purple-200 dark:border-purple-800 text-purple-700 dark:text-purple-300 text-xs font-medium">
            🗒 Trame briefing CCO
          </a>
          <a href="/chainages" class="flex items-center gap-2 px-3 py-2 rounded-xl bg-indigo-50 dark:bg-indigo-950 border border-indigo-200 dark:border-indigo-800 text-indigo-700 dark:text-indigo-300 text-xs font-medium">
            🔗 Chaînages
          </a>
          <a href="/crosswind" class="flex items-center gap-2 px-3 py-2 rounded-xl bg-blue-50 dark:bg-blue-950 border border-blue-200 dark:border-blue-800 text-blue-700 dark:text-blue-300 text-xs font-medium">
            💨 Vent de travers
          </a>
        </div>
      </header>

      <div class="main-grid">

        <!-- Colonne gauche -->
        <div class="col-map">

          <section id="section-carte" class="scroll-mt-6">
            <div class="rounded-xl overflow-hidden border border-gray-200 dark:border-gray-700 shadow-sm">
              <div class="bg-gray-50 dark:bg-gray-800 border-b border-gray-200 dark:border-gray-700 px-4 py-2 text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wide">
                🗺️ Carte des alertes actives
              </div>
              <div id="alert-map" style="height: 420px; width: 100%;"></div>
            </div>
          </section>

          <!-- Slot CDG/ORY (visible uniquement xl+, géré par taf-ui.js) -->
          <div id="base-status-slot" class="rounded-xl border border-gray-200 dark:border-gray-700 shadow-sm bg-white dark:bg-gray-900 overflow-hidden">
            <div class="bg-gray-50 dark:bg-gray-800 border-b border-gray-200 dark:border-gray-700 px-4 py-2 text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wide flex-shrink-0">
              🛥 État base CDG / ORY
            </div>
            <div id="base-status-body" class="text-sm text-gray-400 dark:text-gray-600 italic px-4 py-3">
              Chargement…
            </div>
          </div>

        </div>

        <!-- Colonne droite -->
        <div class="col-alerts">

          <section id="section-alertes" class="mb-8 scroll-mt-6">
            <main id="main-content">
              <div class="text-gray-400 dark:text-gray-600 text-sm italic">Chargement des alertes...</div>
            </main>
          </section>

          <section id="section-vols" class="mb-8 scroll-mt-6">
            <div class="flex items-center justify-between mb-3 flex-wrap gap-3">
              <div>
                <h2 class="text-xl font-bold text-gray-900 dark:text-white">✈️ Vols AF LC impactés</h2>
                <p class="text-gray-500 dark:text-gray-400 text-sm mt-0.5">Croisement TAF / vols AF arrivées — ETA dans une fenêtre de menace active ou dans les 2h précédant celle-ci.</p>
              </div>
              <div id="taf-vol-counters" class="flex gap-2 text-xs"></div>
            </div>
            <div id="taf-vol-main">
              <div class="text-gray-400 dark:text-gray-600 text-sm italic">Chargement des vols…</div>
            </div>
          </section>

          <section id="section-taf" class="mb-8 scroll-mt-6">
            <div class="flex items-center justify-between mb-4 flex-wrap gap-3">
              <div>
                <h2 class="text-xl font-bold text-gray-900 dark:text-white">🌩 TAF Risques AF</h2>
                <p class="text-gray-500 dark:text-gray-400 text-sm mt-0.5">Phénomènes significatifs sur le réseau AF — Source AviationWeather.gov</p>
              </div>
              <div id="taf-counters" class="flex gap-2"></div>
            </div>
            <div id="taf-main">
              <div class="text-gray-400 dark:text-gray-600 text-sm italic">Chargement des TAFs...</div>
            </div>
          </section>

          <footer class="pt-4 border-t border-gray-200 dark:border-gray-800">
            <!-- Widget backup : discret, en bas de page -->
            <div id="backup-widget" class="mb-3"></div>
            <div class="text-xs text-gray-400 dark:text-gray-600 flex flex-wrap gap-4 justify-between">
              <span>Sources : GDACS (UN/CE) · NOAA/NWS · MeteoAlarm (EUMETNET) · AviationWeather.gov (TAF) · NHC (NOAA) · RSMC La Réunion (Météo-France) · JTWC</span>
              <span>SkyWatch POC v0.1 — Open source uniquement</span>
            </div>
          </footer>

        </div>
      </div>
    </div>
  </div>

  <script is:inline src="/lib/main.js"></script>
  <script is:inline src="/lib/taf-ui.js"></script>
  <script is:inline src="/lib/backup-ui.js"></script>
  <script is:inline src="/lib/lazy-load.js"></script>

  <script is:inline>
    (function () {
      const sections = ['section-carte', 'section-alertes', 'section-vols', 'section-taf'];
      const links = document.querySelectorAll('.sidebar-link');
      function setActive(id) {
        links.forEach(l => {
          const href = l.getAttribute('href');
          if (!href.startsWith('#')) return; // ignorer les liens de navigation inter-pages (/briefing, /chainages, /crosswind)
          if (href === '#' + id) { l.classList.add('bg-blue-50', 'dark:bg-blue-950', 'text-blue-700', 'dark:text-blue-400'); l.classList.remove('text-gray-600', 'dark:text-gray-400'); }
          else { l.classList.remove('bg-blue-50', 'dark:bg-blue-950', 'text-blue-700', 'dark:text-blue-400'); l.classList.add('text-gray-600', 'dark:text-gray-400'); }
        });
      }
      const observer = new IntersectionObserver(
        (entries) => { entries.forEach(e => { if (e.isIntersecting) setActive(e.target.id); }); },
        { threshold: 0.2 }
      );
      document.addEventListener('DOMContentLoaded', () => {
        sections.forEach(id => { const el = document.getElementById(id); if (el) observer.observe(el); });
        setActive('section-carte');
      });
    })();
  </script>

  <script is:inline>
    (function () {
      function syncNavCount(sourceId, navId, bgClass, textClass) {
        const src = document.getElementById(sourceId);
        const nav = document.getElementById(navId);
        if (!src || !nav) return;
        const observer = new MutationObserver(() => {
          const countSpans = src.querySelectorAll('span[data-count]');
          let count = 0;
          countSpans.forEach(s => {
            const n = parseInt(s.getAttribute('data-count'));
            if (!isNaN(n)) count += n;
          });
          nav.innerHTML = count > 0
            ? `<span class="${bgClass} ${textClass} text-[10px] font-bold px-1.5 py-0.5 rounded-full">${count}</span>`
            : '';
        });
        observer.observe(src, { childList: true, subtree: true, attributes: true, attributeFilter: ['data-count'] });
      }
      document.addEventListener('DOMContentLoaded', () => {
        syncNavCount('counters',         'nav-alert-count', 'bg-red-100',    'text-red-700');
        syncNavCount('taf-vol-counters', 'nav-vol-count',   'bg-orange-100', 'text-orange-700');
        syncNavCount('taf-counters',     'nav-taf-count',   'bg-orange-100', 'text-orange-700');
      });
    })();
  </script>

</body>
</html>
