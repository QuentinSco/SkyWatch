---
import '../styles/global.css';
---
<!doctype html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>SkyWatch – Chaînages</title>
  <script is:inline src="/lib/dark-mode.js"></script>
  <style>
    .timeline-wrap { overflow-x: auto; }
    .timeline-canvas { display: block; }
    #ch-tooltip {
      position: fixed;
      pointer-events: none;
      background: #1e293b;
      color: #f1f5f9;
      font-size: 11px;
      line-height: 1.6;
      padding: 7px 11px;
      border-radius: 8px;
      white-space: pre;
      z-index: 9999;
      opacity: 0;
      transition: opacity .12s;
    }
  </style>
</head>

<body class="text-gray-900 min-h-screen flex" style="background:#f8fafc">

  <!-- ─ Sidebar ─────────────────────────────────────────── -->
  <aside class="hidden lg:flex flex-col w-56 shrink-0 sticky top-0 h-screen border-r border-gray-200 bg-white px-4 py-6 overflow-y-auto">
    <div class="mb-6">
      <div class="text-2xl font-bold tracking-tight text-gray-900">🛡 SkyWatch</div>
      <div class="text-gray-400 text-xs mt-1">Superviseur dispatch</div>
    </div>
    <nav class="flex flex-col gap-1 text-sm">
      <div class="text-[10px] uppercase font-semibold text-gray-400 tracking-widest mb-2">Navigation</div>
      <a href="/" class="flex items-center gap-2 px-3 py-2 rounded-lg text-gray-600 hover:bg-blue-50 hover:text-blue-700 transition font-medium">🗺️ Tableau de bord</a>
      <div class="mt-4 pt-4 border-t border-gray-100">
        <div class="text-[10px] uppercase font-semibold text-gray-400 tracking-widest mb-2">Outils</div>
        <a href="/briefing" class="flex items-center gap-2 px-3 py-2 rounded-lg text-gray-600 hover:bg-purple-50 hover:text-purple-700 transition font-medium">🗒 Trame briefing</a>
        <a href="/chainages" class="flex items-center gap-2 px-3 py-2 rounded-lg bg-indigo-50 text-indigo-700 font-semibold">🔗 Chaînages</a>
      </div>
    </nav>
    <div class="mt-auto pt-6 border-t border-gray-100 text-[10px] text-gray-400 leading-relaxed">
      <strong class="text-gray-500">Horizon :</strong> 24h glissantes<br>
      Vols AF long-courrier uniquement.
    </div>
  </aside>

  <!-- ─ Contenu ─────────────────────────────────────────── -->
  <div class="flex-1 min-w-0 overflow-y-auto">
    <div class="max-w-5xl mx-auto px-4 py-6 xl:px-8">

      <!-- Header page -->
      <div class="flex items-center justify-between flex-wrap gap-4 mb-6">
        <div>
          <h1 class="text-2xl font-bold tracking-tight text-gray-900">🔗 Chaînages</h1>
          <p class="text-gray-500 text-xs mt-1">Temps de rotation des appareils AF LC — Fenêtre <strong>maintenant → +24h</strong></p>
        </div>
        <div class="flex items-center gap-2">
          <span id="ch-age" class="text-xs text-gray-400"></span>
          <button id="btn-refresh" class="flex items-center gap-1.5 px-3 py-1.5 text-xs font-medium rounded-lg border border-gray-200 bg-white hover:bg-gray-50 text-gray-600 transition">
            🔄 Actualiser
          </button>
        </div>
      </div>

      <!-- Saisie -->
      <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4 mb-6">
        <div class="text-xs font-semibold text-gray-500 uppercase tracking-widest mb-3">Aéroports à surveiller</div>
        <div class="flex items-center gap-2 mb-3">
          <input id="airport-input" type="text" maxlength="4"
            placeholder="IATA (JFK) ou OACI (KJFK)"
            class="w-48 border border-gray-300 rounded-lg px-3 py-1.5 text-sm font-mono uppercase
                   focus:outline-none focus:ring-2 focus:ring-indigo-300 placeholder-gray-400" />
          <button id="btn-add-airport"
            class="flex items-center gap-1.5 px-3 py-1.5 text-xs font-semibold rounded-lg bg-indigo-600 hover:bg-indigo-700 text-white transition">
            + Ajouter
          </button>
        </div>
        <div id="airport-tags" class="flex flex-wrap gap-2 min-h-[28px]">
          <span class="text-xs text-gray-400 italic" id="no-airport-hint">Aucun aéroport sélectionné</span>
        </div>
      </div>

      <!-- Légende globale -->
      <div id="ch-legend" class="hidden flex items-center gap-5 mb-4 text-xs text-gray-500">
        <span class="flex items-center gap-1.5"><span id="leg-known" class="inline-block w-3 h-3 rounded"></span> Au sol (durée connue)</span>
        <span class="flex items-center gap-1.5"><span id="leg-unk" class="inline-block w-3 h-3 rounded border border-dashed"></span> Au sol (départ inconnu)</span>
        <span class="flex items-center gap-1.5"><span class="inline-block w-2 h-2 rounded-full bg-red-400"></span> Maintenant</span>
      </div>

      <!-- Résultats : blocs par aéroport injectés ici -->
      <div id="chainages-result">
        <div class="text-gray-400 text-sm italic text-center py-12">Ajoutez un aéroport pour afficher les chaînages.</div>
      </div>

    </div>
  </div>

  <div id="ch-tooltip"></div>

  <script is:inline>
  (function () {

    // ── Palette couleurs par aéroport ─────────────────────────────────
    // Chaque entrée : [barSolid, barHatch, hatchStroke, bgHeader, textHeader]
    const PALETTE = [
      { bar: '#818cf8', barU: '#c7d2fe', hatch: '#a5b4fc', bg: '#eef2ff', text: '#3730a3', border: '#a5b4fc' }, // indigo
      { bar: '#34d399', barU: '#a7f3d0', hatch: '#6ee7b7', bg: '#ecfdf5', text: '#065f46', border: '#6ee7b7' }, // emerald
      { bar: '#fb923c', barU: '#fed7aa', hatch: '#fdba74', bg: '#fff7ed', text: '#9a3412', border: '#fdba74' }, // orange
      { bar: '#f472b6', barU: '#fbcfe8', hatch: '#f9a8d4', bg: '#fdf2f8', text: '#9d174d', border: '#f9a8d4' }, // pink
      { bar: '#38bdf8', barU: '#bae6fd', hatch: '#7dd3fc', bg: '#f0f9ff', text: '#0c4a6e', border: '#7dd3fc' }, // sky
      { bar: '#a78bfa', barU: '#ddd6fe', hatch: '#c4b5fd', bg: '#f5f3ff', text: '#4c1d95', border: '#c4b5fd' }, // violet
      { bar: '#4ade80', barU: '#bbf7d0', hatch: '#86efac', bg: '#f0fdf4', text: '#14532d', border: '#86efac' }, // green
      { bar: '#fbbf24', barU: '#fde68a', hatch: '#fcd34d', bg: '#fffbeb', text: '#78350f', border: '#fcd34d' }, // amber
    ];

    // Map airport code → palette index (attribué à l'ajout)
    const airportColor = new Map();
    let colorCursor = 0;

    function paletteFor(code) {
      if (!airportColor.has(code)) {
        airportColor.set(code, colorCursor % PALETTE.length);
        colorCursor++;
      }
      return PALETTE[airportColor.get(code)];
    }

    // ── Constantes dessin ────────────────────────────────────────
    const ROW_H     = 44;
    const ROW_PAD   = 8;
    const BAR_H     = ROW_H - ROW_PAD * 2;
    const LABEL_W   = 92;
    const CHART_PAD = 12;
    const HEADER_H  = 28;
    const TICK_EVERY = 2;
    const FONT      = '11px/1 Inter, system-ui, sans-serif';
    const FONT_BOLD = 'bold 11px/1 Inter, system-ui, sans-serif';
    const COLOR_NOW  = '#f87171';
    const COLOR_GRID = '#e2e8f0';
    const COLOR_LABEL = '#64748b';
    const COLOR_BG_ALT = '#f8fafc';

    const airports = new Set();
    let lastData   = null;
    const tooltip  = document.getElementById('ch-tooltip');
    let allHitZones = []; // [{canvas, x1,y1,x2,y2,stop}]

    // ── Tags ──────────────────────────────────────────────────
    function renderTags() {
      const container = document.getElementById('airport-tags');
      const hint = document.getElementById('no-airport-hint');
      container.querySelectorAll('.ap-tag').forEach(el => el.remove());
      if (airports.size === 0) { hint.style.display = ''; return; }
      hint.style.display = 'none';
      airports.forEach(code => {
        const pal = paletteFor(code);
        const tag = document.createElement('span');
        tag.className = 'ap-tag inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-mono font-semibold';
        tag.style.cssText = `background:${pal.bg};color:${pal.text};border:1px solid ${pal.border}`;
        tag.innerHTML = `${code} <button data-code="${code}" class="ap-remove font-bold leading-none opacity-60 hover:opacity-100">✕</button>`;
        container.appendChild(tag);
      });
      container.querySelectorAll('.ap-remove').forEach(btn => {
        btn.addEventListener('click', () => { airports.delete(btn.getAttribute('data-code')); renderTags(); fetchChainages(); });
      });
    }

    function addAirport() {
      const input = document.getElementById('airport-input');
      const val = input.value.trim().toUpperCase();
      if (!val || val.length < 3) return;
      paletteFor(val); // attribution couleur stable
      airports.add(val); input.value = '';
      renderTags(); fetchChainages();
    }
    document.getElementById('btn-add-airport').addEventListener('click', addAirport);
    document.getElementById('airport-input').addEventListener('keydown', e => { if (e.key === 'Enter') addAirport(); });
    document.getElementById('btn-refresh').addEventListener('click', () => fetchChainages(true));

    // ── Helpers ────────────────────────────────────────────────
    function hhmm(ms) {
      const d = new Date(ms);
      return String(d.getUTCHours()).padStart(2,'0') + ':' + String(d.getUTCMinutes()).padStart(2,'0') + 'z';
    }
    function ddmm(ms) {
      const d = new Date(ms);
      return String(d.getUTCDate()).padStart(2,'0') + '/' + String(d.getUTCMonth()+1).padStart(2,'0');
    }

    // ── Dessine UN canvas pour UN aéroport ────────────────────────────
    function drawAirportTimeline(canvas, stops, wStart, wEnd, pal) {
      const nowMs  = Date.now();
      const span   = wEnd - wStart;
      const dpr    = window.devicePixelRatio || 1;
      const wrap   = canvas.parentElement;
      const availW = Math.max(wrap.clientWidth - LABEL_W - CHART_PAD, 200);
      const canvasW = LABEL_W + availW + CHART_PAD;
      const canvasH = HEADER_H + stops.length * ROW_H;

      canvas.width  = canvasW * dpr;
      canvas.height = canvasH * dpr;
      canvas.style.width  = canvasW + 'px';
      canvas.style.height = canvasH + 'px';

      const ctx = canvas.getContext('2d');
      ctx.scale(dpr, dpr);
      const toX = t => LABEL_W + ((t - wStart) / span) * availW;

      // Fond
      ctx.fillStyle = '#fff';
      ctx.fillRect(0, 0, canvasW, canvasH);
      stops.forEach((_, i) => {
        if (i % 2 === 1) { ctx.fillStyle = COLOR_BG_ALT; ctx.fillRect(0, HEADER_H + i * ROW_H, canvasW, ROW_H); }
      });

      // Grille + header heures
      ctx.strokeStyle = COLOR_GRID; ctx.lineWidth = 1;
      ctx.font = FONT; ctx.fillStyle = COLOR_LABEL;
      ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
      for (let h = 0; h <= 24; h += TICK_EVERY) {
        const t = wStart + h * 3600000;
        const x = toX(t);
        ctx.beginPath(); ctx.moveTo(x, HEADER_H); ctx.lineTo(x, canvasH); ctx.stroke();
        ctx.fillText(hhmm(t).slice(0,5), x, HEADER_H / 2);
      }
      // Séparateurs
      ctx.strokeStyle = '#cbd5e1'; ctx.lineWidth = 1;
      ctx.beginPath(); ctx.moveTo(LABEL_W, HEADER_H); ctx.lineTo(canvasW, HEADER_H); ctx.stroke();
      ctx.beginPath(); ctx.moveTo(LABEL_W, 0); ctx.lineTo(LABEL_W, canvasH); ctx.stroke();

      // Blocs
      const hitZones = [];
      stops.forEach((stop, i) => {
        const y0   = HEADER_H + i * ROW_H;
        const barY = y0 + ROW_PAD;
        const midY = barY + BAR_H / 2;

        // Matricule
        ctx.font = FONT_BOLD; ctx.fillStyle = '#1e293b';
        ctx.textAlign = 'left'; ctx.textBaseline = 'middle';
        ctx.fillText(stop.registration, 6, y0 + ROW_H / 2);
        if (stop.aircraftType) {
          const lw = ctx.measureText(stop.registration).width;
          ctx.font = FONT; ctx.fillStyle = '#94a3b8';
          ctx.fillText(stop.aircraftType, 6 + lw + 4, y0 + ROW_H / 2);
        }

        // Bloc
        const xArr  = toX(stop.arrMs);
        const known = stop.depMs !== null;
        const xDep  = known ? toX(stop.depMs) : canvasW - CHART_PAD;
        const barW  = Math.max(xDep - xArr, 4);
        const r     = 4;

        ctx.fillStyle = known ? pal.bar : pal.barU;
        ctx.beginPath(); ctx.roundRect(xArr, barY, barW, BAR_H, r); ctx.fill();

        // Hachures si départ inconnu
        if (!known) {
          ctx.save();
          ctx.beginPath(); ctx.roundRect(xArr, barY, barW, BAR_H, r); ctx.clip();
          ctx.strokeStyle = pal.hatch; ctx.lineWidth = 1.5;
          for (let xi = xArr + barW * 0.55; xi < xDep + BAR_H; xi += 6) {
            ctx.beginPath(); ctx.moveTo(xi, barY); ctx.lineTo(xi - BAR_H, barY + BAR_H); ctx.stroke();
          }
          ctx.restore();
        }

        // Texte dans le bloc
        const textColor = known ? '#fff' : pal.text;
        ctx.font = 'bold 10px/1 Inter, system-ui, sans-serif';
        ctx.fillStyle = textColor; ctx.textAlign = 'left'; ctx.textBaseline = 'middle';
        ctx.fillText('↓ ' + stop.arrFlight, xArr + 5, midY);
        if (stop.depFlight) {
          const dl = '↑ ' + stop.depFlight;
          ctx.fillText(dl, xDep - ctx.measureText(dl).width - 5, midY);
        }
        if (known && barW > 52) {
          const dm = Math.round((stop.depMs - stop.arrMs) / 60000);
          const dh = Math.floor(dm / 60);
          const mm = String(dm % 60).padStart(2, '0');
          ctx.font = FONT; ctx.fillStyle = known ? 'rgba(255,255,255,0.85)' : pal.text;
          ctx.textAlign = 'center';
          ctx.fillText(dh > 0 ? `${dh}h${mm}` : `${dm}min`, (xArr + xDep) / 2, midY);
        }

        hitZones.push({ x1: xArr, y1: barY, x2: xDep, y2: barY + BAR_H, stop });
      });

      // NOW
      const xNow = toX(nowMs);
      if (xNow >= LABEL_W && xNow <= canvasW) {
        ctx.strokeStyle = COLOR_NOW; ctx.lineWidth = 2;
        ctx.setLineDash([4, 3]);
        ctx.beginPath(); ctx.moveTo(xNow, 0); ctx.lineTo(xNow, canvasH); ctx.stroke();
        ctx.setLineDash([]);
        ctx.fillStyle = COLOR_NOW;
        ctx.beginPath(); ctx.arc(xNow, HEADER_H / 2, 4, 0, Math.PI * 2); ctx.fill();
        ctx.font = 'bold 9px/1 Inter, system-ui, sans-serif';
        ctx.fillStyle = COLOR_NOW; ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
        ctx.fillText('NOW', xNow, HEADER_H - 6);
      }

      // Tooltip hover
      canvas.addEventListener('mousemove', e => {
        const rect = canvas.getBoundingClientRect();
        const mx = e.clientX - rect.left, my = e.clientY - rect.top;
        const hit = hitZones.find(z => mx >= z.x1 && mx <= z.x2 && my >= z.y1 && my <= z.y2);
        if (hit) {
          const s = hit.stop;
          const arrL = `↓ ARR  ${s.arrFlight}  ${ddmm(s.arrMs)} ${hhmm(s.arrMs)}`;
          const depL = s.depFlight
            ? (s.depMs ? `↑ DEP  ${s.depFlight}  ${ddmm(s.depMs)} ${hhmm(s.depMs)}` : `↑ DEP  ${s.depFlight}  heure non disponible`)
            : '↑ DEP  non disponible';
          let durL = '';
          if (s.depMs) {
            const dm = Math.round((s.depMs - s.arrMs) / 60000);
            durL = `⏱  ${Math.floor(dm/60)}h${String(dm%60).padStart(2,'0')} au sol`;
          }
          tooltip.textContent = [arrL, depL, durL].filter(Boolean).join('\n');
          tooltip.style.opacity = '1';
          tooltip.style.left = (e.clientX + 14) + 'px';
          tooltip.style.top  = (e.clientY - 10) + 'px';
        } else {
          tooltip.style.opacity = '0';
        }
      });
      canvas.addEventListener('mouseleave', () => { tooltip.style.opacity = '0'; });

      return hitZones;
    }

    // ── Rendu principal ────────────────────────────────────────────
    function renderChainages(data) {
      lastData = data;
      const container = document.getElementById('chainages-result');
      const legend    = document.getElementById('ch-legend');
      const age       = document.getElementById('ch-age');

      if (age && data.generatedAt) {
        const d = new Date(data.generatedAt);
        age.textContent = `Données à ${String(d.getUTCHours()).padStart(2,'0')}:${String(d.getUTCMinutes()).padStart(2,'0')}z`;
      }

      const stops = data.stops || [];
      if (stops.length === 0) {
        container.innerHTML = '<div class="text-gray-400 text-sm italic text-center py-12">Aucun chaînage trouvé pour cette fenêtre 24h.</div>';
        legend.classList.add('hidden');
        return;
      }

      legend.classList.remove('hidden');
      // Met à jour les bulles de la légende avec la couleur du 1er aéroport
      const firstPal = paletteFor(Array.from(airports)[0]);
      document.getElementById('leg-known').style.background = firstPal.bar;
      document.getElementById('leg-unk').style.cssText = `background:${firstPal.barU};border-color:${firstPal.hatch};display:inline-block;width:12px;height:12px;border-radius:2px;border:1px dashed`;

      // Grouper par aéroport (ordre d'ajout)
      const byAirport = new Map();
      airports.forEach(code => byAirport.set(code, []));
      stops.forEach(s => {
        if (byAirport.has(s.iata)) byAirport.get(s.iata).push(s);
        else {
          // aéroport inconnu (OACI saisi) — on le range quand même
          if (!byAirport.has(s.iata)) byAirport.set(s.iata, []);
          byAirport.get(s.iata).push(s);
        }
      });

      container.innerHTML = '';
      allHitZones = [];

      byAirport.forEach((airStops, code) => {
        if (airStops.length === 0) {
          // Section vide
          const empty = document.createElement('div');
          empty.className = 'mb-4 rounded-xl border overflow-hidden shadow-sm';
          const pal = paletteFor(code);
          empty.style.borderColor = pal.border;
          empty.innerHTML = `
            <div class="flex items-center gap-2 px-4 py-2.5" style="background:${pal.bg};border-bottom:1px solid ${pal.border}">
              <span class="font-bold font-mono text-sm" style="color:${pal.text}">${code}</span>
              <span class="text-xs font-medium opacity-60" style="color:${pal.text}">0 appareil dans la fenêtre</span>
            </div>
            <div class="bg-white px-4 py-3 text-xs text-gray-400 italic">Aucun vol AF LC trouvé sur cet aéroport dans les prochaines 24h.</div>`;
          container.appendChild(empty);
          return;
        }

        const pal = paletteFor(code);

        // Wrapper section
        const section = document.createElement('div');
        section.className = 'mb-4 rounded-xl border overflow-hidden shadow-sm';
        section.style.borderColor = pal.border;

        // Header aéroport
        const header = document.createElement('div');
        header.className = 'flex items-center gap-3 px-4 py-2.5';
        header.style.cssText = `background:${pal.bg};border-bottom:1px solid ${pal.border}`;
        header.innerHTML = `
          <span class="inline-flex items-center justify-center w-7 h-7 rounded-lg font-bold font-mono text-xs" style="background:${pal.bar};color:#fff">${code}</span>
          <span class="font-semibold text-sm" style="color:${pal.text}">${airStops.length} appareil${airStops.length > 1 ? 's' : ''} dans la fenêtre</span>`;
        section.appendChild(header);

        // Canvas wrapper
        const wrap = document.createElement('div');
        wrap.className = 'timeline-wrap bg-white';
        const canvas = document.createElement('canvas');
        canvas.className = 'timeline-canvas';
        wrap.appendChild(canvas);
        section.appendChild(wrap);
        container.appendChild(section);

        // Dessin
        drawAirportTimeline(canvas, airStops, data.windowStart, data.windowEnd, pal);
      });
    }

    // Redessiner sur resize
    window.addEventListener('resize', () => { if (lastData) renderChainages(lastData); });

    // ── Fetch ──────────────────────────────────────────────────
    async function fetchChainages(force = false) {
      if (airports.size === 0) {
        document.getElementById('chainages-result').innerHTML =
          '<div class="text-gray-400 text-sm italic text-center py-12">Ajoutez un aéroport pour afficher les chaînages.</div>';
        document.getElementById('ch-legend').classList.add('hidden');
        return;
      }
      document.getElementById('chainages-result').innerHTML =
        '<div class="text-gray-400 text-sm italic text-center py-8">Chargement…</div>';
      const codes = Array.from(airports).join(',');
      const url = `/api/chainages?airports=${encodeURIComponent(codes)}${force ? '&force=1' : ''}`;
      try {
        const r = await fetch(url);
        if (!r.ok) throw new Error(`HTTP ${r.status}`);
        renderChainages(await r.json());
      } catch (e) {
        document.getElementById('chainages-result').innerHTML =
          `<div class="text-red-500 text-sm text-center py-8">⚠️ Erreur : ${e.message}</div>`;
      }
    }

  })();
  </script>

</body>
</html>
