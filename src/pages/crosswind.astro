import '../styles/global.css';
---
<!doctype html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>SkyWatch – Composante Vent de Travers</title>
  <script is:inline src="/lib/dark-mode.js"></script>
</head>

<body class="text-gray-900 dark:text-gray-100 min-h-screen flex bg-slate-50 dark:bg-gray-950">

  <!-- ─ Sidebar ───────────────────────────────────────────── -->
  <aside class="hidden lg:flex flex-col w-56 shrink-0 sticky top-0 h-screen
                border-r border-gray-200 dark:border-gray-800
                bg-white dark:bg-gray-900
                px-4 py-6 overflow-y-auto">
    <div class="mb-6">
      <div class="text-2xl font-bold tracking-tight text-gray-900 dark:text-white">🛡 SkyWatch</div>
      <div class="text-gray-400 dark:text-gray-500 text-xs mt-1">Superviseur dispatch</div>
    </div>
    <nav class="flex flex-col gap-1 text-sm">
      <div class="text-[10px] uppercase font-semibold text-gray-400 dark:text-gray-600 tracking-widest mb-2">Navigation</div>
      <a href="/" class="flex items-center gap-2 px-3 py-2 rounded-lg
                         text-gray-600 dark:text-gray-400
                         hover:bg-blue-50 dark:hover:bg-blue-950 hover:text-blue-700 dark:hover:text-blue-400
                         transition font-medium">🗺️ Tableau de bord</a>
      <div class="mt-4 pt-4 border-t border-gray-100 dark:border-gray-800">
        <div class="text-[10px] uppercase font-semibold text-gray-400 dark:text-gray-600 tracking-widest mb-2">Outils</div>
        <a href="/briefing" class="flex items-center gap-2 px-3 py-2 rounded-lg
                                   text-gray-600 dark:text-gray-400
                                   hover:bg-purple-50 dark:hover:bg-purple-950 hover:text-purple-700 dark:hover:text-purple-400
                                   transition font-medium">🗒 Trame briefing</a>
        <a href="/chainages" class="flex items-center gap-2 px-3 py-2 rounded-lg
                                    text-gray-600 dark:text-gray-400
                                    hover:bg-indigo-50 dark:hover:bg-indigo-950 hover:text-indigo-700 dark:hover:text-indigo-400
                                    transition font-medium">🔗 Chaînages</a>
        <a href="/crosswind" class="flex items-center gap-2 px-3 py-2 rounded-lg
                                    bg-blue-50 dark:bg-blue-950
                                    text-blue-700 dark:text-blue-300 font-semibold">💨 Vent de travers</a>
      </div>
    </nav>
    <div class="mt-auto pt-6 border-t border-gray-100 dark:border-gray-800 text-[10px] text-gray-400 dark:text-gray-600 leading-relaxed">
      <strong class="text-gray-500 dark:text-gray-400">Horizon :</strong> 24h glissantes<br>
      Vols AF long-courrier uniquement.
    </div>
  </aside>

  <!-- ─ Contenu ───────────────────────────────────────────── -->
  <div class="flex-1 min-w-0 overflow-y-auto">
    <div class="max-w-7xl mx-auto px-4 py-6 xl:px-8">

      <!-- En-tête -->
      <div class="flex items-center justify-between flex-wrap gap-4 mb-6">
        <div>
          <h1 class="text-2xl font-bold tracking-tight text-gray-900 dark:text-white">💨 Vent de Travers</h1>
          <p class="text-gray-500 dark:text-gray-400 text-xs mt-1">Composante crosswind par aéroport — TAF + vols AF</p>
        </div>
        <div class="flex items-center gap-3">
          <span id="crosswind-updated" class="text-xs text-gray-400 dark:text-gray-500"></span>
          <button
            id="btn-refresh"
            class="flex items-center gap-1.5 px-3 py-1.5 text-xs font-medium rounded-lg
                   border border-gray-200 dark:border-gray-700
                   bg-white dark:bg-gray-800
                   hover:bg-gray-50 dark:hover:bg-gray-700
                   text-gray-600 dark:text-gray-300 transition"
            onclick="loadCrosswind(true)"
          >🔄 Actualiser</button>
        </div>
      </div>

      <!-- Config panel -->
      <div class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-xl shadow-sm p-5 mb-6">
        <div class="flex flex-wrap items-end gap-4">
          <div class="flex-1 min-w-[200px]">
            <label class="block text-xs font-semibold text-gray-500 dark:text-gray-400 mb-1.5 uppercase tracking-wide">Escales à analyser</label>
            <div id="airport-selector" class="flex flex-wrap gap-2"></div>
          </div>
          <div class="flex flex-wrap gap-3 items-center text-xs font-semibold">
            <span class="text-gray-400 uppercase tracking-wide mr-1">Seuils :</span>
            <span class="flex items-center gap-1"><span class="inline-block w-3 h-3 rounded-sm bg-green-400"></span> OK</span>
            <span class="flex items-center gap-1"><span class="inline-block w-3 h-3 rounded-sm bg-yellow-400"></span> Attention</span>
            <span class="flex items-center gap-1"><span class="inline-block w-3 h-3 rounded-sm bg-orange-400"></span> Limite</span>
            <span class="flex items-center gap-1"><span class="inline-block w-3 h-3 rounded-sm bg-red-500"></span> Dépassé</span>
          </div>
        </div>
      </div>

      <!-- Results -->
      <div id="crosswind-container">
        <div class="flex items-center justify-center py-20 text-gray-400">
          <div class="text-center"><div class="text-4xl mb-3">💨</div><p class="text-sm">Chargement…</p></div>
        </div>
      </div>

    </div>
  </div>

  <script is:inline>
  // ─── CONFIG : pistes & QFU par aéroport ───────────────────────────────────
  const AIRPORT_RUNWAYS = {
    LFPG: { iata: 'CDG', name: 'Paris CDG',          qfu: [80, 260, 90, 270, 82, 262, 92, 272] },
    LFPO: { iata: 'ORY', name: 'Paris ORY',           qfu: [80, 260, 60, 240] },
    EGLL: { iata: 'LHR', name: 'Londres LHR',         qfu: [90, 270] },
    EHAM: { iata: 'AMS', name: 'Amsterdam AMS',       qfu: [180, 360, 60, 240, 40, 220, 90, 270, 120, 300] },
    EDDF: { iata: 'FRA', name: 'Francfort FRA',       qfu: [70, 250, 80, 260] },
    LEMD: { iata: 'MAD', name: 'Madrid MAD',           qfu: [180, 360, 140, 320] },
    LIRF: { iata: 'FCO', name: 'Rome FCO',             qfu: [70, 250, 160, 340] },
    LFMN: { iata: 'NCE', name: 'Nice NCE',             qfu: [40, 220] },
    KJFK: { iata: 'JFK', name: 'New York JFK',         qfu: [40, 220, 130, 310] },
    KLAX: { iata: 'LAX', name: 'Los Angeles LAX',      qfu: [60, 240, 70, 250] },
    KORD: { iata: 'ORD', name: 'Chicago ORD',          qfu: [100, 280, 90, 270, 140, 320] },
    KMIA: { iata: 'MIA', name: 'Miami MIA',             qfu: [90, 270, 120, 300] },
    KBOS: { iata: 'BOS', name: 'Boston BOS',           qfu: [40, 220, 150, 330] },
    OMDB: { iata: 'DXB', name: 'Dubaï DXB',            qfu: [120, 300] },
    VHHH: { iata: 'HKG', name: 'Hong Kong HKG',        qfu: [70, 250] },
    RJTT: { iata: 'HND', name: 'Tokyo HND',             qfu: [160, 340, 40, 220] },
    RJAA: { iata: 'NRT', name: 'Tokyo NRT',             qfu: [160, 340] },
    WSSS: { iata: 'SIN', name: 'Singapour SIN',        qfu: [20, 200] },
    YSSY: { iata: 'SYD', name: 'Sydney SYD',            qfu: [70, 250, 160, 340] },
    FAOR: { iata: 'JNB', name: 'Johannesburg JNB',     qfu: [30, 210] },
    FACT: { iata: 'CPT', name: 'Le Cap CPT',            qfu: [10, 190, 70, 250] },
    HECA: { iata: 'CAI', name: 'Le Caire CAI',          qfu: [50, 230] },
    CYYZ: { iata: 'YYZ', name: 'Toronto YYZ',           qfu: [60, 240, 150, 330] },
    CYUL: { iata: 'YUL', name: 'Montréal YUL',          qfu: [60, 240, 100, 280] },
    SBGR: { iata: 'GRU', name: 'São Paulo GRU',         qfu: [100, 280, 90, 270] },
    SCEL: { iata: 'SCL', name: 'Santiago SCL',          qfu: [170, 350] },
    VIDP: { iata: 'DEL', name: 'Delhi DEL',             qfu: [110, 290, 270, 90] },
    ZBAA: { iata: 'PEK', name: 'Pékin PEK',             qfu: [180, 360, 10, 190] },
    ZSPD: { iata: 'PVG', name: 'Shanghai PVG',          qfu: [170, 350] },
  };

  // Seuils crosswind certifiés par type d'avion (kt, rafales incluses)
  // Source : limitations opérationnelles Air France
  const AIRCRAFT_LIMITS = {
    // ── Long-courriers ──────────────────────────────────────────────────
    '77W': { label: '777-300ER', dry: 38, wet: 38 },
    '772': { label: '777-200ER', dry: 38, wet: 38 },
    '789': { label: '787-9',     dry: 38, wet: 38 },
    '332': { label: 'A330-200',  dry: 38, wet: 38 },
    '333': { label: 'A330-300',  dry: 38, wet: 38 },
    '359': { label: 'A350-900',  dry: 38, wet: 38 },
    // ── Moyen-courriers ─────────────────────────────────────────────────
    '320': { label: 'A320',      dry: 38, wet: 33 },
    '321': { label: 'A321',      dry: 38, wet: 33 },
    '319': { label: 'A319',      dry: 38, wet: 33 },
    // ── Court-courriers / régionaux ──────────────────────────────────────
    'E90': { label: 'E190',      dry: 25, wet: 25 },
    '223': { label: 'A220-300',  dry: 29, wet: 29 },
    '220': { label: 'A220-100',  dry: 29, wet: 29 },
  };
  const DEFAULT_LIMIT = { label: 'Inconnu', dry: 25, wet: 25 };
  const CONSERVATIVE_LIMIT_DRY = 29;
  const CONSERVATIVE_LIMIT_WET = 29;

  const WET_WX_TOKENS = /\b(RA|SN|TSRA|FZRA|SHRA|RASN|SNRA|GR|GS|PL)\b/;

  function isWetAtTime(fcsts, targetEpochSec) {
    if (!fcsts || targetEpochSec == null) return false;
    return fcsts.some(f =>
      f.timeFrom != null && f.timeTo != null &&
      targetEpochSec >= f.timeFrom && targetEpochSec < f.timeTo &&
      WET_WX_TOKENS.test(f.wxString ?? '')
    );
  }

  function isFcstWet(fcst) {
    return WET_WX_TOKENS.test(fcst.wxString ?? '');
  }

  function computeCrosswind(windDir, windSpd, qfuList) {
    if (!windSpd || windSpd === 0 || windDir == null) {
      return { crosswind: 0, bestQfu: qfuList[0] ?? null, headwind: 0, vrb: false };
    }
    if (String(windDir).toUpperCase() === 'VRB' || windDir === 'VRB') {
      return { crosswind: Math.round(windSpd), bestQfu: null, headwind: 0, vrb: true };
    }
    const dir = Number(windDir);
    if (isNaN(dir)) {
      return { crosswind: Math.round(windSpd), bestQfu: null, headwind: 0, vrb: true };
    }
    let minCrosswind = Infinity, bestQfu = null, bestHeadwind = 0;
    for (const qfu of qfuList) {
      const diff = Math.abs(dir - qfu);
      const angle = Math.min(diff, 360 - diff);
      const cw = Math.abs(windSpd * Math.sin((angle * Math.PI) / 180));
      if (cw < minCrosswind) {
        minCrosswind = cw;
        bestQfu = qfu;
        bestHeadwind = windSpd * Math.cos((angle * Math.PI) / 180);
      }
    }
    return { crosswind: Math.round(minCrosswind), bestQfu, headwind: Math.round(bestHeadwind), vrb: false };
  }

  function getWindAtTime(fcsts, targetEpochSec) {
    if (!fcsts || fcsts.length === 0) return { base: null, tempos: [] };
    const baseGroups = fcsts.filter(f => {
      const ci = f.changeIndicator ?? '';
      return !ci.includes('TEMPO') && !ci.includes('PROB')
          && f.timeFrom != null && f.timeTo != null
          && targetEpochSec >= f.timeFrom && targetEpochSec < f.timeTo
          && f.wdir != null && f.wspd != null;
    });
    const base = baseGroups.length ? baseGroups.reduce((a,b) => a.timeFrom > b.timeFrom ? a : b) : null;
    const tempos = fcsts.filter(f => {
      const ci = f.changeIndicator ?? '';
      return (ci.includes('TEMPO') || ci.includes('PROB'))
          && f.timeFrom != null && f.timeTo != null
          && targetEpochSec >= f.timeFrom && targetEpochSec < f.timeTo
          && f.wdir != null && f.wspd != null;
    });
    return { base, tempos };
  }

  function getCrosswindStatus(cw, dry, wet) {
    function level(val, limit) {
      const r = val / limit;
      if (r < 0.6) return { bg: 'bg-green-100 dark:bg-green-900/30',   text: 'text-green-700 dark:text-green-400',   label: 'OK' };
      if (r < 0.8) return { bg: 'bg-yellow-100 dark:bg-yellow-900/30', text: 'text-yellow-700 dark:text-yellow-400', label: 'Attention' };
      if (r < 1.0) return { bg: 'bg-orange-100 dark:bg-orange-900/30', text: 'text-orange-700 dark:text-orange-400', label: 'Limite' };
      return         { bg: 'bg-red-100 dark:bg-red-900/30',            text: 'text-red-700 dark:text-red-400',       label: '⚠ Dépassé' };
    }
    return { dryStatus: level(cw, dry), wetStatus: level(cw, wet) };
  }

  function getCrosswindColor(cw, limit) {
    const r = cw / limit;
    if (r < 0.6) return { bg: 'bg-green-100 dark:bg-green-900/30',   text: 'text-green-700 dark:text-green-400',   label: 'OK' };
    if (r < 0.8) return { bg: 'bg-yellow-100 dark:bg-yellow-900/30', text: 'text-yellow-700 dark:text-yellow-400', label: 'Attention' };
    if (r < 1.0) return { bg: 'bg-orange-100 dark:bg-orange-900/30', text: 'text-orange-700 dark:text-orange-400', label: 'Limite' };
    return         { bg: 'bg-red-100 dark:bg-red-900/30',            text: 'text-red-700 dark:text-red-400',       label: '⚠ Dépassé' };
  }

  const ALL_ICAOS = Object.keys(AIRPORT_RUNWAYS);
  let selectedIcaos = new Set([]);

  function renderAirportSelector() {
    document.getElementById('airport-selector').innerHTML = ALL_ICAOS.map(icao => {
      const ap = AIRPORT_RUNWAYS[icao];
      const sel = selectedIcaos.has(icao);
      return `<button data-icao="${icao}" onclick="toggleAirport('${icao}')"
        class="px-2.5 py-1 rounded-lg text-xs font-bold border transition ${
          sel
            ? 'bg-blue-600 text-white border-blue-600'
            : 'bg-gray-50 dark:bg-gray-700 text-gray-600 dark:text-gray-300 border-gray-200 dark:border-gray-600 hover:border-blue-400'
        }">${ap.iata}</button>`;
    }).join('');
  }

  function toggleAirport(icao) {
    if (selectedIcaos.has(icao)) selectedIcaos.delete(icao);
    else selectedIcaos.add(icao);
    renderAirportSelector();
    loadCrosswind(false);
  }

  async function loadCrosswind(force = false) {
    const container = document.getElementById('crosswind-container');

    if (selectedIcaos.size === 0) {
      container.innerHTML = `
        <div class="flex items-center justify-center py-20 text-gray-400">
          <div class="text-center">
            <div class="text-4xl mb-3">✈️</div>
            <p class="text-sm">Sélectionnez une ou plusieurs escales ci-dessus.</p>
          </div>
        </div>`;
      return;
    }

    container.innerHTML = `
      <div class="flex items-center justify-center py-20 text-gray-400">
        <div class="text-center"><div class="text-2xl mb-3 animate-spin">↻</div><p class="text-sm">Récupération TAF + vols…</p></div>
      </div>`;

    const qs = `icaos=${[...selectedIcaos].join(',')}${force ? '&force=1' : ''}`;

    try {
      const res = await fetch(`/api/crosswind.json?${qs}`);
      if (!res.ok) throw new Error(`HTTP ${res.status} — /api/crosswind.json`);
      const data = await res.json();
      if (data.error) throw new Error(data.error);
      renderResults(data.tafs ?? {}, data.flights ?? []);
      const el = document.getElementById('crosswind-updated');
      if (el) el.textContent = 'Mis à jour ' + new Date().toLocaleTimeString('fr-FR', { hour: '2-digit', minute: '2-digit', timeZone: 'UTC' }) + 'z';
    } catch (err) {
      container.innerHTML = `
        <div class="bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 rounded-xl p-5 text-red-700 dark:text-red-400 text-sm">
          ⚠️ Erreur lors du chargement : ${err.message ?? err}
        </div>`;
    }
  }

  function renderResults(tafByIcao, flightsByIcao) {
    const html = [...selectedIcaos]
      .map(icao => renderAirportBlock(icao, tafByIcao[icao] ?? null, flightsByIcao[icao] ?? []))
      .join('');
    document.getElementById('crosswind-container').innerHTML =
      html || '<p class="text-gray-400 text-sm text-center py-10">Aucune donnée disponible.</p>';
  }

  function renderAirportBlock(icao, tafData, flights) {
    const ap = AIRPORT_RUNWAYS[icao];
    if (!ap) return '';
    const fcsts = tafData?.fcsts ?? [];
    const periodsWithWind = fcsts.filter(f => f.wdir != null && f.wspd != null);

    let tafRows = '';
    if (!tafData) {
      tafRows = `<tr><td colspan="6" class="px-4 py-3 text-xs text-gray-400 italic">TAF non disponible pour ${icao}</td></tr>`;
    } else if (periodsWithWind.length === 0) {
      tafRows = `<tr><td colspan="6" class="px-4 py-3 text-xs text-gray-400 italic">Aucun vent dans le TAF</td></tr>`;
    } else {
      for (const f of periodsWithWind) {
        const ci = f.changeIndicator
          ? `<span class="text-[10px] font-semibold px-1 py-0.5 rounded bg-gray-100 dark:bg-gray-700 text-gray-500">${f.changeIndicator}</span>`
          : '<span class="text-[10px] text-gray-400">BASE</span>';
        const isVrb = String(f.wdir ?? '').toUpperCase() === 'VRB';
        const { crosswind: cwBase, bestQfu, vrb } = computeCrosswind(f.wdir, f.wspd, ap.qfu);
        const cwGust = f.wgst ? computeCrosswind(f.wdir, f.wgst, ap.qfu).crosswind : null;
        const worstCw = cwGust ?? cwBase;

        const wet = isFcstWet(f);
        const activeLimit = wet ? CONSERVATIVE_LIMIT_WET : CONSERVATIVE_LIMIT_DRY;
        const status = getCrosswindColor(worstCw, activeLimit);

        const wxBadge = wet
          ? `<span class="ml-1 px-1 py-0.5 rounded text-[9px] font-bold bg-blue-100 dark:bg-blue-900/40 text-blue-700 dark:text-blue-300">WET ${f.wxString ?? ''}</span>`
          : `<span class="ml-1 px-1 py-0.5 rounded text-[9px] font-bold bg-gray-100 dark:bg-gray-700 text-gray-500">DRY</span>`;

        const dirStr = isVrb ? 'VRB' : String(Number(f.wdir)).padStart(3, '0');
        const windStr = `${dirStr}/${String(f.wspd).padStart(2,'0')}${f.wgst ? 'G'+f.wgst : ''}KT`;
        const qfuCell = vrb
          ? '<span class="text-gray-400 italic text-[10px]">VRB</span>'
          : (bestQfu != null ? String(bestQfu).padStart(3,'0') + '°' : '–');
        const cwNote = vrb
          ? ' <span class="text-gray-400 text-[10px]">(pire cas)</span>'
          : (cwGust != null ? ` <span class="text-gray-400 text-[10px]">(G ${cwGust})</span>` : '');
        const cwStr = `${cwBase} kt${cwNote}`;
        tafRows += `
          <tr class="border-b border-gray-100 dark:border-gray-700 hover:bg-gray-50 dark:hover:bg-gray-700/40 transition ${wet ? 'bg-blue-50/30 dark:bg-blue-900/10' : ''}">
            <td class="px-4 py-2 text-xs font-mono text-gray-500 whitespace-nowrap">${formatEpoch(f.timeFrom)}→${formatEpoch(f.timeTo)}</td>
            <td class="px-4 py-2 text-xs">${ci}</td>
            <td class="px-4 py-2 text-xs font-mono font-semibold text-gray-800 dark:text-gray-200">${windStr}${wxBadge}</td>
            <td class="px-4 py-2 text-xs font-mono text-gray-500">${qfuCell}</td>
            <td class="px-4 py-2 text-xs font-bold font-mono ${status.text}">${cwStr}</td>
            <td class="px-4 py-2 text-xs"><span class="px-1.5 py-0.5 rounded text-[10px] font-bold ${status.bg} ${status.text}">${status.label}</span></td>
          </tr>`;
      }
    }

    const sortedFlights = [...flights].sort((a,b) =>
      new Date(a.estimatedTouchDownTime ?? a.scheduledArrival).getTime() -
      new Date(b.estimatedTouchDownTime ?? b.scheduledArrival).getTime()
    );

    let flightRows = '';
    if (sortedFlights.length === 0) {
      flightRows = `<tr><td colspan="5" class="px-3 py-3 text-xs text-gray-400 italic">Aucun vol AF prévu</td></tr>`;
    } else {
      for (const f of sortedFlights) {
        const eta = f.estimatedTouchDownTime || f.scheduledArrival;
        const etaEpochSec = eta ? Math.floor(new Date(eta).getTime() / 1000) : null;
        const etaStr = eta
          ? new Date(eta).toLocaleTimeString('fr-FR', { hour: '2-digit', minute: '2-digit', timeZone: 'UTC' }) + 'z'
          : '–';

        const { base: baseWind, tempos: tempoWinds } = etaEpochSec ? getWindAtTime(fcsts, etaEpochSec) : { base: null, tempos: [] };
        const acInfo = AIRCRAFT_LIMITS[f.aircraftType ?? ''] ?? DEFAULT_LIMIT;

        let windCell = `<td class="px-3 py-2 text-xs text-gray-400 font-mono">–</td>`;
        let riskCell = `<td class="px-3 py-2 text-xs text-gray-400">–</td>`;

        if (baseWind) {
          const spd = baseWind.wgst ?? baseWind.wspd;
          const { crosswind, bestQfu, vrb } = computeCrosswind(baseWind.wdir, spd, ap.qfu);

          const wet = isWetAtTime(fcsts, etaEpochSec);
          const activeLimit = wet ? acInfo.wet : acInfo.dry;
          const status = getCrosswindColor(crosswind, activeLimit);

          const isVrbBase = String(baseWind.wdir ?? '').toUpperCase() === 'VRB';
          const dirStr = isVrbBase ? 'VRB' : String(Number(baseWind.wdir)).padStart(3,'0');
          const windStr = `${dirStr}/${String(baseWind.wspd).padStart(2,'0')}${baseWind.wgst ? 'G'+baseWind.wgst : ''}KT`;
          const qfuStr = vrb ? '<span class="text-gray-400 italic">VRB</span>' : `QFU ${String(bestQfu).padStart(3,'0')}`;

          const condBadge = wet
            ? `<span class="px-1 py-0.5 rounded text-[9px] font-bold bg-blue-100 dark:bg-blue-900/40 text-blue-700 dark:text-blue-300">WET</span>`
            : `<span class="px-1 py-0.5 rounded text-[9px] font-bold bg-gray-100 dark:bg-gray-700 text-gray-500">DRY</span>`;

          let tempoStr = '';
          if (tempoWinds.length > 0) {
            let worstCw = 0, worstTempo = null;
            for (const t of tempoWinds) {
              const { crosswind: cwt } = computeCrosswind(t.wdir, t.wgst ?? t.wspd, ap.qfu);
              if (cwt > worstCw) { worstCw = cwt; worstTempo = t; }
            }
            if (worstTempo) {
              const tempoWet = wet || WET_WX_TOKENS.test(worstTempo.wxString ?? '');
              const tempoLimit = tempoWet ? acInfo.wet : acInfo.dry;
              const { text: tt, label: tl } = getCrosswindColor(worstCw, tempoLimit);
              tempoStr = `<div class="text-[10px] ${tt} mt-0.5">${worstTempo.changeIndicator ?? 'TEMPO'} : ${worstCw} kt (${tl})</div>`;
            }
          }

          windCell = `<td class="px-3 py-2 text-xs font-mono text-gray-600 dark:text-gray-400 whitespace-nowrap">${windStr} <span class="text-gray-400">${qfuStr}</span></td>`;
          riskCell = `<td class="px-3 py-2 text-xs">
            <div class="flex flex-wrap items-center gap-1">
              <span class="font-bold font-mono ${status.text}">${crosswind} kt</span>
              ${condBadge}
              <span class="px-1.5 py-0.5 rounded text-[10px] font-bold ${status.bg} ${status.text}">${status.label}</span>
            </div>
            <div class="text-[10px] text-gray-400 mt-0.5">${acInfo.label} · max ${activeLimit} kt${wet && acInfo.dry !== acInfo.wet ? ` (DRY ${acInfo.dry})` : ''}</div>
            ${tempoStr}
          </td>`;
        }

        flightRows += `
          <tr class="border-b border-gray-100 dark:border-gray-700 hover:bg-gray-50 dark:hover:bg-gray-700/40 transition">
            <td class="px-3 py-2 text-xs font-bold font-mono text-gray-800 dark:text-gray-200">${f.flightId ?? '–'}</td>
            <td class="px-3 py-2 text-xs font-mono text-blue-600 dark:text-blue-400 font-semibold">${etaStr}</td>
            <td class="px-3 py-2 text-xs font-mono text-gray-500">${f.aircraftType ?? '–'}</td>
            ${windCell}${riskCell}
          </tr>`;
      }
    }

    const qfuDisplay = [...new Set(ap.qfu)].sort((a,b)=>a-b).map(q=>String(q).padStart(3,'0')).join(' / ');

    return `
      <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-700 shadow-sm mb-5 overflow-hidden">
        <div class="flex items-center gap-3 px-5 py-3 border-b border-gray-100 dark:border-gray-700 bg-gray-50 dark:bg-gray-800">
          <span class="text-lg font-black font-mono text-gray-800 dark:text-gray-100">${ap.iata}</span>
          <span class="text-sm text-gray-500">${ap.name}</span>
          <span class="ml-auto text-[10px] text-gray-400 font-mono">QFU : ${qfuDisplay}</span>
        </div>
        <div class="grid grid-cols-1 xl:grid-cols-2 divide-y xl:divide-y-0 xl:divide-x divide-gray-100 dark:divide-gray-700">
          <div>
            <div class="px-5 py-2 border-b border-gray-100 dark:border-gray-700">
              <span class="text-xs font-semibold text-gray-500 uppercase tracking-wide">📋 TAF — Travers par période</span>
            </div>
            <div class="overflow-x-auto">
              <table class="w-full text-sm text-left">
                <thead class="text-[10px] uppercase text-gray-400 border-b border-gray-100 dark:border-gray-700">
                  <tr>
                    <th class="px-4 py-2">Période (UTC)</th><th class="px-4 py-2">Type</th>
                    <th class="px-4 py-2">Vent TAF</th><th class="px-4 py-2">Meilleur QFU</th>
                    <th class="px-4 py-2">Composante travers</th><th class="px-4 py-2">DRY / WET</th>
                  </tr>
                </thead>
                <tbody>${tafRows}</tbody>
              </table>
            </div>
          </div>
          <div>
            <div class="px-5 py-2 border-b border-gray-100 dark:border-gray-700">
              <span class="text-xs font-semibold text-gray-500 uppercase tracking-wide">✈️ Vols AF — Travers à l'ETA</span>
            </div>
            <div class="overflow-x-auto">
              <table class="w-full text-sm text-left">
                <thead class="text-[10px] uppercase text-gray-400 border-b border-gray-100 dark:border-gray-700">
                  <tr>
                    <th class="px-3 py-2">Vol</th><th class="px-3 py-2">ETA</th>
                    <th class="px-3 py-2">Avion</th><th class="px-3 py-2">Vent prévu</th>
                    <th class="px-3 py-2">Travers / Risque</th>
                  </tr>
                </thead>
                <tbody>${flightRows}</tbody>
              </table>
            </div>
          </div>
        </div>
        <!-- TAF brut dépliable -->
        <div class="border-t border-gray-100 dark:border-gray-700">
          <button
            class="w-full flex items-center justify-between px-5 py-2.5 text-xs text-gray-500 hover:bg-gray-50 dark:hover:bg-gray-700/40 transition font-medium"
            onclick="(function(btn){
              const block = btn.nextElementSibling;
              const isHidden = block.classList.contains('hidden');
              block.classList.toggle('hidden');
              btn.querySelector('.taf-toggle-icon').textContent = isHidden ? '▼' : '▶';
            })(this)"
          >
            <span>📄 TAF brut — ${icao}</span>
            <span class="taf-toggle-icon text-gray-400">▶</span>
          </button>
          <div class="hidden px-5 pb-4">
            <pre class="font-mono text-[11px] text-gray-600 dark:text-gray-400 bg-gray-50 dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-lg p-3 whitespace-pre-wrap break-words leading-relaxed">${
              tafData?.rawTaf
                ? tafData.rawTaf.trim()
                    .replace(/(TEMPO|BECMG|PROB\d{2})/g, '\n$1')
                    .trim()
                : 'TAF non disponible'
            }</pre>
          </div>
        </div>
      </div>`;
  }

  function formatEpoch(epochSec) {
    if (!epochSec) return '–';
    return new Date(epochSec * 1000).toLocaleTimeString('fr-FR', { hour: '2-digit', minute: '2-digit', timeZone: 'UTC' }) + 'z';
  }

  document.addEventListener('DOMContentLoaded', () => {
    renderAirportSelector();
    loadCrosswind(false);
  });
  </script>

</body>
</html>
