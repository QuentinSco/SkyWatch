---
import '../styles/global.css';
---
<!doctype html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>SkyWatch – Alertes météo dispatch</title>
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
  <style>
    /* ── Layout widescreen ─────────────────────────────────────────── */
    .main-grid {
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
    }

    /* À partir de 1280px : carte + alertes côte à côte */
    @media (min-width: 1280px) {
      .main-grid {
        display: grid;
        grid-template-columns: minmax(0, 1.1fr) minmax(0, 0.9fr);
        grid-template-rows: auto;
        align-items: start;
        gap: 1.5rem;
      }
      /* La carte occupe la colonne gauche et reste sticky */
      .col-map {
        position: sticky;
        top: 1.5rem;
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
      }
      /* Hauteur de carte bornée — ni trop petite ni trop haute */
      #alert-map {
        height: clamp(420px, 55vh, 620px) !important;
        min-height: 420px;
      }
      /* La colonne droite scroll indépendamment */
      .col-alerts {
        overflow-y: auto;
        max-height: calc(100vh - 3rem);
        padding-right: 0.25rem;
      }
    }

    /* Scrollbar discrète sur la colonne droite */
    .col-alerts::-webkit-scrollbar { width: 4px; }
    .col-alerts::-webkit-scrollbar-track { background: transparent; }
    .col-alerts::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 2px; }

    /* Slot état base — masqué par défaut, visible seulement sur grand écran */
    #base-status-slot {
      display: none;
    }
    @media (min-width: 1280px) {
      #base-status-slot {
        display: block;
      }
    }
  </style>
</head>

<body class="text-gray-900 min-h-screen flex" style="background:#f8fafc">

  <!-- ─── Sidebar ─────────────────────────────────────────────── -->
  <aside class="hidden lg:flex flex-col w-56 shrink-0 sticky top-0 h-screen border-r border-gray-200 bg-white px-4 py-6 overflow-y-auto">

    <!-- Logo -->
    <div class="mb-6">
      <div class="text-2xl font-bold tracking-tight text-gray-900">🛡 SkyWatch</div>
      <div class="text-gray-400 text-xs mt-1">Superviseur dispatch</div>
    </div>

    <!-- Statut mise à jour -->
    <div class="text-xs text-gray-400 mb-1" id="last-update">Chargement…</div>
    <div id="counters" class="flex flex-wrap gap-1 mb-6"></div>

    <!-- Navigation -->
    <nav class="flex flex-col gap-1 text-sm" id="sidebar-nav">
      <div class="text-[10px] uppercase font-semibold text-gray-400 tracking-widest mb-2">Sections</div>

      <a href="#section-carte"
         class="sidebar-link flex items-center gap-2 px-3 py-2 rounded-lg text-gray-600 hover:bg-blue-50 hover:text-blue-700 transition font-medium">
        🗺️ Carte
      </a>

      <a href="#section-alertes"
         class="sidebar-link flex items-center gap-2 px-3 py-2 rounded-lg text-gray-600 hover:bg-blue-50 hover:text-blue-700 transition font-medium">
        🌐 Alertes actives
        <span id="nav-alert-count" class="ml-auto"></span>
      </a>

      <a href="#section-vols"
         class="sidebar-link flex items-center gap-2 px-3 py-2 rounded-lg text-gray-600 hover:bg-blue-50 hover:text-blue-700 transition font-medium">
        ✈️ Vols impactés
        <span id="nav-vol-count" class="ml-auto"></span>
      </a>

      <a href="#section-taf"
         class="sidebar-link flex items-center gap-2 px-3 py-2 rounded-lg text-gray-600 hover:bg-blue-50 hover:text-blue-700 transition font-medium">
        🌩 TAF Risques AF
        <span id="nav-taf-count" class="ml-auto"></span>
      </a>
    </nav>

    <!-- Bandeau horizon -->
    <div class="mt-auto pt-6 border-t border-gray-100 text-[10px] text-gray-400 leading-relaxed">
      <strong class="text-gray-500">Horizon :</strong> J à J+3<br>
      Phénomènes grande échelle uniquement.<br>
      J reste sous resp. dispatcher individuelle.
    </div>
  </aside>

  <!-- ─── Contenu principal ───────────────────────────────────── -->
  <div class="flex-1 min-w-0 overflow-y-auto">
    <div class="px-4 py-6 xl:px-6">

      <!-- Header mobile (masqué sur lg) -->
      <header class="lg:hidden mb-6">
        <div class="flex items-center justify-between flex-wrap gap-4">
          <div>
            <h1 class="text-2xl font-bold tracking-tight text-gray-900">🛡 SkyWatch</h1>
            <p class="text-gray-500 text-xs mt-1">Agrégateur d&rsquo;alertes météo — Outil superviseur dispatch</p>
          </div>
          <div class="text-right text-xs text-gray-500">
            <div id="last-update-mobile">Chargement...</div>
          </div>
        </div>
        <div class="mt-3 bg-blue-50 border border-blue-200 rounded-xl p-3 text-xs text-blue-700">
          ℹ️ <strong>Horizon :</strong> J à J+3 — Phénomènes grande échelle uniquement.
        </div>
      </header>

      <!-- ─── Grid principal : carte | alertes+vols+taf ─────────── -->
      <div class="main-grid">

        <!-- Colonne gauche : Carte (sticky sur grand écran) -->
        <div class="col-map">

          <!-- Carte -->
          <section id="section-carte" class="scroll-mt-6">
            <div class="rounded-xl overflow-hidden border border-gray-200 shadow-sm">
              <div class="bg-gray-50 border-b border-gray-200 px-4 py-2 text-xs font-semibold text-gray-500 uppercase tracking-wide">
                🗺️ Carte des alertes actives
              </div>
              <div id="alert-map" style="height: 420px; width: 100%;"></div>
            </div>
          </section>

          <!-- Slot État base CDG / ORY (widescreen uniquement) -->
          <div id="base-status-slot" class="rounded-xl overflow-hidden border border-gray-200 shadow-sm bg-white">
            <div class="bg-gray-50 border-b border-gray-200 px-4 py-2 text-xs font-semibold text-gray-500 uppercase tracking-wide">
              🛫 État base CDG / ORY
            </div>
            <div id="base-status-body" class="text-sm text-gray-400 italic px-4 py-3">
              Chargement…
            </div>
          </div>

        </div>
        <!-- /col-map -->

        <!-- Colonne droite : Alertes + Vols + TAF -->
        <div class="col-alerts">

          <!-- Alertes actives -->
          <section id="section-alertes" class="mb-8 scroll-mt-6">
            <main id="main-content">
              <div class="text-gray-400 text-sm italic">Chargement des alertes...</div>
            </main>
          </section>

          <!-- Vols AF impactés -->
          <section id="section-vols" class="mb-8 scroll-mt-6">
            <div class="flex items-center justify-between mb-3 flex-wrap gap-3">
              <div>
                <h2 class="text-xl font-bold text-gray-900">✈️ Vols AF LC impactés</h2>
                <p class="text-gray-500 text-sm mt-0.5">
                  Croisement TAF / vols AF arrivées — ETA dans une fenêtre de menace active ou dans les 2h précédant celle-ci.
                </p>
              </div>
              <div id="taf-vol-counters" class="flex gap-2 text-xs"></div>
            </div>
            <div id="taf-vol-main">
              <div class="text-gray-400 text-sm italic">Chargement des vols…</div>
            </div>
          </section>

          <!-- TAF Risques AF -->
          <section id="section-taf" class="mb-8 scroll-mt-6">
            <div class="flex items-center justify-between mb-4 flex-wrap gap-3">
              <div>
                <h2 class="text-xl font-bold text-gray-900">🌩 TAF Risques AF</h2>
                <p class="text-gray-500 text-sm mt-0.5">Phénomènes significatifs sur le réseau AF — Source AviationWeather.gov</p>
              </div>
              <div id="taf-counters" class="flex gap-2"></div>
            </div>
            <div id="taf-main">
              <div class="text-gray-400 text-sm italic">Chargement des TAFs...</div>
            </div>
          </section>

          <!-- Footer -->
          <footer class="pt-6 border-t border-gray-200 text-xs text-gray-400 flex flex-wrap gap-4 justify-between">
            <span>Sources : GDACS (UN/CE) · NOAA/NWS · MeteoAlarm (EUMETNET) · AviationWeather.gov (TAF) · NHC (NOAA) · RSMC La Réunion (Météo-France) · JTWC</span>
            <span>SkyWatch POC v0.1 — Open source uniquement</span>
          </footer>

        </div>
        <!-- /col-alerts -->
      </div>
      <!-- /main-grid -->

    </div>
  </div>

  <script is:inline src="/lib/main.js"></script>
  <script is:inline src="/lib/taf-ui.js"></script>

  <!-- Déplace le bloc État base CDG/ORY dans le slot gauche sur grand écran -->
  <script is:inline>
    (function () {
      if (!window.matchMedia('(min-width: 1280px)').matches) return;

      const slot = document.getElementById('base-status-body');
      if (!slot) return;

      function findBaseSection() {
        // taf-ui.js rend un <section> ou <div> contenant un <h2>/<h3> "État base CDG / ORY"
        const headings = Array.from(document.querySelectorAll('h2, h3'));
        const h = headings.find(el =>
          /[Ée]tat\s+base/i.test(el.textContent || '') &&
          /(CDG|ORY)/i.test(el.textContent || '')
        );
        if (!h) return null;
        return h.closest('section') || h.closest('[class]') || h.parentElement;
      }

      function tryMove() {
        const block = findBaseSection();
        if (!block) return false;
        slot.innerHTML = '';
        slot.classList.remove('text-gray-400', 'italic');
        slot.appendChild(block);
        return true;
      }

      if (tryMove()) return;

      const obs = new MutationObserver(() => {
        if (tryMove()) obs.disconnect();
      });
      obs.observe(document.body, { childList: true, subtree: true });
    })();
  </script>

  <!-- Sidebar : highlight section active au scroll -->
  <script is:inline>
    (function () {
      const sections = ['section-carte', 'section-alertes', 'section-vols', 'section-taf'];
      const links = document.querySelectorAll('.sidebar-link');

      function setActive(id) {
        links.forEach(l => {
          const href = l.getAttribute('href');
          if (href === '#' + id) {
            l.classList.add('bg-blue-50', 'text-blue-700');
            l.classList.remove('text-gray-600');
          } else {
            l.classList.remove('bg-blue-50', 'text-blue-700');
            l.classList.add('text-gray-600');
          }
        });
      }

      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach(e => { if (e.isIntersecting) setActive(e.target.id); });
        },
        { threshold: 0.2 }
      );

      document.addEventListener('DOMContentLoaded', () => {
        sections.forEach(id => {
          const el = document.getElementById(id);
          if (el) observer.observe(el);
        });
        setActive('section-carte');
      });
    })();
  </script>

  <!-- Sync compteurs sidebar depuis les spans déjà peuplés -->
  <script is:inline>
    (function () {
      function syncNavCount(sourceId, navId, bgClass, textClass) {
        const src = document.getElementById(sourceId);
        const nav = document.getElementById(navId);
        if (!src || !nav) return;
        const observer = new MutationObserver(() => {
          const spans = src.querySelectorAll('span');
          let count = 0;
          spans.forEach(s => { const n = parseInt(s.textContent.replace(/\D/g,'')); if (!isNaN(n)) count += n; });
          nav.innerHTML = count > 0
            ? `<span class="${bgClass} ${textClass} text-[10px] font-bold px-1.5 py-0.5 rounded-full">${count}</span>`
            : '';
        });
        observer.observe(src, { childList: true, subtree: true });
      }

      document.addEventListener('DOMContentLoaded', () => {
        syncNavCount('counters',         'nav-alert-count', 'bg-red-100',    'text-red-700');
        syncNavCount('taf-vol-counters', 'nav-vol-count',   'bg-orange-100', 'text-orange-700');
        syncNavCount('taf-counters',     'nav-taf-count',   'bg-orange-100', 'text-orange-700');
      });
    })();
  </script>

</body>
</html>
