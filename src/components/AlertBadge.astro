---
export interface Props {
  severity: 'red' | 'orange' | 'yellow';
  isSpatial?: boolean;
  isBackup?: boolean;
}
const { severity, isSpatial = false, isBackup = false } = Astro.props;

const styles = {
  red:    'bg-red-600 text-white',
  orange: 'bg-orange-500 text-white',
  yellow: 'bg-yellow-400 text-black',
};
const labels = { red: '🔴 ROUGE', orange: '🟠 ORANGE', yellow: '🟡 JAUNE' };

// SVG inline rocket (simple, propre, monochrome)
const rocketSvg = `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="inline w-3 h-3 mr-0.5 -mt-0.5" aria-hidden="true"><path d="M13.75 2c-1.79 0-3.5.7-4.77 1.95L4 8.93V11l2.5 2.5L9 11l1-1 4-4 3.1-.1c.8-.03 1.57.28 2.13.84l.03.03c.56.56.87 1.33.84 2.13L20 12l-4 4-1 1-2.5 2.5H15l4.98-4.98A6.74 6.74 0 0 0 22 10.25C22 5.7 18.3 2 13.75 2ZM9 15.5 4.5 20l-.01-.01A1.49 1.49 0 0 1 4 19H3a1 1 0 0 1-1-1v-1a1.49 1.49 0 0 1 .44-1.06L7 11.5 9 13.5l.5.5L9 15.5Zm5-6a1.5 1.5 0 1 1 3 0 1.5 1.5 0 0 1-3 0Z"/></svg>`;
---
{isSpatial ? (
  <span class={`inline-flex items-center px-2 py-0.5 rounded text-xs font-bold uppercase ${
    isBackup ? 'bg-violet-400 text-white' : 'bg-violet-600 text-white'
  }`}>
    <Fragment set:html={rocketSvg} />
    {isBackup ? 'BACKUP' : 'SPATIAL'}
  </span>
) : (
  <span class={`inline-flex items-center px-2 py-0.5 rounded text-xs font-bold uppercase ${styles[severity]}`}>
    {labels[severity]}
  </span>
)}
