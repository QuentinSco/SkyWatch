  const WET_WX_TOKENS = /\b(RA|TSRA|SHRA|DZ|DZRA)\b/;
  const CONTAMINATED_WX_TOKENS = /\b(SN|FZRA|RASN|SNRA|GR|GS|PL)\b/;

  function getRunwayCode(fcsts, targetEpochSec) {
    if (!fcsts || targetEpochSec == null) return 6;
    const matching = fcsts.filter(f =>
      f.timeFrom != null && f.timeTo != null &&
      targetEpochSec >= f.timeFrom && targetEpochSec < f.timeTo
    );
    for (const f of matching) {
      const wx = f.wxString ?? '';
      if (CONTAMINATED_WX_TOKENS.test(wx)) return 4;
      if (WET_WX_TOKENS.test(wx)) return 5;
    }
    return 6;
  }

  function getRunwayCodeForFcst(fcst) {
    const wx = fcst.wxString ?? '';
    if (CONTAMINATED_WX_TOKENS.test(wx)) return 4;
    if (WET_WX_TOKENS.test(wx)) return 5;
    return 6;
  }

  function normalizeQfu(raw) {
    const trimmed = String(raw ?? '').trim();
    if (!trimmed) return null;
    const n = parseInt(trimmed, 10);
    if (isNaN(n) || n < 0 || n > 36) return null;
    return n;
  }

  // decl = déclinaison magnétique de l'aéroport (est +, ouest −)
  // Le TAF donne le vent en nord vrai ; le QFU est en nord magnétique.
  // Conversion : vent_magnétique = vent_vrai − déclinaison
  function computeCrosswind(windDir, windSpd, qfu, decl = 0) {
    if (!windSpd || windSpd === 0 || windDir == null || qfu == null) {
      return { crosswind: 0, headwind: 0, vrb: false };
    }
    if (String(windDir).toUpperCase() === 'VRB' || windDir === 'VRB') {
      return { crosswind: Math.round(windSpd), headwind: 0, vrb: true };
    }
    const dir = Number(windDir);
    if (isNaN(dir)) {
      return { crosswind: Math.round(windSpd), headwind: 0, vrb: true };
    }
    // Conversion nord vrai → nord magnétique
    const dirMag = ((dir - decl) % 360 + 360) % 360;
    const diff = Math.abs(dirMag - qfu * 10);
    const angle = Math.min(diff, 360 - diff);
    const cw = Math.abs(windSpd * Math.sin((angle * Math.PI) / 180));
    const hw = windSpd * Math.cos((angle * Math.PI) / 180);
    return { crosswind: Math.round(cw), headwind: Math.round(hw), vrb: false };
  }

  function getWindAtTime(fcsts, targetEpochSec) {
    if (!fcsts || fcsts.length === 0) return { base: null, tempos: [] };
    const baseGroups = fcsts.filter(f => {
      const ci = f.changeIndicator ?? '';
      return !ci.includes('TEMPO') && !ci.includes('PROB')
          && f.timeFrom != null && f.timeTo != null
          && targetEpochSec >= f.timeFrom && targetEpochSec < f.timeTo
          && f.wdir != null && f.wspd != null;
    });
    const base = baseGroups.length ? baseGroups.reduce((a,b) => a.timeFrom > b.timeFrom ? a : b) : null;
    const tempos = fcsts.filter(f => {
      const ci = f.changeIndicator ?? '';
      return (ci.includes('TEMPO') || ci.includes('PROB'))
          && f.timeFrom != null && f.timeTo != null
          && targetEpochSec >= f.timeFrom && targetEpochSec < f.timeTo
          && f.wdir != null && f.wspd != null;
    });
    return { base, tempos };
  }

  function getCrosswindColor(cw, limit) {
    const r = cw / limit;
    if (r < 0.6) return { bg: 'bg-green-100 dark:bg-green-900/30',   text: 'text-green-700 dark:text-green-400',   label: 'OK' };
    if (r < 0.8) return { bg: 'bg-yellow-100 dark:bg-yellow-900/30', text: 'text-yellow-700 dark:text-yellow-400', label: 'Attention' };
    if (r < 1.0) return { bg: 'bg-orange-100 dark:bg-orange-900/30', text: 'text-orange-700 dark:text-orange-400', label: 'Limite' };
    return         { bg: 'bg-red-100 dark:bg-red-900/30',            text: 'text-red-700 dark:text-red-400',       label: '⚠ Dépassé' };
  }

  const MONTHS_FR = ['JAN','FEB','MAR','APR','MAY','JUN','JUL','AUG','SEP','OCT','NOV','DEC'];
function formatFlightId(flightId) {
  if (!flightId) return '–';
  // Format API normal : AF1280-2026-03-12...
  const m = flightId.match(/^([A-Z]{2}\d+)-(\d{4})-(\d{2})-(\d{2})/);
  if (m) {
    const flightNum = m[1];
    const month = parseInt(m[3], 10);
    const day = m[4];
    return `${flightNum}/${day}${MONTHS_FR[month - 1] ?? m[3]}`;
  }
  // Format backup CSV : AF1280-CSV-A-EGLL-2026-03-12...
  const mb = flightId.match(/^([A-Z]{2}\d+)-CSV-[AD]-[A-Z]{4}-(\d{4})-(\d{2})-(\d{2})/);
  if (mb) {
    const flightNum = mb[1];
    const month = parseInt(mb[3], 10);
    const day = mb[4];
    return `${flightNum}/${day}${MONTHS_FR[month - 1] ?? mb[3]}`;
  }
  return flightId;
}


