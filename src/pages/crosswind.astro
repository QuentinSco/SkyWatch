---
import '../styles/global.css';
---
<!doctype html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>SkyWatch – Composante Vent de Travers</title>
  <script is:inline src="/lib/dark-mode.js"></script>
  <style>
    @media print {
      @page { 
        size: A4 portrait; 
        margin: 12mm 8mm;
      }

      * { 
        -webkit-print-color-adjust: exact !important; 
        print-color-adjust: exact !important;
      }

      html, body { 
 background: white !important;
    background-color: white !important;
    color: black !important;
    color-scheme: light !important;   /* ← ajouter cette ligne */
        font-size: 10pt; 
        line-height: 1.2; 
      }

      aside, 
      #btn-refresh, 
      #btn-print,
      #config-panel,
      .no-print { 
        display: none !important; 
      }

      body > .flex { 
        display: block !important; 
      }
      .flex-1.min-w-0 { 
        width: 100% !important; 
        max-width: 100% !important; 
        overflow: visible !important; 
      }
      .max-w-7xl { 
        max-width: 100% !important; 
        padding: 0 !important; 
        margin: 0 !important; 
      }

      #page-header {
        display: flex !important;
        align-items: baseline !important;
        gap: 4mm !important;
        margin-bottom: 3mm !important;
        border-bottom: 1.5px solid black !important;
        padding-bottom: 1.5mm;
      }
      h1 { 
        font-size: 14pt !important; 
        font-weight: bold; 
        color: black !important; 
        margin: 0 !important;
        border: none !important;
        padding: 0 !important;
        background: white !important;
      }
      h1[data-print-date]::after { 
        content: " — Impression du " attr(data-print-date); 
        font-size: 10pt; 
        font-weight: normal; 
        color: #555 !important;
      }
      h1 + p { display: none !important; }
      #crosswind-updated { 
        display: inline !important; 
        color: #555 !important; 
        font-size: 9pt !important; 
      }

      #threshold-legend { 
        display: flex !important;
        flex-wrap: wrap;
        gap: 4mm;
        border: 1px solid #ccc !important; 
        background: #f8f8f8 !important; 
        padding: 2mm !important; 
        margin-bottom: 3mm !important;
      }
      #threshold-legend span { 
        color: black !important; 
        font-size: 8pt !important; 
      }

      /*
       * Même logique que chainages : on abandonne break-inside:avoid CSS seul
       * (non fiable sur Chromium pour les blocs de taille variable).
       * La pagination JS dans preparePrint() injecte break-before:page
       * sur les blocs qui déborderaient de la page courante.
       */
      #crosswind-container { 
        display: block !important;
      }
      #crosswind-container > div { 
        margin-bottom: 4mm;
        border: 1px solid #333 !important;
        background: white !important;
        box-shadow: none !important;
        display: block !important;
        break-inside: avoid !important;
        page-break-inside: avoid !important;
      }

      #crosswind-container > div > div:first-child { 
        background: #eeeeee !important; 
        border-bottom: 1px solid #333 !important; 
        padding: 1.5mm 3mm !important;
        break-after: avoid !important;
        page-break-after: avoid !important;
      }
      #crosswind-container > div > div:first-child span { 
        color: black !important; 
        background: transparent !important;
      }
      #crosswind-container > div > div:first-child span:first-child { 
        background: #222 !important; 
        color: white !important; 
        font-weight: bold;
        padding: 1mm 2mm !important;
        border-radius: 2px;
      }

      .grid.grid-cols-1.xl\\:grid-cols-2 { 
        display: block !important;
      }
      .grid.grid-cols-1.xl\\:grid-cols-2 > div { 
        background: white !important;
        border-top: 1px solid #ddd !important;
      }

      .grid.grid-cols-1.xl\\:grid-cols-2 > div > div:first-child {
        background: #f5f5f5 !important;
        border-bottom: 1px solid #bbb !important;
        padding: 1mm 2mm !important;
        break-after: avoid !important;
        page-break-after: avoid !important;
      }
      .grid.grid-cols-1.xl\\:grid-cols-2 > div > div:first-child span {
        font-size: 8pt !important;
        font-weight: bold;
        color: #222 !important;
        background: transparent !important;
      }

      .grid.grid-cols-1.xl\\:grid-cols-2 > div .overflow-x-auto {
        break-before: avoid !important;
        page-break-before: avoid !important;
      }

      table { 
        font-size: 8pt !important;
        width: 100% !important;
        border-collapse: collapse !important;
        background: white !important;
      }

      thead { 
        background: #eeeeee !important;
        display: table-header-group !important;
      }
      thead th { 
        color: black !important; 
        background: #eeeeee !important;
        border-bottom: 1px solid #888 !important;
        padding: 1mm 1.5mm !important;
        font-weight: bold;
        text-align: left;
      }

      tbody tr { 
        border-bottom: 0.5px solid #ddd !important;
        break-inside: avoid !important;
        page-break-inside: avoid !important;
        background: white !important;
      }
      tbody td { 
        color: black !important;
        background: white !important;
        padding: 0.8mm 1.5mm !important;
        vertical-align: top;
      }

      .bg-green-100, .dark\\:bg-green-900\\/30 { 
        background: white !important; 
        border: 1px solid #555 !important;
        color: black !important;
      }
      .bg-yellow-100, .dark\\:bg-yellow-900\\/30 { 
        background: #e0e0e0 !important; 
        border: 1.5px dashed #333 !important;
        color: black !important;
      }
      .bg-orange-100, .dark\\:bg-orange-900\\/30 { 
        background: #aaaaaa !important; 
        border: 2px solid #000 !important;
        color: black !important;
        font-weight: bold !important;
      }
      .bg-red-100, .dark\\:bg-red-900\\/30 { 
        background: #111 !important; 
        border: 2px solid #000 !important;
        color: white !important;
        font-weight: bold !important;
      }

      .text-green-700, .dark\\:text-green-400,
      .text-yellow-700, .dark\\:text-yellow-400,
      .text-orange-700, .dark\\:text-orange-400 { 
        color: black !important; 
      }
      .text-red-700, .dark\\:text-red-400 {
        color: white !important;
      }

      .bg-blue-100, .dark\\:bg-blue-900\\/40 { 
        background: #d8d8d8 !important;
        color: #111 !important;
        border: 1px solid #777 !important;
      }
      .bg-purple-100, .dark\\:bg-purple-900\\/40 { 
        background: #c0c0c0 !important;
        color: #111 !important;
        border: 1px solid #555 !important;
      }
      .bg-gray-100, .dark\\:bg-gray-700 { 
        background: #eeeeee !important;
        color: black !important;
      }
      .text-blue-700, .dark\\:text-blue-300,
      .text-purple-700, .dark\\:text-purple-300,
      .text-gray-500, .text-gray-600 { 
        color: #333 !important; 
      }

      thead th:nth-child(1) { width: 16%; }
      thead th:nth-child(2) { width: 10%; }
      thead th:nth-child(3) { width: 22%; }
      thead th:nth-child(4) { width: 8%; }
      thead th:nth-child(5) { width: 26%; }
      thead th:nth-child(6) { width: 18%; }

      .taf-raw-section { 
        display: none !important;
        visibility: hidden !important;
        height: 0 !important;
        overflow: hidden !important;
        margin: 0 !important;
        padding: 0 !important;
      }

      .print-info { 
        display: block !important; 
        font-size: 8pt; 
        color: #555 !important;
        text-align: center; 
        margin-top: 4mm; 
        border-top: 0.5px solid #ccc !important;
        padding-top: 2mm;
        background: white !important;
      }
    }
    
    @media screen { 
      .print-info { 
        display: none; 
      } 
    }
  </style>
</head>

<body class="text-gray-900 dark:text-gray-100 min-h-screen flex bg-slate-50 dark:bg-gray-950">

  <!-- ─ Sidebar ─────────────────────────────────────────────────────────────── -->
  <aside class="hidden lg:flex flex-col w-56 shrink-0 sticky top-0 h-screen
                border-r border-gray-200 dark:border-gray-800
                bg-white dark:bg-gray-900
                px-4 py-6 overflow-y-auto">
    <div class="mb-6">
      <div class="text-2xl font-bold tracking-tight text-gray-900 dark:text-white">🛡 SkyWatch</div>
      <div class="text-gray-400 dark:text-gray-500 text-xs mt-1">Superviseur dispatch</div>
    </div>
    <nav class="flex flex-col gap-1 text-sm">
      <div class="text-[10px] uppercase font-semibold text-gray-400 dark:text-gray-600 tracking-widest mb-2">Navigation</div>
      <a href="/" class="flex items-center gap-2 px-3 py-2 rounded-lg
                         text-gray-600 dark:text-gray-400
                         hover:bg-blue-50 dark:hover:bg-blue-950 hover:text-blue-700 dark:hover:text-blue-400
                         transition font-medium">🗺️ Tableau de bord</a>
      <div class="mt-4 pt-4 border-t border-gray-100 dark:border-gray-800">
        <div class="text-[10px] uppercase font-semibold text-gray-400 dark:text-gray-600 tracking-widest mb-2">Outils</div>
        <a href="/briefing" class="flex items-center gap-2 px-3 py-2 rounded-lg
                                   text-gray-600 dark:text-gray-400
                                   hover:bg-purple-50 dark:hover:bg-purple-950 hover:text-purple-700 dark:hover:text-purple-400
                                   transition font-medium">🗒 Trame briefing</a>
        <a href="/chainages" class="flex items-center gap-2 px-3 py-2 rounded-lg
                                    text-gray-600 dark:text-gray-400
                                    hover:bg-indigo-50 dark:hover:bg-indigo-950 hover:text-indigo-700 dark:hover:text-indigo-400
                                    transition font-medium">🔗 Chaînages</a>
        <a href="/crosswind" class="flex items-center gap-2 px-3 py-2 rounded-lg
                                    bg-blue-50 dark:bg-blue-950
                                    text-blue-700 dark:text-blue-300 font-semibold">💨 Vent de travers</a>
      </div>
    </nav>
    <div class="mt-auto pt-6 border-t border-gray-100 dark:border-gray-800 text-[10px] text-gray-400 dark:text-gray-600 leading-relaxed">
      <strong class="text-gray-500 dark:text-gray-400">Horizon :</strong> 24h glissantes<br>
      Vols AF long-courrier uniquement.
    </div>
  </aside>

  <!-- ─ Contenu ─────────────────────────────────────────────────────────────── -->
  <div class="flex-1 min-w-0 overflow-y-auto">
    <div class="max-w-7xl mx-auto px-4 py-6 xl:px-8">

      <!-- En-tête -->
      <div id="page-header" class="flex items-center justify-between flex-wrap gap-4 mb-6">
        <div>
          <h1 class="text-2xl font-bold tracking-tight text-gray-900 dark:text-white">💨 Vent de Travers</h1>
          <p class="text-gray-500 dark:text-gray-400 text-xs mt-1">Composante crosswind par aéroport — TAF + vols AF</p>
        </div>
        <div class="flex items-center gap-3 no-print">
          <span id="crosswind-updated" class="text-xs text-gray-400 dark:text-gray-500"></span>
          <button
            id="btn-print"
            class="flex items-center gap-1.5 px-3 py-1.5 text-xs font-medium rounded-lg
                   border border-gray-200 dark:border-gray-700
                   bg-white dark:bg-gray-800
                   hover:bg-gray-50 dark:hover:bg-gray-700
                   text-gray-600 dark:text-gray-300 transition"
            title="Imprimer au format A4"
          >🖨️ Imprimer</button>
          <button
            id="btn-refresh"
            class="flex items-center gap-1.5 px-3 py-1.5 text-xs font-medium rounded-lg
                   border border-gray-200 dark:border-gray-700
                   bg-white dark:bg-gray-800
                   hover:bg-gray-50 dark:hover:bg-gray-700
                   text-gray-600 dark:text-gray-300 transition"
            onclick="loadCrosswind(true)"
          >🔄 Actualiser</button>
        </div>
      </div>

      <!-- Config panel -->
      <div id="config-panel" class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-xl shadow-sm p-5 mb-6">
        <div class="grid grid-cols-1 lg:grid-cols-[1fr_1fr_1.5fr] gap-5 items-start">

          <!-- Colonne gauche : ajout escale -->
          <div class="lg:col-span-1">
            <label class="block text-xs font-semibold text-gray-500 dark:text-gray-400 mb-1.5 uppercase tracking-wide">Ajouter une escale (IATA ou OACI)</label>
            <div class="flex items-center gap-2 mb-4">
              <input id="airport-input" type="text" maxlength="4" placeholder="Ex : JFK ou KJFK"
                class="flex-1 max-w-xs border border-gray-300 dark:border-gray-600 rounded-lg px-3 py-1.5 text-sm font-mono uppercase
                       bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100
                       focus:outline-none focus:ring-2 focus:ring-blue-300 dark:focus:ring-blue-700" />
              <button id="btn-add-airport" class="flex items-center gap-1.5 px-3 py-1.5 text-xs font-semibold rounded-lg bg-blue-600 hover:bg-blue-700 text-white transition">
                + Ajouter
              </button>
            </div>
            <div id="airport-selector" class="flex flex-wrap gap-2 min-h-[32px]"></div>
          </div>

          <!-- Colonne centrale : plage horaire -->
          <div class="border-l border-gray-200 dark:border-gray-700 pl-5">
            <div class="flex items-center justify-between mb-3">
              <div class="text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wide">Plage horaire des vols</div>
              <label class="flex items-center gap-2 text-xs text-gray-600 dark:text-gray-400 cursor-pointer">
                <input type="checkbox" id="time-range-enabled" class="rounded border-gray-300 dark:border-gray-600" />
                <span>Personnaliser</span>
              </label>
            </div>
            <div id="time-range-inputs" class="space-y-2 hidden">
              <div class="flex items-center gap-3">
                <label class="text-[11px] text-gray-500 dark:text-gray-400 w-10 shrink-0">Début</label>
                <input type="datetime-local" id="time-start"
                  class="flex-1 border border-gray-300 dark:border-gray-600 rounded-lg px-2 py-1 text-xs
                         bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100
                         focus:outline-none focus:ring-2 focus:ring-blue-300 dark:focus:ring-blue-700" />
              </div>
              <div class="flex items-center gap-3">
                <label class="text-[11px] text-gray-500 dark:text-gray-400 w-10 shrink-0">Fin</label>
                <input type="datetime-local" id="time-end"
                  class="flex-1 border border-gray-300 dark:border-gray-600 rounded-lg px-2 py-1 text-xs
                         bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100
                         focus:outline-none focus:ring-2 focus:ring-blue-300 dark:focus:ring-blue-700" />
              </div>
            </div>
            <div id="time-range-hint" class="text-[11px] text-gray-400 dark:text-gray-600 italic">Par défaut : validité du TAF</div>
          </div>

          <!-- Colonne droite : limites cliquables = filtre type avion -->
          <div class="border-l border-gray-200 dark:border-gray-700 pl-5 lg:col-span-1" style="min-width:0">
            <div class="flex items-center justify-between mb-2">
              <div class="text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wide">Limites vent de travers</div>
              <span class="text-[10px] text-gray-400 dark:text-gray-600 italic">Cliquer pour filtrer</span>
            </div>
            <div class="grid grid-cols-4 gap-x-3 gap-y-2 text-[11px]">
              <div id="ac-filter-B777_B787"
                class="ac-filter-tile cursor-pointer rounded-lg px-2 py-1.5 border border-transparent hover:border-blue-300 dark:hover:border-blue-700 transition select-none text-gray-600 dark:text-gray-400"
                data-group="B777_B787" title="Cliquer pour filtrer / désfiltrer">
                <div class="font-semibold text-gray-700 dark:text-gray-300 mb-0.5 whitespace-nowrap">777 / 787</div>
                <div class="space-y-0.5">
                  <div class="whitespace-nowrap">• Sèche: <span class="font-mono font-bold">45kt</span></div>
                  <div class="whitespace-nowrap">• Mouillée: <span class="font-mono font-bold">40kt</span></div>
                  <div class="whitespace-nowrap">• Contaminée: <span class="font-mono font-bold">35kt</span></div>
                </div>
              </div>
              <div id="ac-filter-A330_A350"
                class="ac-filter-tile cursor-pointer rounded-lg px-2 py-1.5 border border-transparent hover:border-blue-300 dark:hover:border-blue-700 transition select-none text-gray-600 dark:text-gray-400"
                data-group="A330_A350" title="Cliquer pour filtrer / désfiltrer">
                <div class="font-semibold text-gray-700 dark:text-gray-300 mb-0.5 whitespace-nowrap">A350 / A330</div>
                <div class="space-y-0.5">
                  <div class="whitespace-nowrap">• Sèche: <span class="font-mono font-bold">40kt</span></div>
                  <div class="whitespace-nowrap">• Mouillée: <span class="font-mono font-bold">40kt</span></div>
                  <div class="whitespace-nowrap">• Contaminée: <span class="font-mono font-bold">27kt</span></div>
                </div>
              </div>
              <div id="ac-filter-A320"
                class="ac-filter-tile cursor-pointer rounded-lg px-2 py-1.5 border border-transparent hover:border-blue-300 dark:hover:border-blue-700 transition select-none text-gray-600 dark:text-gray-400"
                data-group="A320" title="Cliquer pour filtrer / désfiltrer">
                <div class="font-semibold text-gray-700 dark:text-gray-300 mb-0.5 whitespace-nowrap">A318-321</div>
                <div class="space-y-0.5">
                  <div class="whitespace-nowrap">• Sèche: <span class="font-mono font-bold">38kt</span></div>
                  <div class="whitespace-nowrap">• Mouillée: <span class="font-mono font-bold">38kt</span></div>
                  <div class="whitespace-nowrap">• Contaminée: <span class="font-mono font-bold">29kt</span></div>
                </div>
              </div>
              <div id="ac-filter-A220"
                class="ac-filter-tile cursor-pointer rounded-lg px-2 py-1.5 border border-transparent hover:border-blue-300 dark:hover:border-blue-700 transition select-none text-gray-600 dark:text-gray-400"
                data-group="A220" title="Cliquer pour filtrer / désfiltrer">
                <div class="font-semibold text-gray-700 dark:text-gray-300 mb-0.5 whitespace-nowrap">A220</div>
                <div class="space-y-0.5">
                  <div class="whitespace-nowrap">• Sèche: <span class="font-mono font-bold">29kt</span></div>
                  <div class="whitespace-nowrap">• Mouillée: <span class="font-mono font-bold">29kt</span></div>
                  <div class="whitespace-nowrap">• Contaminée: <span class="font-mono font-bold">27kt</span></div>
                </div>
              </div>
            </div>
          </div>
        </div>
        
        <div id="threshold-legend" class="flex flex-wrap gap-3 items-center text-xs font-semibold border-t border-gray-100 dark:border-gray-800 pt-4 mt-4">
          <span class="text-gray-400 uppercase tracking-wide mr-1">Seuils :</span>
          <span class="flex items-center gap-1"><span class="inline-block w-3 h-3 rounded-sm bg-green-400"></span> OK</span>
          <span class="flex items-center gap-1"><span class="inline-block w-3 h-3 rounded-sm bg-yellow-400"></span> Attention</span>
          <span class="flex items-center gap-1"><span class="inline-block w-3 h-3 rounded-sm bg-orange-400"></span> Limite</span>
          <span class="flex items-center gap-1"><span class="inline-block w-3 h-3 rounded-sm bg-red-500"></span> Dépassé</span>
        </div>
      </div>

      <!-- Results -->
      <div id="crosswind-container">
        <div class="flex items-center justify-center py-20 text-gray-400">
          <div class="text-center"><div class="text-4xl mb-3">💨</div><p class="text-sm">Chargement…</p></div>
        </div>
      </div>

      <div class="print-info">
        Document généré par SkyWatch — Ne pas diffuser en dehors du service
      </div>

    </div>
  </div>

  <script is:inline>
  // ─── CONFIG : pistes & QFU par aéroport ───────────────────────────────────
// decl = déclinaison magnétique en degrés (est positif, ouest négatif)
// Source : NOAA World Magnetic Model 2025 — arrondi à l'entier le plus proche
// Formule : vent_magnétique = vent_vrai (TAF) − déclinaison
const AIRPORT_RUNWAYS = {
  // ── Canada ──────────────────────────────────────────────────────────────────
  CYOW: { iata: 'YOW', name: 'Ottawa',    qfu: [7, 25, 14, 32], decl: -13 },
  CYUL: { iata: 'YUL', name: 'Montreal',  qfu: [6, 24],          decl: -14 },
  CYVR: { iata: 'YVR', name: 'Vancouver', qfu: [8, 26, 13, 31],  decl: +18 },
  CYYZ: { iata: 'YYZ', name: 'Toronto',   qfu: [5, 23, 6, 24, 15, 33], decl: -10 },
  // ── Afrique du Nord / Moyen-Orient ──────────────────────────────────────────
  DAAG: { iata: 'ALG', name: 'Alger',     qfu: [5, 23, 9, 27],   decl: +1 },
  DAOO: { iata: 'ORN', name: 'Oran',      qfu: [7, 25],           decl: +1 },
  // ── Afrique sub-saharienne / Ouest ──────────────────────────────────────────
  DBBB: { iata: 'COO', name: 'Cotonou',            qfu: [6, 24],         decl: -1 },
  DIAP: { iata: 'ABJ', name: 'Abidjan',            qfu: [3, 21],         decl: -6 },
  DNAA: { iata: 'ABV', name: 'Abuja',              qfu: [4, 22],         decl: -1 },
  DNMM: { iata: 'LOS', name: 'Lagos',              qfu: [18, 36],        decl: -1 },
  DTTA: { iata: 'TUN', name: 'Tunis',              qfu: [1, 19, 11, 29], decl: +2 },
  DXXX: { iata: 'LFW', name: 'Lome',               qfu: [4, 22],         decl: -2 },
  // ── Allemagne ───────────────────────────────────────────────────────────────
  EDDB: { iata: 'BER', name: 'Berlin',      qfu: [6, 24],          decl: +4 },
  EDDF: { iata: 'FRA', name: 'Francfort',   qfu: [7, 25, 18, 36],  decl: +3 },
  EDDH: { iata: 'HAM', name: 'Hambourg',    qfu: [5, 23, 15, 33],  decl: +3 },
  EDDL: { iata: 'DUS', name: 'Dusseldorf',  qfu: [5, 23],           decl: +2 },
  EDDM: { iata: 'MUC', name: 'Munich',      qfu: [8, 26],           decl: +3 },
  EDDN: { iata: 'NUE', name: 'Nuremberg',   qfu: [10, 28],          decl: +3 },
  EDDS: { iata: 'STR', name: 'Stuttgart',   qfu: [7, 25],           decl: +3 },
  EDDV: { iata: 'HAJ', name: 'Hanovre',     qfu: [9, 27],           decl: +3 },
  // ── Finlande / Scandinavie ──────────────────────────────────────────────────
  EFHK: { iata: 'HEL', name: 'Helsinki',   qfu: [4, 22, 15, 33],  decl: +7 },
  EFKT: { iata: 'KTT', name: 'Kittila',    qfu: [16, 34],          decl: +9 },
  EFRO: { iata: 'RVN', name: 'Rovaniemi',  qfu: [3, 21],           decl: +9 },
